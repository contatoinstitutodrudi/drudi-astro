---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { UNITS, SPECIALTIES, HEALTH_PLANS, APPOINTMENT_TYPES, WHATSAPP_LINK } from '../lib/constants';
---

<BaseLayout
  title="Agendar Consulta Online | Drudi e Almeida"
  description="Agende sua consulta oftalmológica online na Drudi e Almeida. Escolha a unidade, data e horário. Atendemos em Santana, Tatuapé, Lapa, São Miguel e Guarulhos."
  canonicalPath="/agendar"
>
  <!-- ========== HERO ========== -->
  <section class="relative min-h-[45vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/images/contato-hero-bg.webp')"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy/90 via-navy/70 to-transparent"></div>
    <div class="relative container pb-12 pt-28">
      <div class="max-w-2xl">
        <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Agendar Consulta" }]} />
        <h1 class="font-display text-4xl md:text-5xl text-cream leading-[1.1] mb-4">
          Agende sua <em class="text-gold italic">Consulta</em>
        </h1>
        <p class="font-body text-lg text-cream/80 leading-relaxed">
          Escolha a unidade, data e horário. Confirmamos em até 2 horas pelo WhatsApp.
        </p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- ========== FORMULÁRIO ========== -->
  <section class="section-padding">
    <div class="container">
      <div class="max-w-2xl mx-auto">

        <!-- Stepper -->
        <div id="stepper" class="flex items-center justify-center gap-0 mb-10">
          {[
            { n: 1, label: 'Unidade' },
            { n: 2, label: 'Data & Hora' },
            { n: 3, label: 'Seus Dados' },
          ].map(({ n, label }) => (
            <div class="flex items-center">
              <div class="flex flex-col items-center">
                <div
                  id={`step-circle-${n}`}
                  class={`w-9 h-9 rounded-full flex items-center justify-center font-ui text-sm font-bold transition-all duration-300 ${n === 1 ? 'bg-navy text-cream' : 'bg-border text-muted-foreground'}`}
                >
                  {n}
                </div>
                <span id={`step-label-${n}`} class={`font-ui text-xs mt-1 ${n === 1 ? 'text-navy font-semibold' : 'text-muted-foreground'}`}>{label}</span>
              </div>
              {n < 3 && (
                <div id={`step-line-${n}`} class="w-16 sm:w-24 h-0.5 bg-border mx-2 mb-4 transition-colors duration-300"></div>
              )}
            </div>
          ))}
        </div>

        <!-- STEP 0: Escolher Unidade -->
        <div id="step-0" class="step-panel">
          <h2 class="font-display text-2xl text-navy mb-2">Escolha a unidade</h2>
          <p class="font-body text-sm text-muted-foreground mb-6">Selecione a unidade mais próxima de você.</p>
          <div class="grid grid-cols-1 gap-3">
            {UNITS.map(u => (
              <button
                type="button"
                class="unit-btn text-left rounded-xl border-2 border-border p-4 hover:border-navy/40 transition-all duration-200 group"
                data-value={u.value}
              >
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-lg bg-navy/8 flex items-center justify-center flex-shrink-0 group-hover:bg-navy/15 transition-colors">
                    <svg class="w-4 h-4 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                  </div>
                  <div>
                    <div class="font-ui text-sm font-semibold text-navy">{u.value}</div>
                    <div class="font-body text-xs text-muted-foreground">{u.label.split(' — ')[1]}</div>
                  </div>
                </div>
              </button>
            ))}
          </div>
          <div class="flex justify-end mt-8">
            <button id="btn-0-next" type="button" disabled
              class="inline-flex items-center gap-2 bg-navy text-cream font-ui text-sm font-semibold px-6 py-3 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed hover:bg-navy/90 transition-colors">
              Próximo
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <!-- STEP 1: Data e Hora -->
        <div id="step-1" class="step-panel hidden">
          <h2 class="font-display text-2xl text-navy mb-2">Escolha a data e horário</h2>
          <p class="font-body text-sm text-muted-foreground mb-6">Atendemos seg–sex das 8h às 18h e sábados das 8h às 12h.</p>

          <!-- Seletor de data -->
          <div class="mb-6">
            <label class="font-ui text-xs font-semibold tracking-wide text-muted-foreground uppercase mb-3 block">Data</label>
            <div id="days-grid" class="grid grid-cols-2 sm:grid-cols-3 gap-2 max-h-56 overflow-y-auto pr-1"></div>
          </div>

          <!-- Seletor de horário -->
          <div id="slots-section" class="mb-6 hidden">
            <label class="font-ui text-xs font-semibold tracking-wide text-muted-foreground uppercase mb-3 block">Horário disponível</label>
            <div id="slots-loading" class="hidden flex items-center gap-2 text-muted-foreground text-sm">
              <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
              Verificando disponibilidade...
            </div>
            <div id="slots-dayoff" class="hidden text-sm text-muted-foreground">Não atendemos neste dia.</div>
            <div id="slots-empty" class="hidden text-sm text-amber-600 font-medium">Todos os horários estão ocupados. Escolha outro dia.</div>
            <div id="slots-grid" class="flex flex-wrap gap-2"></div>
          </div>

          <div class="flex justify-between mt-8">
            <button id="btn-1-back" type="button"
              class="inline-flex items-center gap-2 border border-border text-foreground font-ui text-sm font-semibold px-6 py-3 rounded-lg hover:bg-muted/50 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Voltar
            </button>
            <button id="btn-1-next" type="button" disabled
              class="inline-flex items-center gap-2 bg-navy text-cream font-ui text-sm font-semibold px-6 py-3 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed hover:bg-navy/90 transition-colors">
              Próximo
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <!-- STEP 2: Dados pessoais -->
        <div id="step-2" class="step-panel hidden">
          <h2 class="font-display text-2xl text-navy mb-2">Seus dados</h2>
          <p class="font-body text-sm text-muted-foreground mb-6">Preencha para que nossa equipe possa confirmar sua consulta.</p>

          <!-- Resumo -->
          <div id="summary-card" class="bg-muted/40 border border-border/60 rounded-xl p-4 mb-6 flex flex-wrap gap-4 text-sm"></div>

          <div class="space-y-4">
            <!-- Especialidade -->
            <div>
              <label class="font-ui text-sm font-medium mb-1.5 block text-foreground">Especialidade</label>
              <select id="field-specialty" class="w-full border border-border rounded-lg px-3 py-2.5 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30">
                {SPECIALTIES.map(s => <option value={s.value}>{s.label}</option>)}
              </select>
            </div>

            <!-- Plano de saúde -->
            <div>
              <label class="font-ui text-sm font-medium mb-1.5 block text-foreground">Plano de saúde</label>
              <select id="field-health-plan" class="w-full border border-border rounded-lg px-3 py-2.5 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30">
                {HEALTH_PLANS.map(p => <option value={p}>{p}</option>)}
              </select>
              <input id="field-health-plan-other" type="text" placeholder="Nome do seu plano de saúde"
                class="hidden mt-2 w-full border border-border rounded-lg px-3 py-2.5 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30" />
            </div>

            <!-- Tipo de consulta -->
            <div>
              <label class="font-ui text-sm font-medium mb-1.5 block text-foreground">Tipo de consulta</label>
              <select id="field-type" class="w-full border border-border rounded-lg px-3 py-2.5 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30">
                {APPOINTMENT_TYPES.map(t => <option value={t.value}>{t.label}</option>)}
              </select>
            </div>

            <!-- Nome -->
            <div>
              <label class="font-ui text-sm font-medium mb-1.5 block text-foreground">
                Nome completo <span class="text-red-500">*</span>
              </label>
              <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                <input id="field-name" type="text" placeholder="Seu nome completo"
                  class="w-full border border-border rounded-lg pl-9 pr-3 py-2.5 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30" />
              </div>
            </div>

            <!-- Telefone -->
            <div>
              <label class="font-ui text-sm font-medium mb-1.5 block text-foreground">
                Telefone / WhatsApp <span class="text-red-500">*</span>
              </label>
              <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <input id="field-phone" type="tel" placeholder="(11) 99999-9999"
                  class="w-full border border-border rounded-lg pl-9 pr-3 py-2.5 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30" />
              </div>
            </div>

            <!-- E-mail -->
            <div>
              <label class="font-ui text-sm font-medium mb-1.5 block text-foreground">
                E-mail <span class="text-muted-foreground text-xs font-normal">(opcional — para confirmação)</span>
              </label>
              <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <input id="field-email" type="email" placeholder="seu@email.com"
                  class="w-full border border-border rounded-lg pl-9 pr-3 py-2.5 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30" />
              </div>
            </div>

            <!-- Observações -->
            <div>
              <label class="font-ui text-sm font-medium mb-1.5 block text-foreground">
                Observações <span class="text-muted-foreground text-xs font-normal">(opcional)</span>
              </label>
              <textarea id="field-notes" rows="3" placeholder="Ex: Tenho dificuldade para enxergar de longe há 3 meses..."
                class="w-full border border-border rounded-lg px-3 py-2.5 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30 resize-none"></textarea>
            </div>
          </div>

          <div id="form-error" class="hidden mt-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"></div>

          <div class="flex justify-between mt-8">
            <button id="btn-2-back" type="button"
              class="inline-flex items-center gap-2 border border-border text-foreground font-ui text-sm font-semibold px-6 py-3 rounded-lg hover:bg-muted/50 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Voltar
            </button>
            <button id="btn-submit" type="button"
              class="inline-flex items-center gap-2 bg-gold text-navy font-ui text-sm font-bold px-7 py-3 rounded-lg hover:bg-gold-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
              <span id="btn-submit-text">Confirmar Agendamento</span>
              <svg id="btn-submit-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            </button>
          </div>
        </div>

        <!-- STEP 3: Sucesso -->
        <div id="step-3" class="step-panel hidden text-center py-8">
          <div class="w-20 h-20 mx-auto rounded-full bg-green-100 flex items-center justify-center mb-6">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h2 class="font-display text-3xl text-navy mb-3">Agendamento Confirmado!</h2>
          <p class="font-body text-base text-muted-foreground mb-2 max-w-md mx-auto" id="success-msg">
            Recebemos seu pedido. Nossa equipe entrará em contato em breve para confirmar.
          </p>
          <p class="font-body text-sm text-muted-foreground mb-8">
            Se informou seu e-mail, você receberá uma confirmação em instantes.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white font-ui text-sm font-bold px-6 py-3 rounded-lg hover:bg-[#22c55e] transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Falar pelo WhatsApp
            </a>
            <a href="/"
              class="inline-flex items-center justify-center gap-2 border border-border text-foreground font-ui text-sm font-semibold px-6 py-3 rounded-lg hover:bg-muted/50 transition-colors">
              Voltar ao início
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- WhatsApp fixo -->
  <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition-transform"
    aria-label="Falar pelo WhatsApp">
    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</BaseLayout>

<script>
// ============================================================
// Formulário de Agendamento — Vanilla JS
// ============================================================
(function () {
  // Estado
  let currentStep = 0;
  let selectedUnit = '';
  let selectedDate = '';
  let selectedSlot: { hour: number; minute: number } | null = null;

  // Helpers
  const $ = (id: string) => document.getElementById(id)!;
  const show = (id: string) => $(`step-${id}`).classList.remove('hidden');
  const hide = (id: string) => $(`step-${id}`).classList.add('hidden');

  function formatDateBR(d: string) {
    const [y, m, day] = d.split('-');
    const months = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
    const weekdays = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
    const dt = new Date(Number(y), Number(m) - 1, Number(day));
    return `${weekdays[dt.getDay()]}, ${day}/${m}`;
  }

  function formatHour(h: number, m: number) {
    return `${String(h).padStart(2, '0')}h${m > 0 ? String(m).padStart(2, '0') : ''}`;
  }

  // Gerar próximos 30 dias (excluindo domingos)
  function generateDays() {
    const grid = $('days-grid');
    grid.innerHTML = '';
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    let count = 0;
    let d = new Date(today);
    d.setDate(d.getDate() + 1); // começa amanhã

    while (count < 30) {
      if (d.getDay() !== 0) { // pula domingos
        const val = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'day-btn py-2.5 px-3 rounded-lg border text-sm font-ui transition-all border-border hover:border-navy/30 text-foreground';
        btn.dataset.value = val;
        btn.textContent = formatDateBR(val);
        btn.addEventListener('click', () => selectDate(val));
        grid.appendChild(btn);
        count++;
      }
      d.setDate(d.getDate() + 1);
    }
  }

  // Atualizar stepper visual
  function updateStepper(step: number) {
    for (let i = 1; i <= 3; i++) {
      const circle = $(`step-circle-${i}`);
      const label = $(`step-label-${i}`);
      const active = i === step + 1;
      const done = i < step + 1;
      circle.className = `w-9 h-9 rounded-full flex items-center justify-center font-ui text-sm font-bold transition-all duration-300 ${
        active ? 'bg-navy text-cream' : done ? 'bg-gold text-navy' : 'bg-border text-muted-foreground'
      }`;
      label.className = `font-ui text-xs mt-1 ${active ? 'text-navy font-semibold' : done ? 'text-gold font-semibold' : 'text-muted-foreground'}`;
      if (i <= 2) {
        const line = $(`step-line-${i}`);
        line.className = `w-16 sm:w-24 h-0.5 mx-2 mb-4 transition-colors duration-300 ${done ? 'bg-gold' : 'bg-border'}`;
      }
    }
  }

  function goToStep(step: number) {
    hide(String(currentStep));
    currentStep = step;
    show(String(currentStep));
    updateStepper(currentStep);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Step 0: Selecionar unidade
  document.querySelectorAll('.unit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      selectedUnit = (btn as HTMLElement).dataset.value ?? '';
      document.querySelectorAll('.unit-btn').forEach(b => {
        b.classList.remove('border-navy', 'bg-navy/5');
        b.classList.add('border-border');
      });
      btn.classList.remove('border-border');
      btn.classList.add('border-navy', 'bg-navy/5');
      ($('btn-0-next') as HTMLButtonElement).disabled = false;
    });
  });

  $('btn-0-next').addEventListener('click', () => {
    if (!selectedUnit) return;
    generateDays();
    goToStep(1);
  });

  // Step 1: Selecionar data
  function selectDate(val: string) {
    selectedDate = val;
    selectedSlot = null;
    ($('btn-1-next') as HTMLButtonElement).disabled = true;

    document.querySelectorAll('.day-btn').forEach(b => {
      const active = (b as HTMLElement).dataset.value === val;
      b.className = `day-btn py-2.5 px-3 rounded-lg border text-sm font-ui transition-all ${
        active ? 'border-gold bg-gold/10 text-navy font-semibold' : 'border-border hover:border-navy/30 text-foreground'
      }`;
    });

    loadSlots(val);
  }

  async function loadSlots(date: string) {
    const section = $('slots-section');
    const loading = $('slots-loading');
    const dayoff = $('slots-dayoff');
    const empty = $('slots-empty');
    const grid = $('slots-grid');

    section.classList.remove('hidden');
    loading.classList.remove('hidden');
    dayoff.classList.add('hidden');
    empty.classList.add('hidden');
    grid.innerHTML = '';

    try {
      const res = await fetch(`/api/agendamento/slots?date=${date}&unit=${encodeURIComponent(selectedUnit)}`);
      const data = await res.json() as { dayOff?: boolean; slots?: { hour: number; minute: number; available: boolean }[] };

      loading.classList.add('hidden');

      if (data.dayOff) {
        dayoff.classList.remove('hidden');
        return;
      }

      const available = (data.slots ?? []).filter(s => s.available);
      if (available.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      available.forEach(slot => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'slot-btn px-4 py-2 rounded-lg border font-ui text-sm transition-all border-border hover:border-navy/30 text-foreground';
        btn.textContent = formatHour(slot.hour, slot.minute);
        btn.addEventListener('click', () => {
          selectedSlot = slot;
          document.querySelectorAll('.slot-btn').forEach(b => {
            b.className = 'slot-btn px-4 py-2 rounded-lg border font-ui text-sm transition-all border-border hover:border-navy/30 text-foreground';
          });
          btn.className = 'slot-btn px-4 py-2 rounded-lg border font-ui text-sm transition-all border-gold bg-gold text-navy font-bold';
          ($('btn-1-next') as HTMLButtonElement).disabled = false;
        });
        grid.appendChild(btn);
      });
    } catch {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  }

  $('btn-1-back').addEventListener('click', () => goToStep(0));
  $('btn-1-next').addEventListener('click', () => {
    if (!selectedDate || !selectedSlot) return;
    // Preencher resumo
    const card = $('summary-card');
    card.innerHTML = `
      <div class="flex items-center gap-2"><svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg><span class="font-semibold text-navy">${selectedUnit}</span></div>
      <div class="flex items-center gap-2"><svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg><span>${formatDateBR(selectedDate)}</span></div>
      <div class="flex items-center gap-2"><svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><span>${formatHour(selectedSlot!.hour, selectedSlot!.minute)}</span></div>
    `;
    goToStep(2);
  });

  // Step 2: Dados pessoais
  $('btn-2-back').addEventListener('click', () => goToStep(1));

  // Plano de saúde "Outro"
  $('field-health-plan').addEventListener('change', (e) => {
    const val = (e.target as HTMLSelectElement).value;
    const other = $('field-health-plan-other') as HTMLInputElement;
    if (val === 'Outro') {
      other.classList.remove('hidden');
    } else {
      other.classList.add('hidden');
    }
  });

  $('btn-submit').addEventListener('click', async () => {
    const name = ($('field-name') as HTMLInputElement).value.trim();
    const phone = ($('field-phone') as HTMLInputElement).value.trim();
    const email = ($('field-email') as HTMLInputElement).value.trim();
    const specialty = ($('field-specialty') as HTMLSelectElement).value;
    const healthPlanSelect = ($('field-health-plan') as HTMLSelectElement).value;
    const healthPlanOther = ($('field-health-plan-other') as HTMLInputElement).value.trim();
    const health_plan = healthPlanSelect === 'Outro' ? (healthPlanOther || 'Outro') : healthPlanSelect;
    const appointment_type = ($('field-type') as HTMLSelectElement).value;
    const notes = ($('field-notes') as HTMLTextAreaElement).value.trim();

    const errorEl = $('form-error');
    errorEl.classList.add('hidden');

    if (!name) { showError('Informe seu nome completo.'); return; }
    if (!phone) { showError('Informe seu telefone/WhatsApp.'); return; }

    setSubmitting(true);

    try {
      const res = await fetch('/api/agendamento/criar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          patient_name: name,
          patient_phone: phone,
          patient_email: email || null,
          unit: selectedUnit,
          specialty,
          health_plan,
          appointment_date: selectedDate,
          appointment_hour: selectedSlot!.hour,
          appointment_minute: selectedSlot!.minute,
          appointment_type,
          notes: notes || null,
        }),
      });

      const data = await res.json() as { success?: boolean; error?: string };

      if (!res.ok || !data.success) {
        showError(data.error ?? 'Erro ao criar agendamento. Tente novamente.');
        setSubmitting(false);
        return;
      }

      // Sucesso
      const successMsg = $('success-msg');
      successMsg.textContent = `Recebemos seu pedido, ${name}! Nossa equipe confirmará em breve pelo WhatsApp ${phone}.`;
      goToStep(3);
    } catch {
      showError('Erro de conexão. Verifique sua internet e tente novamente.');
      setSubmitting(false);
    }
  });

  function showError(msg: string) {
    const el = $('form-error');
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function setSubmitting(loading: boolean) {
    const btn = $('btn-submit') as HTMLButtonElement;
    const text = $('btn-submit-text');
    const spinner = $('btn-submit-spinner');
    btn.disabled = loading;
    text.textContent = loading ? 'Enviando...' : 'Confirmar Agendamento';
    spinner.classList.toggle('hidden', !loading);
  }
})();
</script>
