---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { UNITS, HEALTH_PLANS, APPOINTMENT_TYPES, SPECIALTIES, WHATSAPP_LINK } from '../lib/constants';
---
<BaseLayout
  title="Agendar Consulta Online | Drudi e Almeida"
  description="Agende sua consulta oftalmológica online na Drudi e Almeida. Escolha a unidade, data e horário. Atendemos em Santana, Tatuapé, Lapa, São Miguel e Guarulhos."
  canonicalPath="/agendar"
>
  <!-- ========== HERO ========== -->
  <section class="relative min-h-[38vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/images/contato-hero-bg.webp')"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy/90 via-navy/70 to-transparent"></div>
    <div class="relative container pb-10 pt-[100px] md:pt-[120px]">
      <div class="max-w-2xl">
        <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Agendar Consulta" }]} />
        <h1 class="font-display text-4xl md:text-5xl text-cream leading-[1.1] mb-4">
          Agende sua <em class="text-gold italic">Consulta</em>
        </h1>
        <p class="font-body text-lg text-cream/80 leading-relaxed">
          Em poucos cliques, escolha a unidade, data e horário. Rápido, seguro e sem complicações.
        </p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- ========== AGENDAMENTO ========== -->
  <section class="section-padding -mt-6 relative z-10">
    <div class="container max-w-3xl">

      <!-- ── Progress Bar ── -->
      <div id="progress-bar" class="mb-10">
        <div class="flex items-center justify-between relative">
          <div class="absolute top-5 left-[12%] right-[12%] h-[2px] bg-border/60"></div>
          <div id="progress-line" class="absolute top-5 left-[12%] h-[2px] bg-gold transition-all duration-700 ease-out" style="width:0%"></div>
          {[
            { n:1, label:'Unidade' },
            { n:2, label:'Data & Hora' },
            { n:3, label:'Seus Dados' },
            { n:4, label:'Confirmação' },
          ].map(({n,label})=>(
            <div class="flex flex-col items-center relative z-10" style="flex:1">
              <div id={`sc-${n}`} class={`w-10 h-10 rounded-full flex items-center justify-center font-ui text-sm font-bold transition-all duration-500 ${n===1?'bg-gold text-navy shadow-lg shadow-gold/25 scale-110':'bg-white border-2 border-border text-muted-foreground'}`}>{n}</div>
              <span id={`sl-${n}`} class={`font-ui text-[11px] mt-2 transition-colors duration-300 ${n===1?'text-gold font-bold':'text-muted-foreground'}`}>{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- ── Container dos passos ── -->
      <div id="steps-wrap" class="relative" style="min-height:380px">

        <!-- ===== PASSO 1 — UNIDADE ===== -->
        <div id="panel-1" class="step-panel">
          <div class="text-center mb-8">
            <h2 class="font-display text-2xl md:text-3xl text-navy mb-2">Onde deseja ser atendido?</h2>
            <p class="font-body text-sm text-muted-foreground">Clique na unidade para continuar automaticamente.</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
            {UNITS.map(u=>(
              <button type="button" data-unit={u.value}
                class="unit-card group relative flex items-center gap-4 p-5 rounded-xl border-2 border-border/60 bg-white hover:border-gold/50 hover:shadow-lg hover:shadow-gold/10 transition-all duration-300 text-left cursor-pointer">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-navy/8 to-navy/4 flex items-center justify-center flex-shrink-0 group-hover:from-gold/15 group-hover:to-gold/5 transition-all duration-300">
                  <svg class="w-5 h-5 text-navy group-hover:text-gold transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-ui text-[15px] font-bold text-navy group-hover:text-gold transition-colors">{u.value}</div>
                  <div class="font-body text-xs text-muted-foreground mt-0.5 truncate">{u.label.split('—')[1]?.trim()}</div>
                </div>
                <svg class="w-5 h-5 text-gold opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
                <div class="unit-check absolute top-3 right-3 w-6 h-6 rounded-full bg-gold text-navy flex items-center justify-center opacity-0 scale-75 transition-all duration-300">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                </div>
              </button>
            ))}
          </div>
        </div>

        <!-- ===== PASSO 2 — DATA & HORA ===== -->
        <div id="panel-2" class="step-panel hidden">
          <div class="text-center mb-6">
            <h2 class="font-display text-2xl md:text-3xl text-navy mb-2">Escolha a data e horário</h2>
            <p class="font-body text-sm text-muted-foreground">Selecione o dia e depois o horário desejado.</p>
          </div>
          <!-- badge + voltar -->
          <div class="flex items-center justify-center gap-2 mb-6">
            <button id="back1" type="button" class="flex items-center gap-1 text-xs font-ui text-muted-foreground hover:text-navy transition-colors">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg>
              Alterar unidade
            </button>
            <span class="text-border">|</span>
            <span id="badge-unit" class="inline-flex items-center gap-1.5 bg-gold/10 border border-gold/30 rounded-full px-3 py-1 font-ui text-xs font-semibold text-gold">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/></svg>
              <span id="badge-unit-name"></span>
            </span>
          </div>
          <!-- Calendário horizontal -->
          <div class="mb-6">
            <div class="flex items-center justify-between mb-3">
              <button id="cal-prev" type="button" class="w-8 h-8 rounded-lg border border-border hover:border-gold/50 flex items-center justify-center text-muted-foreground hover:text-gold transition-all"><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg></button>
              <span id="cal-month" class="font-ui text-sm font-semibold text-navy"></span>
              <button id="cal-next" type="button" class="w-8 h-8 rounded-lg border border-border hover:border-gold/50 flex items-center justify-center text-muted-foreground hover:text-gold transition-all"><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg></button>
            </div>
            <div id="cal-days" class="flex gap-2 overflow-x-auto pb-2 snap-x snap-mandatory" style="-webkit-overflow-scrolling:touch"></div>
          </div>
          <!-- Horários -->
          <div id="slots-wrap" class="hidden">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-1 h-5 bg-gold rounded-full"></div>
              <h3 class="font-ui text-sm font-semibold text-navy">Horários disponíveis</h3>
              <span id="slots-date-lbl" class="font-body text-xs text-muted-foreground"></span>
            </div>
            <div id="slots-loading" class="hidden flex items-center justify-center py-8">
              <div class="w-5 h-5 border-2 border-gold border-t-transparent rounded-full animate-spin"></div>
              <span class="ml-3 font-ui text-sm text-muted-foreground">Carregando...</span>
            </div>
            <div id="slots-grid" class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 gap-2"></div>
            <div id="slots-empty" class="hidden text-center py-8">
              <p class="font-ui text-sm text-muted-foreground">Nenhum horário disponível neste dia.</p>
              <p class="font-body text-xs text-muted-foreground/70 mt-1">Tente outro dia ou unidade.</p>
            </div>
            <div id="slots-dayoff" class="hidden text-center py-8">
              <p class="font-ui text-sm text-muted-foreground">Dia indisponível para agendamento.</p>
            </div>
          </div>
        </div>

        <!-- ===== PASSO 3 — DADOS ===== -->
        <div id="panel-3" class="step-panel hidden">
          <div class="text-center mb-6">
            <h2 class="font-display text-2xl md:text-3xl text-navy mb-2">Seus dados</h2>
            <p class="font-body text-sm text-muted-foreground">Preencha para finalizar o agendamento.</p>
          </div>
          <!-- Resumo mini -->
          <div class="flex flex-wrap items-center justify-center gap-2 mb-8">
            <button id="back2" type="button" class="flex items-center gap-1 text-xs font-ui text-muted-foreground hover:text-navy transition-colors">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg>Voltar
            </button>
            <span class="text-border">|</span>
            <span id="sum-unit" class="inline-flex items-center gap-1 bg-navy/5 rounded-full px-3 py-1 font-ui text-[11px] text-navy font-semibold"></span>
            <span id="sum-date" class="inline-flex items-center gap-1 bg-navy/5 rounded-full px-3 py-1 font-ui text-[11px] text-navy font-semibold"></span>
            <span id="sum-time" class="inline-flex items-center gap-1 bg-gold/10 border border-gold/30 rounded-full px-3 py-1 font-ui text-[11px] text-gold font-bold"></span>
          </div>
          <!-- Form -->
          <form id="bk-form" class="max-w-lg mx-auto space-y-5" novalidate>
            <div>
              <label class="font-ui text-xs font-semibold text-navy mb-1.5 block">Nome completo *</label>
              <input type="text" name="patient_name" required placeholder="Seu nome completo" class="w-full px-4 py-3 rounded-xl border-2 border-border/60 bg-white font-body text-sm text-navy placeholder:text-muted-foreground/50 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"/>
            </div>
            <div>
              <label class="font-ui text-xs font-semibold text-navy mb-1.5 block">Telefone (WhatsApp) *</label>
              <input type="tel" name="patient_phone" id="inp-phone" required placeholder="(11) 99999-9999" class="w-full px-4 py-3 rounded-xl border-2 border-border/60 bg-white font-body text-sm text-navy placeholder:text-muted-foreground/50 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"/>
            </div>
            <div>
              <label class="font-ui text-xs font-semibold text-navy mb-1.5 block">E-mail <span class="text-muted-foreground font-normal">(para confirmação)</span></label>
              <input type="email" name="patient_email" placeholder="seu@email.com" class="w-full px-4 py-3 rounded-xl border-2 border-border/60 bg-white font-body text-sm text-navy placeholder:text-muted-foreground/50 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"/>
            </div>
            <div>
              <label class="font-ui text-xs font-semibold text-navy mb-2 block">Tipo de consulta *</label>
              <div class="grid grid-cols-3 gap-3">
                {APPOINTMENT_TYPES.map((t,i)=>(
                  <label class="type-opt relative flex flex-col items-center gap-2 p-4 rounded-xl border-2 border-border/60 bg-white cursor-pointer hover:border-gold/40 hover:shadow-md transition-all duration-300">
                    <input type="radio" name="appointment_type" value={t.value} class="sr-only" checked={i===0}/>
                    {t.value==='primeira_vez' && <svg class="w-6 h-6 text-navy" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>}
                    {t.value==='retorno' && <svg class="w-6 h-6 text-navy" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>}
                    {t.value==='exame' && <svg class="w-6 h-6 text-navy" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>}
                    <span class="font-ui text-xs font-semibold text-navy">{t.label}</span>
                    <div class="tcheck absolute top-2 right-2 w-5 h-5 rounded-full bg-gold text-navy flex items-center justify-center opacity-0 scale-75 transition-all duration-300"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></div>
                  </label>
                ))}
              </div>
            </div>
            <div>
              <label class="font-ui text-xs font-semibold text-navy mb-1.5 block">Convênio / Particular *</label>
              <select name="health_plan" required class="w-full px-4 py-3 rounded-xl border-2 border-border/60 bg-white font-body text-sm text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all appearance-none" style="background-image:url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23999%22 stroke-width=%222%22%3E%3Cpath d=%22M6 9l6 6 6-6%22/%3E%3C/svg%3E');background-repeat:no-repeat;background-position:right 16px center">
                <option value="" disabled selected>Selecione...</option>
                {HEALTH_PLANS.map(p=>(<option value={p}>{p}</option>))}
              </select>
            </div>
            <div>
              <label class="font-ui text-xs font-semibold text-navy mb-1.5 block">Observações <span class="text-muted-foreground font-normal">(opcional)</span></label>
              <textarea name="notes" rows={2} placeholder="Ex: preciso de acessibilidade, tenho urgência..." class="w-full px-4 py-3 rounded-xl border-2 border-border/60 bg-white font-body text-sm text-navy placeholder:text-muted-foreground/50 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all resize-none"></textarea>
            </div>
            <input type="hidden" name="unit" id="f-unit"/>
            <input type="hidden" name="appointment_date" id="f-date"/>
            <input type="hidden" name="appointment_hour" id="f-hour"/>
            <input type="hidden" name="appointment_minute" id="f-min"/>
            <div>
              <label class="font-ui text-xs font-semibold text-navy mb-1.5 block">Especialidade *</label>
              <select name="specialty" required class="w-full px-4 py-3 rounded-xl border-2 border-border/60 bg-white font-body text-sm text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all appearance-none" style="background-image:url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23999%22 stroke-width=%222%22%3E%3Cpath d=%22M6 9l6 6 6-6%22/%3E%3C/svg%3E');background-repeat:no-repeat;background-position:right 16px center">
                <option value="" disabled selected>Selecione a especialidade...</option>
                {SPECIALTIES.map(s=>(<option value={s.value}>{s.label}</option>))}
              </select>
            </div>
            <button type="submit" id="btn-submit" class="w-full flex items-center justify-center gap-2 bg-gold text-navy font-ui text-sm font-bold px-8 py-4 rounded-xl hover:bg-gold-light hover:shadow-lg hover:shadow-gold/20 active:scale-[0.98] transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed">
              <span id="btn-txt">Confirmar Agendamento</span>
              <div id="btn-spin" class="hidden w-5 h-5 border-2 border-navy border-t-transparent rounded-full animate-spin"></div>
            </button>
            <div id="form-err" class="hidden text-center"><p class="font-ui text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3"></p></div>
          </form>
        </div>

        <!-- ===== PASSO 4 — CONFIRMAÇÃO ===== -->
        <div id="panel-4" class="step-panel hidden">
          <div class="text-center py-8">
            <div class="relative w-20 h-20 mx-auto mb-6">
              <div id="conf-circle" class="absolute inset-0 rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 shadow-lg shadow-emerald-500/30 flex items-center justify-center" style="transform:scale(0);transition:transform .5s cubic-bezier(.34,1.56,.64,1)">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path id="conf-path" d="M5 13l4 4L19 7" stroke-dasharray="30" stroke-dashoffset="30" style="transition:stroke-dashoffset .6s ease .3s"/></svg>
              </div>
            </div>
            <h2 class="font-display text-2xl md:text-3xl text-navy mb-2">Agendamento Confirmado!</h2>
            <p class="font-body text-sm text-muted-foreground mb-8 max-w-md mx-auto">Sua consulta foi agendada com sucesso. Você receberá um e-mail de confirmação em breve.</p>
            <div class="max-w-sm mx-auto bg-white border-2 border-border/60 rounded-2xl overflow-hidden mb-8">
              <div class="bg-navy px-6 py-4"><p class="font-ui text-xs text-gold tracking-wider uppercase font-bold">Resumo do Agendamento</p></div>
              <div class="px-6 py-5 space-y-3 text-left">
                <div class="flex items-center gap-3"><svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/></svg><div><div class="font-ui text-[10px] text-muted-foreground uppercase tracking-wider">Unidade</div><div id="c-unit" class="font-ui text-sm text-navy font-semibold"></div></div></div>
                <div class="h-px bg-border/50"></div>
                <div class="flex items-center gap-3"><svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg><div><div class="font-ui text-[10px] text-muted-foreground uppercase tracking-wider">Data</div><div id="c-date" class="font-ui text-sm text-navy font-semibold"></div></div></div>
                <div class="h-px bg-border/50"></div>
                <div class="flex items-center gap-3"><svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg><div><div class="font-ui text-[10px] text-muted-foreground uppercase tracking-wider">Horário</div><div id="c-time" class="font-ui text-sm text-navy font-semibold"></div></div></div>
                <div class="h-px bg-border/50"></div>
                <div class="flex items-center gap-3"><svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/></svg><div><div class="font-ui text-[10px] text-muted-foreground uppercase tracking-wider">Tipo</div><div id="c-type" class="font-ui text-sm text-navy font-semibold"></div></div></div>
              </div>
            </div>
            <div class="flex flex-col sm:flex-row gap-3 justify-center max-w-sm mx-auto">
              <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer" class="flex-1 inline-flex items-center justify-center gap-2 bg-[#25D366] text-white font-ui text-sm font-bold px-6 py-3 rounded-xl hover:bg-[#20bd5a] transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
                Falar pelo WhatsApp
              </a>
              <a href="/" class="flex-1 inline-flex items-center justify-center gap-2 border-2 border-border text-navy font-ui text-sm font-semibold px-6 py-3 rounded-xl hover:bg-navy/5 transition-colors">Voltar ao início</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WhatsApp fixo -->
  <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition-transform" aria-label="WhatsApp">
    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</BaseLayout>

<style>
  .step-panel{animation:fadeUp .4s ease-out}
  @keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
  #cal-days::-webkit-scrollbar{height:4px}
  #cal-days::-webkit-scrollbar-thumb{background:#c9a961;border-radius:4px}
  .day-card{min-width:68px;scroll-snap-align:start;transition:all .2s}
  .day-card:not(.off):hover{border-color:rgba(201,169,97,.5);box-shadow:0 4px 12px rgba(201,169,97,.15)}
  .day-card.sel{border-color:#c9a961;background:linear-gradient(135deg,rgba(201,169,97,.12),rgba(201,169,97,.04));box-shadow:0 4px 16px rgba(201,169,97,.2)}
  .day-card.off{opacity:.35;cursor:not-allowed}
  .slot-btn{transition:all .2s}
  .slot-btn:not(:disabled):hover{border-color:#c9a961;background:rgba(201,169,97,.08);transform:translateY(-1px);box-shadow:0 2px 8px rgba(201,169,97,.15)}
  .slot-btn.sel{background:#c9a961;color:#2c3e50;border-color:#c9a961;font-weight:700;box-shadow:0 4px 12px rgba(201,169,97,.3)}
  .slot-btn:disabled{opacity:.3;cursor:not-allowed;text-decoration:line-through}
  .type-opt:has(input:checked){border-color:#c9a961;background:rgba(201,169,97,.05);box-shadow:0 2px 12px rgba(201,169,97,.15)}
  .type-opt:has(input:checked) .tcheck{opacity:1;transform:scale(1)}
  .unit-card.sel{border-color:#c9a961;background:linear-gradient(135deg,rgba(201,169,97,.08),rgba(201,169,97,.02));box-shadow:0 4px 20px rgba(201,169,97,.15)}
  .unit-card.sel .unit-check{opacity:1;transform:scale(1)}
</style>

<script>
document.addEventListener('DOMContentLoaded',()=>{
  // ── Estado ──
  let step=1, unit='', date='', hour=-1, minute=-1, calOff=0;
  const DAYS=30;
  const WD=['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  const MO=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
  const $=(id:string)=>document.getElementById(id)!;
  const TYPE_LABELS:Record<string,string>={primeira_vez:'Primeira Consulta',retorno:'Retorno',exame:'Exame / Procedimento'};

  // ── Navegar passos ──
  function go(s:number){
    for(let i=1;i<=4;i++){const p=$(`panel-${i}`);if(p){p.classList.add('hidden');}}
    const p=$(`panel-${s}`);if(p){p.classList.remove('hidden');p.style.animation='none';p.offsetHeight;p.style.animation='';}
    const pcts=[0,26.6,53.3,80];
    const line=$('progress-line');if(line)(line as HTMLElement).style.width=pcts[s-1]+'%';
    for(let i=1;i<=4;i++){
      const c=$(`sc-${i}`),l=$(`sl-${i}`);if(!c||!l)continue;
      if(i<s){c.className='w-10 h-10 rounded-full flex items-center justify-center font-ui text-sm font-bold transition-all duration-500 bg-gold text-navy';l.className='font-ui text-[11px] mt-2 transition-colors duration-300 text-gold font-bold';}
      else if(i===s){c.className='w-10 h-10 rounded-full flex items-center justify-center font-ui text-sm font-bold transition-all duration-500 bg-gold text-navy shadow-lg shadow-gold/25 scale-110';l.className='font-ui text-[11px] mt-2 transition-colors duration-300 text-gold font-bold';}
      else{c.className='w-10 h-10 rounded-full flex items-center justify-center font-ui text-sm font-bold transition-all duration-500 bg-white border-2 border-border text-muted-foreground';l.className='font-ui text-[11px] mt-2 transition-colors duration-300 text-muted-foreground';}
    }
    step=s;$('progress-bar')?.scrollIntoView({behavior:'smooth',block:'start'});
  }

  // ── Passo 1: Unidade ──
  document.querySelectorAll('.unit-card').forEach(card=>{
    card.addEventListener('click',()=>{
      unit=(card as HTMLElement).dataset.unit??'';
      document.querySelectorAll('.unit-card').forEach(c=>c.classList.remove('sel'));
      card.classList.add('sel');
      ($('badge-unit-name') as HTMLElement).textContent=unit;
      ($('f-unit') as HTMLInputElement).value=unit;
      setTimeout(()=>{go(2);buildCal();},400);
    });
  });

  // ── Passo 2: Calendário ──
  function buildCal(){
    const cont=$('cal-days'),ml=$('cal-month');if(!cont||!ml)return;
    cont.innerHTML='';
    const today=new Date();today.setHours(0,0,0,0);
    const start=new Date(today);start.setDate(start.getDate()+calOff*7);
    if(start<today)start.setTime(today.getTime());
    let fm='';
    for(let i=0;i<14;i++){
      const d=new Date(start);d.setDate(d.getDate()+i);
      const diff=Math.floor((d.getTime()-today.getTime())/864e5);
      if(diff>=DAYS)break;
      const isSun=d.getDay()===0;
      const ds=d.toISOString().split('T')[0];
      const isToday=d.getTime()===today.getTime();
      const isSel=ds===date;
      if(!fm)fm=`${MO[d.getMonth()]} ${d.getFullYear()}`;
      const btn=document.createElement('button');btn.type='button';
      btn.className=`day-card flex flex-col items-center justify-center py-3 px-2 rounded-xl border-2 bg-white cursor-pointer ${isSun?'off border-border/30':'border-border/40'} ${isSel?'sel':''}`;
      btn.dataset.date=ds;
      if(isSun)(btn as HTMLButtonElement).disabled=true;
      btn.innerHTML=`<span class="font-ui text-[10px] uppercase tracking-wider ${isSun?'text-muted-foreground/50':'text-muted-foreground'}">${WD[d.getDay()]}</span><span class="font-display text-xl ${isSel?'text-gold font-bold':isSun?'text-muted-foreground/50':'text-navy font-semibold'}">${d.getDate()}</span><span class="font-ui text-[9px] ${isSun?'text-muted-foreground/50':'text-muted-foreground'}">${MO[d.getMonth()].substring(0,3)}</span>${isToday?'<span class="w-1.5 h-1.5 rounded-full bg-gold mt-1"></span>':''}`;
      if(!isSun)btn.addEventListener('click',()=>pickDate(ds));
      cont.appendChild(btn);
    }
    ml.textContent=fm;
  }
  $('cal-prev')?.addEventListener('click',()=>{if(calOff>0){calOff--;buildCal();}});
  $('cal-next')?.addEventListener('click',()=>{if(calOff<Math.ceil(DAYS/7)-1){calOff++;buildCal();}});

  async function pickDate(ds:string){
    date=ds;hour=-1;minute=-1;
    document.querySelectorAll('.day-card').forEach(c=>c.classList.remove('sel'));
    document.querySelector(`.day-card[data-date="${ds}"]`)?.classList.add('sel');
    const sw=$('slots-wrap'),ld=$('slots-loading'),gr=$('slots-grid'),em=$('slots-empty'),doff=$('slots-dayoff'),dlbl=$('slots-date-lbl');
    if(sw)sw.classList.remove('hidden');
    if(ld)ld.classList.remove('hidden');
    if(gr){gr.classList.add('hidden');gr.innerHTML='';}
    if(em)em.classList.add('hidden');
    if(doff)doff.classList.add('hidden');
    const d=new Date(ds+'T12:00:00');
    if(dlbl)dlbl.textContent=`— ${d.getDate()} de ${MO[d.getMonth()]}`;
    try{
      const r=await fetch(`/api/agendamento/slots/?date=${ds}&unit=${encodeURIComponent(unit)}`);
      const data=await r.json();
      if(ld)ld.classList.add('hidden');
      if(data.dayOff){if(doff)doff.classList.remove('hidden');return;}
      const avail=(data.slots||[]).filter((s:any)=>s.available);
      if(avail.length===0&&(data.slots||[]).length===0){if(em)em.classList.remove('hidden');return;}
      if(gr){
        gr.classList.remove('hidden');
        for(const s of data.slots){
          const b=document.createElement('button');b.type='button';
          const t=`${String(s.hour).padStart(2,'0')}:${String(s.minute).padStart(2,'0')}`;
          b.className='slot-btn px-3 py-2.5 rounded-lg border-2 border-border/40 bg-white font-ui text-sm text-navy';
          b.textContent=t;b.disabled=!s.available;
          b.dataset.hour=String(s.hour);b.dataset.minute=String(s.minute);
          if(s.available)b.addEventListener('click',()=>pickSlot(s.hour,s.minute,b));
          gr.appendChild(b);
        }
        if(avail.length===0&&em)em.classList.remove('hidden');
      }
    }catch{if(ld)ld.classList.add('hidden');if(em)em.classList.remove('hidden');}
  }

  function pickSlot(h:number,m:number,btn:HTMLElement){
    hour=h;minute=m;
    document.querySelectorAll('.slot-btn').forEach(b=>b.classList.remove('sel'));
    btn.classList.add('sel');
    ($('f-date') as HTMLInputElement).value=date;
    ($('f-hour') as HTMLInputElement).value=String(h);
    ($('f-min') as HTMLInputElement).value=String(m);
    const d=new Date(date+'T12:00:00');
    const df=`${d.getDate()} de ${MO[d.getMonth()]} de ${d.getFullYear()}`;
    const tf=`${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
    $('sum-unit').textContent=unit;
    $('sum-date').textContent=df;
    $('sum-time').textContent=tf;
    setTimeout(()=>go(3),500);
  }

  // ── Voltar ──
  $('back1')?.addEventListener('click',()=>go(1));
  $('back2')?.addEventListener('click',()=>go(2));

  // ── Máscara telefone ──
  const ph=$('inp-phone') as HTMLInputElement;
  if(ph)ph.addEventListener('input',()=>{
    let v=ph.value.replace(/\D/g,'');if(v.length>11)v=v.substring(0,11);
    if(v.length>7)ph.value=`(${v.substring(0,2)}) ${v.substring(2,7)}-${v.substring(7)}`;
    else if(v.length>2)ph.value=`(${v.substring(0,2)}) ${v.substring(2)}`;
    else if(v.length>0)ph.value=`(${v}`;
  });

  // ── Submit ──
  const form=$('bk-form') as HTMLFormElement;
  form?.addEventListener('submit',async(e)=>{
    e.preventDefault();
    const btn=$('btn-submit') as HTMLButtonElement;
    const txt=$('btn-txt'),spin=$('btn-spin'),errBox=$('form-err');
    btn.disabled=true;if(txt)txt.textContent='Agendando...';if(spin)spin.classList.remove('hidden');if(errBox)errBox.classList.add('hidden');
    const fd=new FormData(form);
    const payload={
      patient_name:fd.get('patient_name'),patient_phone:fd.get('patient_phone'),
      patient_email:fd.get('patient_email')||null,unit:fd.get('unit'),
      specialty:fd.get('specialty'),health_plan:fd.get('health_plan'),
      appointment_date:fd.get('appointment_date'),
      appointment_hour:Number(fd.get('appointment_hour')),
      appointment_minute:Number(fd.get('appointment_minute')),
      appointment_type:fd.get('appointment_type'),notes:fd.get('notes')||null,
    };
    try{
      const r=await fetch('/api/agendamento/criar/',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      const data=await r.json();
      if(!r.ok)throw new Error(data.error||'Erro ao criar agendamento.');
      // Sucesso
      const d=new Date(date+'T12:00:00');
      $('c-unit').textContent=unit;
      $('c-date').textContent=`${d.getDate()} de ${MO[d.getMonth()]} de ${d.getFullYear()}`;
      $('c-time').textContent=`${String(hour).padStart(2,'0')}:${String(minute).padStart(2,'0')}`;
      $('c-type').textContent=TYPE_LABELS[String(payload.appointment_type)]||String(payload.appointment_type);
      go(4);
      setTimeout(()=>{const ci=$('conf-circle');if(ci)(ci as HTMLElement).style.transform='scale(1)';setTimeout(()=>{const pa=$('conf-path');if(pa)(pa as SVGPathElement).style.strokeDashoffset='0';},200);},300);
    }catch(err:any){
      if(errBox){errBox.classList.remove('hidden');const p=errBox.querySelector('p');if(p)p.textContent=err.message||'Erro de conexão.';}
      btn.disabled=false;if(txt)txt.textContent='Confirmar Agendamento';if(spin)spin.classList.add('hidden');
    }
  });

  // ── Type radio visual ──
  document.querySelectorAll('.type-opt input[type="radio"]').forEach(r=>{
    r.addEventListener('change',()=>{
      document.querySelectorAll('.type-opt').forEach(o=>{o.classList.remove('border-gold','bg-gold/5','shadow-sm');o.classList.add('border-border/60');});
      const p=(r as HTMLElement).closest('.type-opt');
      if(p){p.classList.add('border-gold','bg-gold/5','shadow-sm');p.classList.remove('border-border/60');}
    });
  });
});
</script>
