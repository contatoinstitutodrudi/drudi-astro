  <!-- FAQ accordion + tech carousel JS -->
  <script>
    // FAQ accordion
    document.querySelectorAll('.faq-trigger').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const content = item?.querySelector('.faq-content') as HTMLElement;
        const icon = btn.querySelector('.faq-icon') as HTMLElement;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        // Close all
        document.querySelectorAll('.faq-item').forEach(el => {
          const c = el.querySelector('.faq-content') as HTMLElement;
          const b = el.querySelector('.faq-trigger');
          const ic = el.querySelector('.faq-icon') as HTMLElement;
          if (c) c.style.maxHeight = '0';
          if (b) b.setAttribute('aria-expanded', 'false');
          if (ic) ic.style.transform = '';
          el.style.borderColor = '#f0ece6';
        });
        // Open clicked
        if (!isOpen && content) {
          content.style.maxHeight = content.scrollHeight + 'px';
          btn.setAttribute('aria-expanded', 'true');
          if (icon) icon.style.transform = 'rotate(180deg)';
          if (item) (item as HTMLElement).style.borderColor = 'rgba(201,169,97,0.30)';
        }
      });
    });

    // Tech carousel dots
    const techScroll = document.getElementById('tech-scroll');
    const techDots = document.querySelectorAll('#tech-dots button');
    techDots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        if (techScroll) {
          techScroll.scrollTo({ left: i * 320, behavior: 'smooth' });
        }
        techDots.forEach((d, j) => {
          const span = (d as HTMLElement).querySelector('span');
          if (span) {
            span.style.background = j === i ? '#1e2a44' : '#d1d5db';
            span.style.width = j === i ? '1.5rem' : '0.5rem';
            span.style.height = '0.5rem';
          }
        });
      });
    });

    // Convênios auto-scroll
    const track = document.getElementById('convenios-track');
    if (track) {
      let pos = 0;
      const SPEED = 0.5;
      const blockW = 7 * (160 + 20); // 7 items * (width + gap)
      let paused = false;
      track.addEventListener('mouseenter', () => paused = true);
      track.addEventListener('mouseleave', () => paused = false);
      function tick() {
        if (!paused) {
          pos -= SPEED;
          if (Math.abs(pos) >= blockW) pos += blockW;
          track.style.transform = `translateX(${pos}px)`;
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
  </script>

