  <!-- ========== QUEM SOMOS ========== -->
  <section class="relative overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2" style="min-height:600px">
      <!-- Left: Cirurgia image -->
      <div class="relative aos-element">
        <div class="relative h-full" style="min-height:400px">
