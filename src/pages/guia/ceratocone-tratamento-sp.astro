const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "O ceratocone tem cura?", "acceptedAnswer": { "@type": "Answer", "text": "O ceratocone não tem cura no sentido de reversão completa da ectasia já estabelecida. No entanto, o crosslinking (CXL) é capaz de parar a progressão na grande maioria dos casos, e as lentes de contato especiais proporcionam excelente qualidade visual. Em casos avançados, o transplante de córnea oferece resultados visuais muito satisfatórios." } },
    { "@type": "Question", "name": "O ceratocone causa cegueira?", "acceptedAnswer": { "@type": "Answer", "text": "O ceratocone raramente causa cegueira legal quando tratado adequadamente. Com as opções terapêuticas disponíveis — crosslinking, segmentos intracorneanos, lentes de contato especiais e transplante de córnea — a grande maioria dos pacientes mantém boa acuidade visual ao longo da vida." } },
    { "@type": "Question", "name": "Posso fazer LASIK se tiver ceratocone?", "acceptedAnswer": { "@type": "Answer", "text": "Não. O LASIK e outras cirurgias refrativas que removem tecido corneano são contraindicados em pacientes com ceratocone, pois podem acelerar drasticamente a progressão da ectasia." } },
    { "@type": "Question", "name": "O crosslinking dói?", "acceptedAnswer": { "@type": "Answer", "text": "O procedimento é realizado sob anestesia tópica (colírios), sem dor durante a cirurgia. No pós-operatório imediato (primeiros 3-5 dias), é comum desconforto moderado (sensação de areia, lacrimejamento, fotofobia)." } },
    { "@type": "Question", "name": "O ceratocone é hereditário?", "acceptedAnswer": { "@type": "Answer", "text": "Sim, há componente genético no ceratocone. Aproximadamente 10% dos pacientes têm familiar de primeiro grau afetado. Familiares de pacientes com ceratocone devem realizar exame oftalmológico completo com topografia corneana, especialmente durante a adolescência." } }
  ]
};
---

