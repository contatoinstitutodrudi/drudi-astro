            </div>
            <h2 class="font-display text-2xl md:text-3xl text-navy mb-4 group-hover:text-gold transition-colors leading-tight">{featuredPost.title}</h2>
            <p class="font-body text-sm text-muted-foreground leading-relaxed mb-6">{featuredPost.excerpt}</p>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4 font-body text-xs text-muted-foreground">
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {featuredPost.readTime} de leitura
                </span>
                <span>{formatDate(featuredPost.date)}</span>
              </div>
              <span class="inline-flex items-center gap-1 font-ui text-xs font-semibold text-navy group-hover:text-gold transition-colors">
                Ler artigo completo
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </a>
      </div>

      <!-- Grid de posts -->
      <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {regularPosts.map(post => (
          <article class="blog-post group rounded-2xl overflow-hidden border border-border/40 hover:shadow-lg transition-all bg-white" data-category={post.category} data-title={post.title.toLowerCase()}>
            <a href={`/blog/${post.slug}`} class="block">
