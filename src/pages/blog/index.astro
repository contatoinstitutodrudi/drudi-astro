          >
            Ligar Agora
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const catFilters = document.querySelectorAll('.cat-filter');
  const blogPosts = document.querySelectorAll('.blog-post');
  const emptyState = document.getElementById('empty-state');
  const searchInput = document.getElementById('blog-search') as HTMLInputElement;

  let activeCategory = '';
  let searchTerm = '';

  function filterPosts() {
    let visible = 0;
    blogPosts.forEach((post) => {
      const el = post as HTMLElement;
      const cat = el.dataset.category || '';
      const title = el.dataset.title || '';

      const matchesCat = activeCategory === '' || cat === activeCategory;
      const matchesSearch = searchTerm === '' || title.includes(searchTerm);

      if (matchesCat && matchesSearch) {
        el.style.display = '';
        visible++;
      } else {
        el.style.display = 'none';
      }
    });

    if (emptyState) {
      emptyState.classList.toggle('hidden', visible > 0);
    }
  }

  catFilters.forEach(btn => {
    btn.addEventListener('click', () => {
      catFilters.forEach(b => {
        b.classList.remove('active', 'bg-navy', 'text-cream', 'border-navy');
        b.classList.add('border-border/60', 'text-navy');
      });
      btn.classList.add('active', 'bg-navy', 'text-cream', 'border-navy');
      btn.classList.remove('border-border/60');
      activeCategory = (btn as HTMLElement).dataset.cat || '';
      filterPosts();
    });
  });

  searchInput?.addEventListener('input', () => {
    searchTerm = searchInput.value.toLowerCase().trim();
    filterPosts();
  });
</script>
