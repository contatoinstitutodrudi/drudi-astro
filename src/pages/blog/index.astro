          Blog de Oftalmologia e Saúde <span class="text-gold italic">Ocular</span>
        </h1>
        <p class="font-body text-lg text-cream/80 leading-relaxed max-w-xl">
          Artigos, vídeos e conteúdos educativos sobre cuidados com a visão, elaborados pelos especialistas da Drudi e Almeida Oftalmologia.
        </p>
        <div class="w-16 h-0.5 bg-gold mt-6"></div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- ========== BUSCA E FILTROS ========== -->
  <div class="bg-white border-b border-border shadow-sm sticky top-0 z-20">
    <div class="container py-4">
      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
        <div class="relative max-w-xl w-full">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input
            type="text"
            id="blog-search"
            placeholder="Buscar artigos, vídeos, podcasts..."
            class="w-full pl-12 pr-4 py-2.5 border border-border/60 rounded-lg font-body text-sm text-navy focus:ring-2 focus:ring-gold/30 focus:border-gold outline-none transition-all"
          />
        </div>
        <div class="flex flex-wrap gap-2">
          <button class="cat-filter active font-ui text-xs font-semibold px-4 py-2 rounded-full border border-navy bg-navy text-cream transition-all" data-cat="">
            Todos
          </button>
          {categories.map(cat => (
            <button class="cat-filter font-ui text-xs font-semibold px-4 py-2 rounded-full border border-border/60 text-navy hover:border-navy/40 transition-all" data-cat={cat.name}>
              {cat.name}
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- ========== POST DESTAQUE ========== -->
  <section class="section-padding bg-white" id="blog-content">
    <div class="container">
      <!-- Featured post -->
      <div class="mb-12 blog-post" data-category={featuredPost.category} data-title={featuredPost.title.toLowerCase()}>
        <a href={`/blog/${featuredPost.slug}`} class="group grid grid-cols-1 lg:grid-cols-2 gap-0 rounded-2xl overflow-hidden border border-border/40 hover:shadow-xl transition-all">
          <div class="relative overflow-hidden">
            <img
              src={featuredPost.image}
              alt={featuredPost.title}
              class="w-full h-[300px] lg:h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="eager"
            />
            <div class="absolute top-4 left-4 flex items-center gap-2">
              <span class="inline-flex items-center gap-1.5 bg-gold text-navy font-ui text-xs font-bold px-3 py-1.5 rounded-full">
                Destaque
              </span>
