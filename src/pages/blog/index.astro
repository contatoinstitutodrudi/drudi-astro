                    Artigo
                  </span>
                  <span class="inline-flex items-center bg-navy/80 backdrop-blur-sm text-cream font-ui text-xs font-semibold px-2.5 py-1 rounded-full">
                    {post.category}
                  </span>
                </div>
              </div>
              <div class="p-5">
                <div class="flex items-center gap-3 mb-3 font-body text-xs text-muted-foreground">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {post.readTime}
                  </span>
                  <span>·</span>
                  <span>{formatDate(post.date)}</span>
                </div>
                <h3 class="font-display text-base text-navy mb-2 group-hover:text-gold transition-colors leading-snug">{post.title}</h3>
                <p class="font-body text-xs text-muted-foreground leading-relaxed line-clamp-3">{post.excerpt}</p>
                <div class="mt-4 flex items-center gap-1 font-ui text-xs font-semibold text-navy group-hover:text-gold transition-colors">
                  Ler artigo
                  <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16">
        <svg class="w-12 h-12 text-muted-foreground/40 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <p class="font-display text-lg text-navy mb-2">Nenhum artigo encontrado</p>
        <p class="font-body text-sm text-muted-foreground">Tente buscar por outro termo ou categoria.</p>
      </div>
    </div>
