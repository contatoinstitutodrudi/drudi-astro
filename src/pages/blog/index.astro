      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/images/seurat-grande-jatte_8467105c.webp')"
    ></div>
    <!-- Gradiente: escuro na base para legibilidade, sutil no topo -->
    <div class="absolute inset-0 bg-gradient-to-t from-navy/95 via-navy/55 to-navy/15"></div>
    <!-- Vinheta lateral esquerda suave -->
    <div class="absolute inset-0 bg-gradient-to-r from-navy/40 to-transparent"></div>

    <div class="relative container pb-16 pt-32">
      <nav class="flex items-center gap-2 font-ui text-xs text-cream/60 mb-5">
        <a href="/" class="hover:text-cream transition-colors">Início</a>
        <span>/</span>
        <span class="text-cream">Blog</span>
      </nav>
      <div class="max-w-2xl">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-3 block">
          Saúde Ocular em Foco
        </span>
