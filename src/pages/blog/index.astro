  <!-- ========== CTA COM FAMÍLIA FELIZ (fundo, igual aos institutos) ========== -->
  <section class="relative min-h-[500px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/happy-family_6ee5e159.webp')"></div>
    <div class="absolute inset-0 bg-navy/70"></div>

    <div class="relative container py-14 md:py-16">
      <div class="max-w-2xl mx-auto text-center">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4 block">
