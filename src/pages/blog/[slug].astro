---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { allPosts } from '../../data/blogPosts';

const WA_LINK = "https://wa.me/5511916544653";
const WA_AGENDAR = `${WA_LINK}?text=Olá! Gostaria de agendar uma consulta.`;

// ─── Geração estática de rotas ───────────────────────────────────────────────
export function getStaticPaths() {
  return allPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const relatedPosts = allPosts.filter(p => post.relatedSlugs.includes(p.slug));

function formatDate(dateStr: string) {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}

const categoryColors: Record<string, string> = {
  "Retina": "bg-rose-100 text-rose-800",
  "Ceratocone": "bg-emerald-100 text-emerald-800",
  "Catarata": "bg-blue-100 text-blue-800",
  "Glaucoma": "bg-amber-100 text-amber-800",
  "Estrabismo": "bg-violet-100 text-violet-800",
  "Saúde Ocular": "bg-teal-100 text-teal-800",
};
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  keywords={post.keywords}
  canonicalPath={`/blog/${post.slug}`}
  ogImage={post.image}
>
  <!-- Breadcrumb + Hero -->
  <section class="bg-navy pt-28 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style={`background-image: url('${post.image}'); background-size: cover; background-position: center;`}></div>
    <div class="absolute inset-0 bg-gradient-to-b from-navy/80 to-navy"></div>
    <div class="relative container">
      <div class="max-w-3xl">
        <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Blog", href: "/blog" }, { label: post.title.length > 40 ? post.title.substring(0, 40) + '…' : post.title }]} />
        <span class={`inline-block text-xs font-bold px-3 py-1 rounded-full mb-4 ${categoryColors[post.category] || 'bg-gold/20 text-gold'}`}>
          {post.category}
        </span>
        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl text-cream leading-tight mb-4">
          {post.title}
        </h1>
        <div class="flex flex-wrap items-center gap-4 text-cream/70 text-sm">
          <span>📅 {formatDate(post.date)}</span>
          <span>⏱ {post.readTime} de leitura</span>
          <span>✍️ {post.author}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Imagem de capa -->
  <div class="container -mt-8 mb-0 relative z-10">
    <img
      src={post.image}
      alt={post.title}
      class="w-full max-w-3xl mx-auto rounded-xl shadow-2xl object-cover"
      style="max-height: 420px;"
      loading="eager"
    />
  </div>

  <!-- Conteúdo principal -->
  <div class="container py-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10 max-w-5xl mx-auto">

      <!-- Artigo -->
      <article>
        <!-- Autor -->
        <div class="flex items-center gap-4 p-4 bg-cream rounded-xl border border-border/40 mb-8">
          <img src={post.authorImg} alt={post.author} class="w-14 h-14 rounded-full object-cover object-top flex-shrink-0" />
          <div>
            <div class="font-ui text-xs text-gold font-bold uppercase tracking-wider mb-0.5">Autor</div>
            <div class="font-semibold text-navy">{post.author}</div>
            <div class="text-xs text-muted-foreground">{post.authorCRM}</div>
          </div>
        </div>

        <!-- Texto do artigo -->
        <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-navy prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-p:text-gray-700 prose-p:leading-relaxed prose-li:text-gray-700 prose-strong:text-navy prose-a:text-gold prose-a:no-underline hover:prose-a:underline" set:html={post.content} />

        <!-- CTA inline -->
        <div class="mt-12 p-6 bg-navy rounded-xl text-center">
          <p class="text-cream/80 text-sm mb-1">Ficou com dúvidas ou quer agendar uma consulta?</p>
          <h3 class="font-display text-2xl text-cream mb-4">Fale com nossos especialistas</h3>
          <a
            href={WA_AGENDAR}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#25d366] text-white font-bold px-8 py-3 rounded-lg hover:bg-[#1fb855] transition-colors"
          >
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Agendar pelo WhatsApp
          </a>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- CTA Sidebar -->
        <div class="bg-cream border border-border/40 rounded-xl p-5 sticky top-24">
          <div class="text-xs font-bold text-gold uppercase tracking-wider mb-2">Agende sua consulta</div>
          <p class="text-sm text-gray-600 mb-4 leading-relaxed">Especialistas com mais de 10 anos de experiência. 5 unidades em SP e Guarulhos.</p>
          <a
            href={WA_AGENDAR}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full bg-[#25d366] text-white font-bold py-3 px-4 rounded-lg text-sm hover:bg-[#1fb855] transition-colors mb-3"
          >
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href="tel:+5511916544653" class="flex items-center justify-center gap-2 w-full bg-navy text-white font-semibold py-2.5 px-4 rounded-lg text-sm hover:bg-navy/90 transition-colors">
            (11) 91654-4653
          </a>
          <div class="mt-4 pt-4 border-t border-border/40">
            <div class="text-xs text-gray-500 font-semibold mb-2">Unidades</div>
            <ul class="text-xs text-gray-600 space-y-1">
              <li>• Guarulhos</li>
              <li>• Santana — SP</li>
              <li>• Tatuapé — SP</li>
              <li>• Lapa — SP</li>
              <li>• São Miguel — SP</li>
            </ul>
          </div>
        </div>
      </aside>
    </div>

    <!-- Posts relacionados -->
    {relatedPosts.length > 0 && (
      <div class="max-w-5xl mx-auto mt-16">
        <h2 class="font-display text-2xl text-navy mb-6">Artigos relacionados</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {relatedPosts.map(related => (
            <a href={`/blog/${related.slug}`} class="group flex gap-4 bg-cream rounded-xl p-4 border border-border/40 hover:shadow-md transition-all">
              <img src={related.image} alt={related.title} class="w-24 h-20 object-cover rounded-lg flex-shrink-0" loading="lazy" />
              <div>
                <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${categoryColors[related.category] || 'bg-gold/20 text-gold'}`}>{related.category}</span>
                <h3 class="font-semibold text-navy text-sm mt-1 leading-snug group-hover:text-gold transition-colors line-clamp-2">{related.title}</h3>
                <span class="text-xs text-muted-foreground">{related.readTime}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
