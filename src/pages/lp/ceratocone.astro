---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tratamento de Ceratocone em SP | Drudi e Almeida Clínicas Oftalmológicas</title>
  <meta name="description" content="Crosslinking, lentes esclerais e anéis de Ferrara para ceratocone em SP. Especialista em córnea Dra. Priscilla de Almeida. 5 unidades. Aceita convênios." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #2c3e50;
      --navy-deep: #1a2637;
      --gold: #c9a961;
      --gold-light: #d4b97a;
      --cream: #fafaf8;
      --cream-dark: #f2f2f0;
      --white: #ffffff;
      --gray: #6b7280;
      --green: #16a34a;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--cream); color: var(--navy); line-height: 1.6;       padding-bottom: 64px;
    }
    .font-display { font-family: 'Cormorant Garamond', serif; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; }
    /* Announcement Bar */
    .ann-bar {
      background: var(--navy-deep);
      color: var(--cream);
      text-align: center;
      padding: 9px 16px;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.01em;
    }
    .ann-bar strong { color: var(--gold); }
    /* Header */
    .lp-header { background: var(--white); border-bottom: 1px solid rgba(44,62,80,0.1); padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 200; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .lp-header img { height: 42px; }
    .header-cta { display: flex; align-items: center; gap: 12px; }
    .btn-header-phone { display: flex; align-items: center; gap: 7px; background: var(--navy); color: var(--white); padding: 9px 18px; border-radius: 6px; font-size: 13px; font-weight: 600; }
    .btn-header-wa { display: flex; align-items: center; gap: 7px; background: #25d366; color: var(--white); padding: 9px 18px; border-radius: 6px; font-size: 13px; font-weight: 700; }
    /* Hero */
    .hero { position: relative; min-height: 90vh; display: flex; align-items: center; overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; background-image: url('/images/ceratocone-hero_4839850a.webp'); background-size: cover; background-position: center top; }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(105deg, rgba(26,38,55,0.93) 0%, rgba(26,38,55,0.78) 55%, rgba(26,38,55,0.48) 100%); }
    .hero-content { position: relative; z-index: 10; max-width: 1100px; margin: 0 auto; padding: 80px 32px 60px; display: grid; grid-template-columns: 1fr 420px; gap: 48px; align-items: center; width: 100%; }
    .hero-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(201,169,97,0.18); border: 1px solid rgba(201,169,97,0.4); color: var(--gold); padding: 6px 14px; border-radius: 20px; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 22px; }
    .hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 4.2vw, 3.5rem); font-weight: 500; line-height: 1.15; color: var(--cream); margin-bottom: 16px; text-shadow: 0 2px 12px rgba(0,0,0,0.4); }
    .hero h1 em { color: var(--gold); font-style: italic; }
    .hero-desc { font-size: 15px; color: rgba(245,240,232,0.80); line-height: 1.75; margin-bottom: 28px; max-width: 520px; }
    .hero-checks { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 0; }
    .hero-check { display: inline-flex; align-items: center; gap: 6px; background: var(--navy); color: var(--white); padding: 7px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; border: 1px solid rgba(201,169,97,0.2); }
    .hero-check .check-icon { color: var(--gold); font-weight: 700; }
    /* Form Card */
    .form-card { background: var(--white); border-radius: 14px; padding: 28px; box-shadow: 0 8px 40px rgba(0,0,0,0.18); border: 1px solid rgba(255,255,255,0.15); }
    .form-card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 600; color: var(--navy); margin-bottom: 4px; }
    .form-card-sub { font-size: 12px; color: var(--gray); margin-bottom: 20px; }
    .form-label { font-size: 12px; font-weight: 600; color: var(--navy); display: block; margin-bottom: 6px; }
    .form-select { width: 100%; padding: 12px 16px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; color: var(--navy); background: var(--white); margin-bottom: 12px; cursor: pointer; outline: none; }
    .form-select:focus { border-color: var(--gold); }
    .btn-wa-main { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; background: #25d366; color: var(--white); padding: 14px 20px; border-radius: 8px; font-size: 15px; font-weight: 700; margin-bottom: 10px; transition: background 0.2s; }
    .btn-wa-main:hover { background: #1fb855; }
    .btn-phone-main { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; background: var(--navy); color: var(--white); padding: 12px 20px; border-radius: 8px; font-size: 14px; font-weight: 600; margin-bottom: 14px; transition: background 0.2s; }
    .btn-phone-main:hover { background: var(--navy-deep); }
    .google-rating { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--gray); }
    .stars { color: #f59e0b; font-size: 14px; }
    /* Testimonial Card */
    .testimonial-card { background: var(--white); border-radius: 12px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); border: 1px solid rgba(0,0,0,0.06); margin-bottom: 16px; }
    .testimonial-card .stars { margin-bottom: 12px; display: block; }
    .testimonial-card blockquote { font-size: 14px; color: #374151; font-style: italic; line-height: 1.6; margin-bottom: 14px; }
    .testimonial-author { display: flex; align-items: center; gap: 10px; }
    .author-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--navy); color: var(--white); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }
    .author-name { font-size: 13px; font-weight: 600; color: var(--navy); }
    .author-detail { font-size: 12px; color: var(--gray); }
    .verified { font-size: 11px; color: var(--green); font-weight: 500; }
    /* Units List */
    .units-box { background: var(--navy); color: var(--cream); border-radius: 10px; padding: 18px 20px; margin-top: 16px; }
    .units-box h4 { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; color: var(--gold); margin-bottom: 10px; }
    .units-box ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
    .units-box li { font-size: 13px; display: flex; align-items: center; gap: 6px; }
    .units-box li::before { content: "·"; font-size: 16px; color: var(--gold); }
    /* Proof Bar */
    .proof-bar { background: var(--navy); padding: 20px 24px; }
    .proof-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-around; flex-wrap: wrap; gap: 16px; }
    .proof-item { text-align: center; color: var(--white); }
    .proof-value { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 600; color: var(--gold); line-height: 1; }
    .proof-label { font-size: 12px; color: rgba(255,255,255,0.7); margin-top: 4px; }
    /* Convenios */
    .convenios-strip { background: var(--white); padding: 24px; border-bottom: 1px solid rgba(0,0,0,0.06); }
    .convenios-strip h4 { text-align: center; font-size: 13px; font-weight: 700; color: var(--navy); letter-spacing: 0.05em; margin-bottom: 16px; }
    .convenios-logos { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 16px 24px; }
    .convenios-logos img { height: 32px; object-fit: contain; filter: grayscale(30%); opacity: 0.85; transition: all 0.2s; }
    .convenios-logos img:hover { filter: grayscale(0%); opacity: 1; }
    .convenio-not-found { text-align: center; font-size: 13px; color: var(--gray); margin-top: 12px; }
    .convenio-not-found a { color: var(--navy); font-weight: 600; text-decoration: underline; }
    /* Sections */
    .section { padding: 64px 24px; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; color: var(--gold); text-transform: uppercase; margin-bottom: 8px; }
    .section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); color: var(--navy); margin-bottom: 12px; line-height: 1.2; }
    .section-subtitle { font-size: 15px; color: var(--gray); max-width: 600px; line-height: 1.7; margin-bottom: 8px; }
    .gold-line { width: 60px; height: 3px; background: var(--gold); margin: 16px 0 40px; border-radius: 2px; }
    /* Sintomas Grid */
    .sintomas-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }
    .sintoma-card { background: var(--white); border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.07); transition: transform 0.2s; }
    .sintoma-card:hover { transform: translateY(-4px); }
    .sintoma-card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
    .sintoma-info { padding: 16px; }
    .sintoma-info h3 { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
    .sintoma-info p { font-size: 13px; color: var(--gray); line-height: 1.5; }
    /* Tratamentos Grid */
    .tratamentos-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 40px; }
    .tratamento-card { background: var(--white); border-radius: 12px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); border-left: 4px solid var(--gold); }
    .tratamento-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--navy); margin-bottom: 8px; }
    .tratamento-card .badge { display: inline-block; font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 20px; margin-bottom: 10px; }
    .badge-cirurgico { background: var(--navy); color: var(--gold); }
    .badge-clinico { background: var(--navy); color: var(--gold); }
    .badge-optico { background: var(--navy); color: var(--gold); }
    .tratamento-card p { font-size: 13px; color: var(--gray); line-height: 1.6; }
    .tratamento-card .detail { font-size: 12px; color: var(--accent); font-weight: 600; margin-top: 8px; }
    /* Prices */
    .prices-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }
    .price-card { background: var(--white); border-radius: 12px; padding: 28px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); border: 2px solid transparent; transition: border-color 0.2s; }
    .price-card.featured { border-color: var(--gold); position: relative; }
    .price-card.featured::before { content: "MAIS INDICADO"; position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--gold); color: var(--navy); font-size: 10px; font-weight: 700; padding: 4px 14px; border-radius: 20px; white-space: nowrap; }
    .price-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; color: var(--navy); margin-bottom: 8px; }
    .price-card .price-desc { font-size: 13px; color: var(--gray); margin-bottom: 20px; line-height: 1.5; }
    .price-amount { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 600; color: var(--navy); margin-bottom: 4px; }
    .price-amount em { color: var(--gold); }
    .price-per { font-size: 12px; color: var(--gray); margin-bottom: 20px; }
    .price-features { list-style: none; margin-bottom: 24px; }
    .price-features li { font-size: 13px; color: #374151; padding: 6px 0; border-bottom: 1px solid #f3f4f6; display: flex; align-items: center; gap: 8px; }
    .price-features li::before { content: "✓"; color: var(--green); font-weight: 700; }
    .price-cta { display: block; text-align: center; padding: 12px 20px; border-radius: 8px; font-size: 14px; font-weight: 600; transition: all 0.2s; }
    .price-cta.primary { background: var(--gold); color: var(--navy); }
    .price-cta.primary:hover { background: var(--gold-light); }
    .price-cta.secondary { background: var(--navy); color: var(--white); }
    .price-cta.secondary:hover { background: var(--navy-light); }
    .price-cta.outline { border: 2px solid var(--navy); color: var(--navy); }
    .price-cta.outline:hover { background: var(--navy); color: var(--white); }
    .price-note { font-size: 12px; color: var(--gray); text-align: center; margin-top: 20px; line-height: 1.6; }
    .price-note a { color: var(--navy); text-decoration: underline; }
    /* Steps */
    .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; margin-top: 40px; }
    .step-item { text-align: center; }
    .step-number { width: 56px; height: 56px; border-radius: 50%; background: var(--navy); color: var(--gold); font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
    .step-item h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
    .step-item p { font-size: 13px; color: var(--gray); line-height: 1.6; }
    /* Specialists */
    .specialists-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 40px; }
    .specialist-card { background: var(--white); border-radius: 12px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.08); display: flex; }
    .specialist-img { width: 160px; flex-shrink: 0; object-fit: cover; object-position: top; }
    .specialist-info { padding: 24px; }
    .specialist-info h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--navy); margin-bottom: 4px; }
    .specialist-crm { font-size: 12px; color: var(--gold); font-weight: 600; margin-bottom: 12px; }
    .specialist-info p { font-size: 13px; color: var(--gray); line-height: 1.6; }
    /* Testimonials */
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }
    /* Media */
    .media-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
    .media-card { background: var(--white); border-radius: 10px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.08); transition: transform 0.2s; }
    .media-card:hover { transform: translateY(-3px); }
    .media-thumb { position: relative; aspect-ratio: 16/9; background: var(--navy); }
    .media-thumb img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; }
    .media-badge { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; color: var(--gold); padding: 10px 14px 4px; }
    .media-card h4 { font-size: 13px; font-weight: 600; color: var(--navy); padding: 0 14px 6px; }
    .media-card p { font-size: 12px; color: var(--gray); padding: 0 14px 14px; line-height: 1.5; }
    /* FAQ */
    .faq-list { margin-top: 40px; display: flex; flex-direction: column; gap: 12px; }
    .faq-item { background: var(--white); border-radius: 10px; border: 1px solid rgba(0,0,0,0.08); overflow: hidden; }
    .faq-question { width: 100%; text-align: left; padding: 18px 20px; font-size: 15px; font-weight: 600; color: var(--navy); background: none; border: none; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
    .faq-question .icon { font-size: 20px; color: var(--gold); font-weight: 300; flex-shrink: 0; }
    .faq-answer { padding: 0 20px 18px; font-size: 14px; color: var(--gray); line-height: 1.7; display: none; }
    .faq-answer a { color: var(--navy); text-decoration: underline; }
    .faq-item.open .faq-answer { display: block; }
    .faq-item.open .icon { transform: rotate(45deg); }
    .faq-cta { text-align: center; margin-top: 24px; font-size: 14px; color: var(--gray); }
    .faq-cta a { color: var(--navy); font-weight: 600; text-decoration: underline; }
    /* Final CTA */
    .final-cta { background: var(--navy); padding: 64px 24px; text-align: center; }
    .urgency-badge { display: inline-block; background: rgba(201,169,97,0.15); border: 1px solid var(--gold); color: var(--gold); font-size: 11px; font-weight: 700; letter-spacing: 0.1em; padding: 6px 16px; border-radius: 20px; margin-bottom: 20px; }
    .final-cta h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 4vw, 3rem); color: var(--white); margin-bottom: 16px; }
    .final-cta h2 em { color: var(--gold); font-style: italic; }
    .final-cta p { font-size: 15px; color: rgba(255,255,255,0.75); max-width: 600px; margin: 0 auto 32px; line-height: 1.7; }
    .final-cta-btn { display: inline-flex; align-items: center; gap: 10px; background: #25d366; color: var(--white); padding: 16px 36px; border-radius: 10px; font-size: 17px; font-weight: 700; transition: background 0.2s; }
    .final-cta-btn:hover { background: #1fb855; }
    .final-cta-trust { font-size: 13px; color: rgba(255,255,255,0.5); margin-top: 16px; }
    .final-cta-info { font-size: 13px; color: rgba(255,255,255,0.6); margin-top: 8px; }
    /* Addresses */
    .addresses-section { background: var(--cream-dark); padding: 48px 24px; }
    .addresses-inner { max-width: 1100px; margin: 0 auto; }
    .addresses-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-top: 32px; }
    .address-card { background: var(--white); border-radius: 10px; padding: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .address-card h4 { font-size: 13px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
    .address-card p { font-size: 12px; color: var(--gray); margin-bottom: 10px; line-height: 1.5; }
    .address-card a { font-size: 12px; color: var(--navy); font-weight: 600; text-decoration: underline; }
    /* Footer */
    .lp-footer { background: var(--navy); padding: 24px; text-align: center; }
    .lp-footer p { font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.8; }
    .lp-footer a { color: rgba(255,255,255,0.7); text-decoration: underline; }
    /* Sticky CTA Mobile */
    .sticky-cta { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: var(--white); border-top: 1px solid rgba(0,0,0,0.1); padding: 12px 16px; z-index: 200; box-shadow: 0 -4px 16px rgba(0,0,0,0.1); }
    /* Responsive */
    @media (max-width: 768px) {
      .hero-inner { grid-template-columns: 1fr; gap: 32px; }
      .sintomas-grid { grid-template-columns: 1fr 1fr; }
      .tratamentos-grid { grid-template-columns: 1fr; }
      .prices-grid { grid-template-columns: 1fr; }
      .steps-grid { grid-template-columns: 1fr 1fr; }
      .specialists-grid { grid-template-columns: 1fr; }
      .testimonials-grid { grid-template-columns: 1fr; }
      .media-grid { grid-template-columns: 1fr 1fr; }
      .addresses-grid { grid-template-columns: 1fr 1fr; }
      .sticky-cta { display: block; }
      .proof-bar-inner { gap: 24px; }
          .btn-header-wa { display: none; }
      .form-card { max-width: 480px; margin: 0 auto; }
      .lp-header { padding: 12px 20px; }
      .btn-header-phone { display: none; }
    }
        @media (max-width: 860px) {
      .hero-content, .hero-inner { grid-template-columns: 1fr; }
      .form-card { max-width: 480px; margin-left: auto; margin-right: auto; }
      .lp-header { padding: 12px 20px; }
      .btn-header-wa { font-size: 12px; padding: 8px 14px; }
      .btn-header-phone { display: none; }
    }
    @media (max-width: 480px) {
      .sintomas-grid { grid-template-columns: 1fr; }
      .steps-grid { grid-template-columns: 1fr; }
      .media-grid { grid-template-columns: 1fr; }
      .addresses-grid { grid-template-columns: 1fr; }
    }
