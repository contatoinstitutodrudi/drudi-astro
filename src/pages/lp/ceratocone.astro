            <div style="position:absolute;top:10px;left:10px;background:rgba(44,62,80,.85);color:#fff;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:3px 8px;border-radius:4px;">CNN Brasil</div>
          </div>
