---
// LP Glaucoma — Réplica fiel de lp-glaucoma.institutodrudiealmeida.com.br
const WA_LINK = "https://wa.me/5511916544653";
const WA_AGENDAR = `${WA_LINK}?text=Olá! Gostaria de agendar uma avaliação de glaucoma.`;
const WA_CONVENIO = `${WA_LINK}?text=Olá! Gostaria de verificar se meu convênio cobre o tratamento de glaucoma.`;
const WA_DUVIDA = `${WA_LINK}?text=Olá! Tenho uma dúvida sobre glaucoma.`;
const PHONE = "tel:+5511916544653";

const unidades = [
  { nome: "Guarulhos Centro", endereco: "R. Sete de Setembro, 375", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Guarulhos" },
  { nome: "Santana — São Paulo", endereco: "R. Dr. César, 130", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Santana" },
  { nome: "Tatuapé — São Paulo", endereco: "R. Tuiuti, 2429", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Tatuape" },
  { nome: "Lapa — São Paulo", endereco: "R. Barão de Jundiaí, 221", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Lapa" },
  { nome: "São Miguel — São Paulo", endereco: "R. Bernardo Marcondes, 108", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Sao+Miguel" },
];
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Instituto do Glaucoma em SP | Drudi e Almeida Clínicas Oftalmológicas</title>
  <meta name="description" content="Diagnóstico precoce, tratamento personalizado e acompanhamento contínuo do glaucoma. Laser SLT, cirurgia MIGS, trabeculectomia. 5 unidades em SP." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #1a2e44;
      --navy-light: #243b55;
      --gold: #c9a961;
      --gold-light: #d4b97a;
      --cream: #f5f0e8;
      --cream-dark: #ede8df;
      --white: #ffffff;
      --gray: #6b7280;
      --gray-light: #f3f4f6;
      --green: #16a34a;
      --red: #dc2626;
    }
    body { font-family: 'Inter', sans-serif; background: var(--cream); color: var(--navy); line-height: 1.6; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; }

    .announcement-bar {
      background: var(--navy);
      color: var(--cream);
      text-align: center;
      padding: 10px 16px;
      font-size: 13px;
      font-weight: 500;
    }
    .announcement-bar strong { color: var(--gold); }

    .lp-header {
      background: var(--white);
      border-bottom: 1px solid rgba(0,0,0,0.08);
      padding: 14px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .lp-header img { height: 40px; }
    .header-phone {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--navy);
      color: var(--white);
      padding: 8px 18px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
    }

    .hero { background: var(--cream); padding: 48px 24px 56px; }
    .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--navy);
      color: var(--gold);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.05em;
      margin-bottom: 20px;
    }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.2rem, 4.5vw, 3.4rem);
      font-weight: 500;
      line-height: 1.15;
      color: var(--navy);
      margin-bottom: 20px;
    }
    .hero h1 em { color: var(--gold); font-style: italic; }
    .hero-desc { font-size: 15px; color: #4b5563; margin-bottom: 24px; line-height: 1.7; }
    .hero-checks { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
    .hero-check {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--navy);
      color: var(--white);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 500;
    }

    .form-card {
      background: var(--white);
      border-radius: 12px;
      padding: 28px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.1);
      border: 1px solid rgba(0,0,0,0.06);
    }
    .form-card select {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid #e5e7eb;
      border-radius: 8px;
      font-size: 14px;
      color: var(--navy);
      background: var(--white);
      margin-bottom: 12px;
      cursor: pointer;
      outline: none;
    }
    .form-card select:focus { border-color: var(--gold); }
    .btn-wa {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      background: #25d366;
      color: var(--white);
      padding: 14px 20px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 10px;
      transition: background 0.2s;
    }
    .btn-wa:hover { background: #1fb855; }
    .btn-phone {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      background: var(--navy);
      color: var(--white);
      padding: 12px 20px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      transition: background 0.2s;
    }
    .btn-phone:hover { background: var(--navy-light); }
    .google-rating { display: flex; align-items: center; gap: 8px; margin-top: 16px; font-size: 13px; color: var(--gray); }
    .stars { color: #f59e0b; font-size: 14px; }

    .testimonial-card {
      background: var(--white);
      border-radius: 12px;
      padding: 24px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      border: 1px solid rgba(0,0,0,0.06);
      margin-bottom: 16px;
    }
    .testimonial-card .stars { margin-bottom: 12px; display: block; }
    .testimonial-card blockquote { font-size: 14px; color: #374151; font-style: italic; line-height: 1.6; margin-bottom: 14px; }
    .testimonial-author { display: flex; align-items: center; gap: 10px; }
    .author-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--navy); color: var(--white);
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; flex-shrink: 0;
    }
    .author-name { font-size: 13px; font-weight: 600; color: var(--navy); }
    .author-detail { font-size: 12px; color: var(--gray); }
    .verified { font-size: 11px; color: var(--green); font-weight: 500; }

    .units-box {
      background: var(--navy); color: var(--cream);
      border-radius: 10px; padding: 18px 20px; margin-top: 16px;
    }
    .units-box h4 { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; color: var(--gold); margin-bottom: 10px; }
    .units-box ul { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 4px 16px; }
    .units-box li { font-size: 13px; }
    .units-box li::before { content: "• "; color: var(--gold); }

    .convenios-strip {
      background: var(--white);
      border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb;
      padding: 24px;
    }
    .convenios-strip h4 { text-align: center; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; color: var(--gray); text-transform: uppercase; margin-bottom: 16px; }
    .convenios-logos { display: flex; align-items: center; justify-content: center; gap: 24px; flex-wrap: wrap; }
    .convenios-logos img { height: 36px; object-fit: contain; filter: grayscale(0.3); }
    .convenio-not-found { text-align: center; margin-top: 14px; font-size: 13px; color: var(--gray); }
    .convenio-not-found a { color: var(--navy); font-weight: 600; text-decoration: underline; }

    .section { padding: 64px 24px; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
    .section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 500; color: var(--navy); margin-bottom: 12px; line-height: 1.2; }
    .section-title em { color: var(--gold); font-style: italic; }
    .section-subtitle { font-size: 15px; color: var(--gray); max-width: 600px; line-height: 1.7; }
    .gold-line { width: 60px; height: 2px; background: var(--gold); margin: 16px 0 40px; }

    /* Tunnel Vision Section */
    .tunnel-section { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
    .tunnel-image { border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.15); }
    .tunnel-image img { width: 100%; height: 300px; object-fit: cover; }

    /* Symptoms Grid */
    .symptoms-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 40px; }
    .symptom-card {
      background: var(--white);
      border-radius: 10px;
      padding: 20px;
      border-left: 4px solid var(--gold);
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .symptom-card.urgent { border-left-color: var(--red); }
    .symptom-title { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
    .symptom-desc { font-size: 13px; color: var(--gray); line-height: 1.5; }
    .symptom-card.urgent .symptom-title { color: var(--red); }

    /* Treatments */
    .treatments-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }
    .treatment-card {
      background: var(--white);
      border-radius: 12px;
      padding: 28px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      border: 1px solid rgba(0,0,0,0.06);
    }
    .treatment-icon {
      width: 48px; height: 48px;
      background: var(--navy);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px;
      color: var(--gold);
      font-size: 22px;
    }
    .treatment-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--navy); margin-bottom: 10px; }
    .treatment-card p { font-size: 13px; color: var(--gray); line-height: 1.6; margin-bottom: 12px; }
    .treatment-tag { font-size: 11px; font-weight: 600; color: var(--gold); letter-spacing: 0.05em; }

    /* Types of Glaucoma */
    .types-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
    .type-card {
      background: var(--white);
      border-radius: 10px;
      padding: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      border-top: 3px solid var(--gold);
    }
    .type-card h3 { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
    .type-card p { font-size: 13px; color: var(--gray); line-height: 1.5; }

    /* Nerve Comparison */
    .nerve-section { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
    .nerve-image { border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.15); }
    .nerve-image img { width: 100%; height: 280px; object-fit: cover; }

    /* Steps */
    .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; margin-top: 40px; }
    .step-item { text-align: center; }
    .step-number {
      width: 56px; height: 56px; border-radius: 50%;
      background: var(--navy); color: var(--gold);
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem; font-weight: 600;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 16px;
    }
    .step-item h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
    .step-item p { font-size: 13px; color: var(--gray); line-height: 1.6; }

    /* Specialists */
    .specialists-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 40px; }
    .specialist-card {
      background: var(--white); border-radius: 12px;
      overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.08);
      display: flex;
    }
    .specialist-img { width: 160px; flex-shrink: 0; object-fit: cover; object-position: top; }
    .specialist-info { padding: 24px; }
    .specialist-info h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--navy); margin-bottom: 4px; }
    .specialist-crm { font-size: 12px; color: var(--gold); font-weight: 600; margin-bottom: 12px; }
    .specialist-info p { font-size: 13px; color: var(--gray); line-height: 1.6; }

    /* Testimonials */
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }

    /* Media */
    .media-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
    .media-card {
      background: var(--white); border-radius: 10px;
      overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    .media-thumb {
      position: relative; aspect-ratio: 16/9;
      background: var(--navy);
      display: flex; align-items: center; justify-content: center;
    }
    .media-thumb img { width: 100%; height: 100%; object-fit: cover; opacity: 0.7; }
    .play-btn {
      position: absolute; width: 44px; height: 44px; border-radius: 50%;
      background: rgba(255,255,255,0.9);
      display: flex; align-items: center; justify-content: center;
    }
    .play-btn::after { content: ""; border-left: 16px solid var(--navy); border-top: 10px solid transparent; border-bottom: 10px solid transparent; margin-left: 4px; }
    .media-badge { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; color: var(--gold); padding: 10px 14px 4px; }
    .media-card h4 { font-size: 13px; font-weight: 600; color: var(--navy); padding: 0 14px 6px; }
    .media-card p { font-size: 12px; color: var(--gray); padding: 0 14px 14px; line-height: 1.5; }

    /* FAQ */
    .faq-list { margin-top: 40px; max-width: 800px; }
    .faq-item { border-bottom: 1px solid #e5e7eb; }
    .faq-question {
      width: 100%; background: none; border: none;
      text-align: left; padding: 18px 0;
      font-size: 15px; font-weight: 600; color: var(--navy);
      cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 16px;
    }
    .faq-question .icon {
      width: 24px; height: 24px; border-radius: 50%;
      background: var(--navy); color: var(--white);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0; transition: transform 0.2s;
    }
    .faq-answer { font-size: 14px; color: #4b5563; line-height: 1.7; padding-bottom: 18px; display: none; }
    .faq-item.open .faq-answer { display: block; }
    .faq-item.open .icon { transform: rotate(45deg); }
    .faq-cta { margin-top: 24px; font-size: 14px; color: var(--gray); }
    .faq-cta a { color: var(--navy); font-weight: 600; text-decoration: underline; }

    /* Final CTA */
    .final-cta { background: var(--navy); padding: 64px 24px; text-align: center; }
    .final-cta .urgency-badge {
      display: inline-block;
      background: rgba(201,169,97,0.2); border: 1px solid var(--gold);
      color: var(--gold); font-size: 12px; font-weight: 700;
      letter-spacing: 0.1em; padding: 6px 18px; border-radius: 20px; margin-bottom: 24px;
    }
    .final-cta h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 4vw, 3rem); color: var(--white); margin-bottom: 16px; line-height: 1.2; }
    .final-cta h2 em { color: var(--gold); font-style: italic; }
    .final-cta p { font-size: 15px; color: rgba(255,255,255,0.75); max-width: 560px; margin: 0 auto 32px; line-height: 1.7; }
    .final-cta-btn {
      display: inline-flex; align-items: center; gap: 10px;
      background: #25d366; color: var(--white);
      padding: 16px 36px; border-radius: 8px;
      font-size: 16px; font-weight: 700; transition: background 0.2s;
    }
    .final-cta-btn:hover { background: #1fb855; }
    .final-cta-trust { margin-top: 16px; font-size: 13px; color: rgba(255,255,255,0.5); }
    .final-cta-info { margin-top: 12px; font-size: 13px; color: rgba(255,255,255,0.5); }
    .final-cta-info strong { color: rgba(255,255,255,0.75); }

    .addresses-section { background: var(--navy); padding: 48px 24px; }
    .addresses-inner { max-width: 1100px; margin: 0 auto; }
    .addresses-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-top: 24px; }
    .address-card { text-align: center; }
    .address-card h4 { font-size: 14px; font-weight: 700; color: var(--gold); margin-bottom: 6px; }
    .address-card p { font-size: 12px; color: rgba(255,255,255,0.7); margin-bottom: 8px; }
    .address-card a { font-size: 12px; color: var(--cream); border: 1px solid rgba(255,255,255,0.3); padding: 4px 12px; border-radius: 4px; display: inline-block; }

    .lp-footer { background: #0f1f2e; padding: 24px; text-align: center; }
    .lp-footer p { font-size: 12px; color: rgba(255,255,255,0.4); line-height: 1.7; }
    .lp-footer a { color: rgba(255,255,255,0.6); text-decoration: underline; }

    .sticky-cta { position: fixed; bottom: 0; left: 0; right: 0; display: none; grid-template-columns: 1fr auto; z-index: 200; box-shadow: 0 -4px 16px rgba(0,0,0,0.15); }
    .sticky-cta .btn-wa { border-radius: 0; margin: 0; font-size: 14px; padding: 14px; }
    .sticky-cta .btn-phone { border-radius: 0; width: auto; padding: 14px 20px; }

    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; gap: 32px; }
      .treatments-grid { grid-template-columns: 1fr 1fr; }
      .types-grid { grid-template-columns: 1fr 1fr; }
      .symptoms-grid { grid-template-columns: 1fr; }
      .steps-grid { grid-template-columns: 1fr 1fr; }
      .specialists-grid { grid-template-columns: 1fr; }
      .testimonials-grid { grid-template-columns: 1fr; }
      .media-grid { grid-template-columns: 1fr 1fr; }
      .addresses-grid { grid-template-columns: 1fr 1fr; }
      .tunnel-section { grid-template-columns: 1fr; }
      .nerve-section { grid-template-columns: 1fr; }
      .sticky-cta { display: grid; }
    }
    @media (max-width: 600px) {
      .treatments-grid { grid-template-columns: 1fr; }
      .types-grid { grid-template-columns: 1fr; }
      .steps-grid { grid-template-columns: 1fr; }
      .media-grid { grid-template-columns: 1fr; }
      .addresses-grid { grid-template-columns: 1fr; }
      .specialist-card { flex-direction: column; }
      .specialist-img { width: 100%; height: 200px; }
      .units-box ul { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- Announcement Bar -->
  <div class="announcement-bar">
    Referência em glaucoma &nbsp;·&nbsp; 5 unidades em SP e Guarulhos &nbsp;·&nbsp; <strong>(11) 91654-4653</strong>
  </div>

  <!-- Header -->
  <header class="lp-header">
    <a href="/"><img src="/images/logo-horizontal-200w_opt.webp" alt="Drudi e Almeida Oftalmologia" /></a>
    <a href={PHONE} class="header-phone">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/></svg>
      (11) 91654-4653
    </a>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div>
        <div class="hero-badge">Instituto do Glaucoma — Drudi e Almeida</div>
        <h1>Proteja sua visão do <em>glaucoma</em></h1>
        <p class="hero-desc">Diagnóstico precoce, tratamento personalizado e acompanhamento contínuo. Na Drudi e Almeida, cuidamos do seu glaucoma com tecnologia avançada e especialistas dedicados a preservar cada grau da sua visão.</p>
        <div class="hero-checks">
          <span class="hero-check">✓ Laser SLT</span>
          <span class="hero-check">✓ Cirurgia MIGS</span>
          <span class="hero-check">✓ Trabeculectomia</span>
          <span class="hero-check">✓ Aceita Convênios</span>
          <span class="hero-check">✓ Pacote Consulta + Exames</span>
        </div>

        <div class="form-card">
          <select>
            <option value="">Selecione a unidade mais próxima</option>
            {unidades.map(u => <option value={u.nome}>{u.nome}</option>)}
