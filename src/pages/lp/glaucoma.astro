// LP Glaucoma — Padrão visual aprovado Instituto Drudi e Almeida
const WA_LINK = "https://wa.me/5511916544653";
const WA_PRECO = `${WA_LINK}?text=Olá! Gostaria de saber mais sobre o tratamento de glaucoma.`;
const WA_CONVENIO = `${WA_LINK}?text=Olá! Gostaria de verificar se meu convênio cobre o tratamento de glaucoma.`;
const WA_DUVIDA = `${WA_LINK}?text=Olá! Tenho uma dúvida sobre glaucoma.`;
const WA_DISPONIBILIDADE = `${WA_LINK}?text=Olá! Gostaria de agendar uma avaliação para glaucoma.`;
const PHONE = "tel:+5511916544653";
const PHONE_DISPLAY = "(11) 91654-4653";

const faq = [
  { q: "O glaucoma tem cura?", a: "O glaucoma não tem cura, mas é uma doença controlável. Com diagnóstico precoce e tratamento adequado — colírios, laser ou cirurgia — é possível preservar a visão por toda a vida. O acompanhamento regular é fundamental para monitorar a pressão intraocular e o nervo óptico." },
  { q: "Quais são os sintomas do glaucoma?", a: "O glaucoma de ângulo aberto (o mais comum) é chamado de 'ladrão silencioso da visão' porque evolui sem sintomas até estágios avançados. A perda começa pela visão periférica e só é percebida quando já há dano significativo. Por isso, o exame oftalmológico regular é essencial, especialmente após os 40 anos." },
  { q: "Quem tem mais risco de desenvolver glaucoma?", a: "Os principais fatores de risco são: pressão intraocular elevada, histórico familiar de glaucoma, idade acima de 60 anos, miopia alta, diabetes, hipertensão arterial e uso prolongado de corticosteroides. Pessoas com esses fatores devem realizar exames anuais." },
  { q: "O colírio para glaucoma precisa ser usado para sempre?", a: "Na maioria dos casos, sim. Os colírios controlam a pressão intraocular mas não curam a doença. Interromper o tratamento pode causar progressão rápida da perda visual. Em alguns casos, o laser ou a cirurgia podem reduzir ou eliminar a necessidade de colírios." },
  { q: "Meu convênio cobre o tratamento de glaucoma?", a: "Sim. Os principais planos de saúde cobrem consultas, exames (campo visual, OCT de nervo óptico, paquimetria) e procedimentos como trabeculoplastia a laser e cirurgia de glaucoma. Consulte nossa equipe para verificar a cobertura específica do seu plano." },
  { q: "Qual a diferença entre glaucoma e pressão alta nos olhos?", a: "Pressão intraocular elevada (hipertensão ocular) é um fator de risco para glaucoma, mas não é sinônimo. Glaucoma é definido pela lesão do nervo óptico, que pode ocorrer mesmo com pressão normal (glaucoma normotensivo). O diagnóstico correto exige avaliação completa do nervo óptico e campo visual." },
];

const depoimentos = [
  { nome: "Antônio Ferreira", iniciais: "AF", local: "Tratamento de Glaucoma — Guarulhos", texto: "Descobri o glaucoma num exame de rotina. Graças ao diagnóstico precoce e ao tratamento com colírios, minha pressão está controlada há 5 anos. A equipe me acompanha com muito cuidado e atenção." },
  { nome: "Maria Aparecida", iniciais: "MA", local: "Glaucoma — Santana", texto: "Minha mãe perdeu visão por glaucoma não tratado. Quando descobri que também tinha, fiquei desesperada. O Dr. Fernando me explicou tudo com calma e hoje minha visão está preservada. Gratidão enorme." },
  { nome: "Carlos Eduardo", iniciais: "CE", local: "Cirurgia de Glaucoma — Tatuapé", texto: "Fiz trabeculectomia e o resultado foi excelente. Minha pressão que estava em 32 mmHg caiu para 12 sem colírios. A cirurgia foi rápida e a recuperação tranquila. Recomendo o Instituto do Glaucoma." },
];
