// LP Glaucoma — Redesign com padrão visual do Instituto — navy/dourado, hero artístico, foco em conversão
const WA_LINK = "https://wa.me/5511916544653";
const WA_AGENDAR = `${WA_LINK}?text=Olá! Gostaria de agendar uma avaliação de glaucoma.`;
const WA_PRECO = `${WA_LINK}?text=Olá! Gostaria de agendar uma avaliação de glaucoma.`;
const WA_CONVENIO = `${WA_LINK}?text=Olá! Gostaria de verificar se meu convênio cobre o tratamento de glaucoma.`;
const WA_DUVIDA = `${WA_LINK}?text=Olá! Tenho uma dúvida sobre glaucoma.`;
const PHONE = "tel:+5511916544653";
const PHONE_DISPLAY = "(11) 91654-4653";

const unidades = [
  { nome: "Guarulhos Centro", endereco: "R. Sete de Setembro, 375", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Guarulhos" },
  { nome: "Santana — São Paulo", endereco: "R. Dr. César, 130", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Santana" },
  { nome: "Tatuapé — São Paulo", endereco: "R. Tuiuti, 2429", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Tatuape" },
  { nome: "Lapa — São Paulo", endereco: "R. Barão de Jundiaí, 221", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Lapa" },
  { nome: "São Miguel — São Paulo", endereco: "R. Bernardo Marcondes, 108", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Sao+Miguel" },
];

const faq = [
  { q: "O glaucoma tem cura?", a: "O glaucoma não tem cura, mas tem controle. Com diagnóstico precoce e tratamento adequado, é possível estabilizar a doença e preservar a visão por toda a vida. O tratamento evita a progressão da perda visual." },
  { q: "O glaucoma causa cegueira?", a: "Sim, o glaucoma é a segunda maior causa de cegueira irreversível no mundo. Porém, quando diagnosticado precocemente e tratado corretamente, a grande maioria dos pacientes preserva a visão funcional por toda a vida." },
  { q: "Quais são os sintomas do glaucoma?", a: "Na maioria dos casos, o glaucoma não apresenta sintomas nas fases iniciais — daí ser chamado de 'ladrão silencioso da visão'. Nas fases avançadas pode ocorrer perda de visão periférica, visão em túnel e, em casos de glaucoma agudo, dor intensa e visão embaçada súbita." },
  { q: "Meu convênio cobre o tratamento de glaucoma?", a: "Sim. A avaliação e o tratamento do glaucoma são cobertos pelos principais planos de saúde. Consulte nossa equipe para verificar a cobertura específica do seu plano." },
  { q: "Com que frequência preciso fazer consultas de acompanhamento?", a: "Pacientes com glaucoma controlado geralmente fazem consultas a cada 3 a 6 meses. Em casos de glaucoma em progressão ou recém-diagnosticado, o acompanhamento pode ser mais frequente para ajuste do tratamento." },
  { q: "O colírio de glaucoma precisa ser usado para sempre?", a: "Na maioria dos casos, sim. O colírio controla a pressão intraocular e deve ser usado continuamente. Em alguns casos, o laser SLT ou a cirurgia podem reduzir ou eliminar a necessidade de colírios, mas isso é avaliado individualmente." },
];

const depoimentos = [
  { nome: "Roberto Alves", iniciais: "RA", local: "Tratamento de Glaucoma — Guarulhos", texto: "Descobri o glaucoma numa consulta de rotina. Graças ao diagnóstico precoce e ao acompanhamento do Dr. Fernando, minha visão está estável há 3 anos. Sou muito grato." },
  { nome: "Sônia Ferreira", iniciais: "SF", local: "Glaucoma — Santana", texto: "Meu pai tinha glaucoma e ficou cego. Fui me consultar com medo e descobri que também tenho. Mas com o tratamento certo e acompanhamento regular, estou controlada. Recomendo muito." },
  { nome: "Carlos Mendes", iniciais: "CM", local: "Laser SLT — Tatuapé", texto: "Fiz o laser SLT para controle do glaucoma e foi excelente. Procedimento rápido, sem dor e consegui reduzir o número de colírios. Equipe muito atenciosa e competente." },
];
