<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Glaucoma em SP — Diagnóstico e Tratamento | Drudi e Almeida</title>
  <meta name="description" content="O glaucoma não dói, mas pode roubar sua visão para sempre. Diagnóstico precoce, laser SLT e cirurgia. 5 unidades em SP e Guarulhos. Agende sua avaliação." />
  <meta name="robots" content="noindex, nofollow" />
  <meta property="og:image" content="https://institutodrudiealmeida.com.br/images/og-glaucoma.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="Drudi e Almeida Clínicas Oftalmológicas" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://institutodrudiealmeida.com.br/images/og-glaucoma.jpg" />

  <link rel="canonical" href="https://institutodrudiealmeida.com.br/instituto/glaucoma/" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <!-- Fontes: preload não-bloqueante com display=swap para evitar render-blocking -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" /></noscript>
  <!-- Preload hero image para LCP rápido -->
  <link rel="preload" as="image" href="/images/glaucoma-lp-hero-480w.webp" media="(max-width: 767px)" fetchpriority="high" />
  <link rel="preload" as="image" href="/images/glaucoma-lp-hero-960w.webp" media="(min-width: 768px)" fetchpriority="high" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #2c3e50;
      --navy-deep: #1a2637;
      --gold: #c9a961;
      --gold-light: #d4b97a;
      --cream: #fafaf8;
      --cream-dark: #f2f2f0;
      --white: #ffffff;
      --gray: #6b7280;
      --green: #16a34a;
      --red: #dc2626;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--cream); color: var(--navy); line-height: 1.6; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; }

    /* ── Announcement Bar ── */
    .ann-bar {
      background: var(--navy-deep);
      color: var(--cream);
      text-align: center;
      padding: 9px 16px;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.01em;
    }
    .ann-bar strong { color: var(--gold); }

    /* ── Header ── */
    .lp-header {
      background: var(--white);
      border-bottom: 1px solid rgba(44,62,80,0.1);
      padding: 14px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 200;
      box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    }
    .lp-header img { height: 42px; }
    .header-cta {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .btn-header-phone {
      display: flex;
      align-items: center;
      gap: 7px;
      background: var(--navy);
      color: var(--white);
      padding: 9px 18px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.01em;
    }
    .btn-header-wa {
      display: flex;
      align-items: center;
      gap: 7px;
      background: #25d366;
      color: var(--white);
      padding: 9px 18px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 700;
    }

    /* ── Hero ── */
    .hero {
      position: relative;
      min-height: 90vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('/images/glaucoma-lp-hero-480w.webp');
      background-size: cover;
      background-position: center top;
    }
    @media (min-width: 768px) {
      .hero-bg { background-image: url('/images/glaucoma-lp-hero-960w.webp'); }
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(105deg, rgba(26,38,55,0.92) 0%, rgba(26,38,55,0.75) 55%, rgba(26,38,55,0.45) 100%);
    }
    .hero-content {
      position: relative;
      z-index: 10;
      max-width: 1100px;
      margin: 0 auto;
      padding: 80px 32px 60px;
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 48px;
      align-items: center;
      width: 100%;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(201,169,97,0.18);
      border: 1px solid rgba(201,169,97,0.4);
      color: var(--gold);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 22px;
    }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.2rem, 4.2vw, 3.5rem);
      font-weight: 500;
      line-height: 1.15;
      color: var(--cream);
      margin-bottom: 16px;
      text-shadow: 0 2px 12px rgba(0,0,0,0.4);
    }
    .hero h1 em { color: var(--gold); font-style: italic; }
    .hero-subtitle {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.1rem, 1.8vw, 1.4rem);
      font-weight: 400;
      color: rgba(245,240,232,0.82);
      margin-bottom: 22px;
      line-height: 1.5;
      max-width: 540px;
    }
    .hero-desc {
      font-size: 15px;
      color: rgba(245,240,232,0.80);
      line-height: 1.75;
      margin-bottom: 28px;
      max-width: 520px;
    }
    .hero-checks {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 0;
    }
    .hero-check {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--navy);
      color: var(--white);
      padding: 7px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      border: 1px solid rgba(201,169,97,0.2);
    }
    .hero-check .check-icon { color: var(--gold); font-weight: 700; }

    /* ── Form Card ── */
    .form-card {
      background: rgba(255,255,255,0.97);
      border-radius: 16px;
      padding: 32px 28px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.25);
      border: 1px solid rgba(201,169,97,0.15);
    }
    .form-card-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 4px;
    }
    .form-card-sub {
      font-size: 13px;
      color: var(--gray);
      margin-bottom: 20px;
    }
    .form-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gray);
      display: block;
      margin-bottom: 6px;
    }
    .form-select {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid #e5e7eb;
      border-radius: 8px;
      font-size: 14px;
      color: var(--navy);
      background: var(--white);
      margin-bottom: 14px;
      cursor: pointer;
      outline: none;
      font-family: 'Inter', sans-serif;
    }
    .form-select:focus { border-color: var(--gold); }
    .btn-wa-main {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      background: #25d366;
      color: var(--white);
      padding: 15px 20px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 10px;
      transition: background 0.2s;
    }
    .btn-wa-main:hover { background: #1fb855; }
    .btn-phone-main {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      background: var(--navy);
      color: var(--white);
      padding: 13px 20px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      transition: background 0.2s;
    }
    .btn-phone-main:hover { background: var(--navy-deep); }
    .google-rating {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 16px;
      font-size: 12px;
      color: var(--gray);
      justify-content: center;
    }
    .stars { color: #f59e0b; }

    /* ── Stats Bar ── */
    .stats-bar {
      background: var(--navy);
      padding: 28px 32px;
    }
    .stats-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      text-align: center;
    }
    .stat-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 600;
      color: var(--gold);
      line-height: 1;
    }
    .stat-label {
      font-size: 12px;
      color: rgba(245,240,232,0.7);
      margin-top: 4px;
      letter-spacing: 0.03em;
    }

    /* ── Convênios ── */
    .convenios-strip {
      background: var(--white);
      border-top: 1px solid #e5e7eb;
      border-bottom: 1px solid #e5e7eb;
      padding: 28px 32px;
    }
    .convenios-inner { max-width: 1100px; margin: 0 auto; }
    .convenios-label {
      text-align: center;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 18px;
    }
    .convenios-logos {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 28px;
      flex-wrap: wrap;
    }
    .convenios-logos img { height: 34px; object-fit: contain; filter: grayscale(0.2); }
    .convenio-note { text-align: center; margin-top: 14px; font-size: 13px; color: var(--gray); }
    .convenio-note a { color: var(--navy); font-weight: 600; text-decoration: underline; }

    /* ── Sections ── */
    .section { padding: 72px 32px; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 8px;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.8rem, 3.2vw, 2.6rem);
      font-weight: 500;
      color: var(--navy);
      line-height: 1.2;
      margin-bottom: 10px;
    }
    .section-title em { color: var(--gold); font-style: italic; }
    .section-subtitle { font-size: 15px; color: var(--gray); max-width: 580px; line-height: 1.7; margin-bottom: 8px; }
    .gold-line { width: 60px; height: 2px; background: var(--gold); margin: 14px 0 40px; }

    /* ── Alerta Silencioso ── */
    .alert-section { background: var(--navy); }
    .alert-section .section-label { color: var(--gold); }
    .alert-section .section-title { color: var(--cream); }
    .alert-section .section-subtitle { color: rgba(245,240,232,0.75); }
    .alert-section .gold-line { background: var(--gold); }
    .alert-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }
    .alert-image {
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }
    .alert-image img { width: 100%; height: 340px; object-fit: cover; }
    .risk-list { list-style: none; display: flex; flex-direction: column; gap: 14px; }
    .risk-item {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      background: rgba(255,255,255,0.06);
      border-radius: 10px;
      padding: 16px 18px;
      border-left: 3px solid var(--gold);
    }
    .risk-icon { font-size: 20px; flex-shrink: 0; margin-top: 2px; }
    .risk-title { font-size: 14px; font-weight: 700; color: var(--cream); margin-bottom: 2px; }
    .risk-desc { font-size: 13px; color: rgba(245,240,232,0.65); line-height: 1.5; }

    /* ── Tratamentos ── */
    .treatments-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 40px;
    }
    .treatment-card {
      background: var(--white);
      border-radius: 12px;
      padding: 28px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.07);
      border: 1px solid rgba(44,62,80,0.08);
      border-top: 3px solid var(--gold);
    }
    .treatment-icon {
      width: 48px; height: 48px;
      background: var(--navy);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px;
      font-size: 22px;
    }
    .treatment-icon svg {
      stroke: #fff;
      fill: none;
      color: #fff;
    }
    .treatment-name { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
    .treatment-desc { font-size: 13px; color: var(--gray); line-height: 1.6; }
    .treatment-badge {
      display: inline-block;
      background: rgba(201,169,97,0.12);
      color: var(--gold);
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 12px;
      margin-top: 12px;
      letter-spacing: 0.05em;
    }

    /* ── Jornada ── */
    .journey-section { background: var(--cream-dark); }
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      margin-top: 40px;
    }
    .step-card {
      text-align: center;
      padding: 28px 20px;
      background: var(--white);
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      position: relative;
    }
    .step-number {
      width: 44px; height: 44px;
      background: var(--navy);
      color: var(--gold);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      font-weight: 600;
      margin: 0 auto 16px;
    }
    .step-title { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
    .step-desc { font-size: 13px; color: var(--gray); line-height: 1.6; }

    /* ── Especialistas ── */
    .doctors-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      margin-top: 40px;
    }
    .doctor-card {
      display: flex;
      gap: 20px;
      background: var(--white);
      border-radius: 12px;
      padding: 24px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.07);
      border: 1px solid rgba(44,62,80,0.08);
    }
    .doctor-photo {
      width: 100px; height: 120px;
      border-radius: 8px;
      object-fit: cover;
      object-position: top;
      flex-shrink: 0;
    }
    .doctor-name { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600; color: var(--navy); margin-bottom: 4px; }
    .doctor-crm { font-size: 12px; color: var(--gold); font-weight: 600; margin-bottom: 10px; }
    .doctor-bio { font-size: 13px; color: var(--gray); line-height: 1.65; }

    /* ── Depoimentos ── */
    .testimonials-section { background: var(--navy); }
    .testimonials-section .section-label { color: var(--gold); }
    .testimonials-section .section-title { color: var(--cream); }
    .testimonials-section .gold-line { background: var(--gold); }
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 40px;
    }
    .testimonial-card {
      background: rgba(255,255,255,0.07);
      border-radius: 12px;
      padding: 24px;
      border: 1px solid rgba(201,169,97,0.15);
    }
    .testimonial-stars { color: #f59e0b; font-size: 14px; margin-bottom: 14px; }
    .testimonial-text { font-size: 14px; color: rgba(245,240,232,0.85); font-style: italic; line-height: 1.7; margin-bottom: 16px; }
    .testimonial-author { display: flex; align-items: center; gap: 10px; }
    .author-avatar {
      width: 38px; height: 38px; border-radius: 50%;
      background: var(--gold); color: var(--navy);
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; flex-shrink: 0;
    }
    .author-name { font-size: 13px; font-weight: 600; color: var(--cream); }
    .author-detail { font-size: 12px; color: rgba(245,240,232,0.55); }
    .verified { font-size: 11px; color: #4ade80; font-weight: 500; }

    /* ── FAQ ── */
    .faq-list { display: flex; flex-direction: column; gap: 12px; margin-top: 40px; max-width: 780px; }
    .faq-item {
      background: var(--white);
      border-radius: 10px;
      border: 1px solid rgba(44,62,80,0.1);
      overflow: hidden;
    }
    .faq-question {
      width: 100%;
      text-align: left;
      padding: 18px 20px;
      background: none;
      border: none;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 15px;
      font-weight: 600;
      color: var(--navy);
