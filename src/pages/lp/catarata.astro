---
// LP Catarata — Réplica fiel de lp.institutodrudiealmeida.com.br
// Layout dedicado sem header/footer padrão do site
const WA_LINK = "https://wa.me/5511916544653";
const WA_PRECO = `${WA_LINK}?text=Olá! Gostaria de receber o preço da cirurgia de catarata.`;
const WA_CONVENIO = `${WA_LINK}?text=Olá! Gostaria de verificar se meu convênio cobre a cirurgia de catarata.`;
const WA_DUVIDA = `${WA_LINK}?text=Olá! Tenho uma dúvida sobre a cirurgia de catarata.`;
const WA_DISPONIBILIDADE = `${WA_LINK}?text=Olá! Gostaria de consultar a disponibilidade para cirurgia de catarata.`;
const WA_PREMIUM = `${WA_LINK}?text=Olá! Tenho interesse no Pacote Premium de catarata com lente multifocal.`;
const PHONE = "tel:+5511916544653";

const unidades = [
  { nome: "Guarulhos Centro", endereco: "R. Sete de Setembro, 375", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Guarulhos" },
  { nome: "Santana — São Paulo", endereco: "R. Dr. César, 130", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Santana" },
  { nome: "Tatuapé — São Paulo", endereco: "R. Tuiuti, 2429", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Tatuape" },
  { nome: "Lapa — São Paulo", endereco: "R. Barão de Jundiaí, 221", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Lapa" },
  { nome: "São Miguel — São Paulo", endereco: "R. Bernardo Marcondes, 108", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Sao+Miguel" },
];
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cirurgia de Catarata em SP | Drudi e Almeida Clínicas Oftalmológicas</title>
  <meta name="description" content="Cirurgia de catarata a partir de R$ 2.800 em até 10x sem juros. Pacote completo com consulta, exames, lente importada e cirurgia. 5 unidades em SP e Guarulhos." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #1a2e44;
      --navy-light: #243b55;
      --gold: #c9a961;
      --gold-light: #d4b97a;
      --cream: #f5f0e8;
      --cream-dark: #ede8df;
      --white: #ffffff;
      --gray: #6b7280;
      --gray-light: #f3f4f6;
      --green: #16a34a;
    }
    body { font-family: 'Inter', sans-serif; background: var(--cream); color: var(--navy); line-height: 1.6; }
    .font-display { font-family: 'Cormorant Garamond', serif; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; }

    /* Announcement Bar */
    .announcement-bar {
      background: var(--navy);
      color: var(--cream);
      text-align: center;
      padding: 10px 16px;
      font-size: 13px;
      font-weight: 500;
    }
    .announcement-bar strong { color: var(--gold); }

    /* Header */
    .lp-header {
      background: var(--white);
      border-bottom: 1px solid rgba(0,0,0,0.08);
      padding: 14px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .lp-header img { height: 40px; }
    .header-phone {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--navy);
      color: var(--white);
      padding: 8px 18px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
    }

    /* Hero */
    .hero {
      background: var(--cream);
      padding: 48px 24px 56px;
    }
    .hero-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: start;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--navy);
      color: var(--gold);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.05em;
      margin-bottom: 20px;
    }
    .hero-badge::before { content: "●"; font-size: 8px; }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.4rem, 5vw, 3.6rem);
      font-weight: 500;
      line-height: 1.15;
      color: var(--navy);
      margin-bottom: 20px;
    }
    .hero h1 em { color: var(--gold); font-style: italic; }
    .hero-desc {
      font-size: 15px;
      color: #4b5563;
      margin-bottom: 24px;
      line-height: 1.7;
    }
    .hero-checks {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 28px;
    }
    .hero-check {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--navy);
      color: var(--white);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 500;
    }
    .hero-check strong { color: var(--gold); }

    /* Form Card */
    .form-card {
      background: var(--white);
      border-radius: 12px;
      padding: 28px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.1);
      border: 1px solid rgba(0,0,0,0.06);
    }
    .form-card select {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid #e5e7eb;
      border-radius: 8px;
      font-size: 14px;
      color: var(--navy);
      background: var(--white);
      margin-bottom: 12px;
      cursor: pointer;
      outline: none;
    }
    .form-card select:focus { border-color: var(--gold); }
    .btn-wa {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      background: #25d366;
      color: var(--white);
      padding: 14px 20px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 10px;
      transition: background 0.2s;
    }
    .btn-wa:hover { background: #1fb855; }
    .btn-phone {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      background: var(--navy);
      color: var(--white);
      padding: 12px 20px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      transition: background 0.2s;
    }
    .btn-phone:hover { background: var(--navy-light); }
    .google-rating {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 16px;
      font-size: 13px;
      color: var(--gray);
    }
    .stars { color: #f59e0b; font-size: 14px; }

    /* Testimonial Card */
    .testimonial-card {
      background: var(--white);
      border-radius: 12px;
      padding: 24px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      border: 1px solid rgba(0,0,0,0.06);
      margin-bottom: 16px;
    }
    .testimonial-card .stars { margin-bottom: 12px; display: block; }
    .testimonial-card blockquote {
      font-size: 14px;
      color: #374151;
      font-style: italic;
      line-height: 1.6;
      margin-bottom: 14px;
    }
    .testimonial-author {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .author-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
      flex-shrink: 0;
    }
    .author-name { font-size: 13px; font-weight: 600; color: var(--navy); }
    .author-detail { font-size: 12px; color: var(--gray); }
    .verified { font-size: 11px; color: var(--green); font-weight: 500; }

    /* Units List */
    .units-box {
      background: var(--navy);
      color: var(--cream);
      border-radius: 10px;
      padding: 18px 20px;
      margin-top: 16px;
    }
    .units-box h4 {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--gold);
      margin-bottom: 10px;
    }
    .units-box ul { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 4px 16px; }
    .units-box li { font-size: 13px; }
    .units-box li::before { content: "• "; color: var(--gold); }

    /* Convenios */
    .convenios-strip {
      background: var(--white);
      border-top: 1px solid #e5e7eb;
      border-bottom: 1px solid #e5e7eb;
      padding: 24px;
    }
    .convenios-strip h4 {
      text-align: center;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--gray);
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .convenios-logos {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .convenios-logos img { height: 36px; object-fit: contain; filter: grayscale(0.3); }
    .convenio-not-found {
      text-align: center;
      margin-top: 14px;
      font-size: 13px;
      color: var(--gray);
    }
    .convenio-not-found a { color: var(--navy); font-weight: 600; text-decoration: underline; }

    /* Section */
    .section { padding: 64px 24px; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 8px;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 500;
      color: var(--navy);
      margin-bottom: 12px;
      line-height: 1.2;
    }
    .section-title em { color: var(--gold); font-style: italic; }
    .section-subtitle {
      font-size: 15px;
      color: var(--gray);
      max-width: 600px;
      line-height: 1.7;
    }
    .gold-line { width: 60px; height: 2px; background: var(--gold); margin: 16px 0 40px; }

    /* Pricing */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 40px;
    }
    .price-card {
      background: var(--white);
      border-radius: 12px;
      padding: 32px 28px;
      border: 2px solid #e5e7eb;
      position: relative;
      transition: box-shadow 0.2s;
    }
    .price-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
    .price-card.featured {
      border-color: var(--gold);
      box-shadow: 0 8px 32px rgba(201,169,97,0.2);
    }
    .price-badge {
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--gold);
      color: var(--navy);
      font-size: 11px;
      font-weight: 800;
      padding: 4px 16px;
      border-radius: 20px;
      letter-spacing: 0.05em;
      white-space: nowrap;
    }
    .price-card h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      color: var(--navy);
      margin-bottom: 8px;
    }
    .price-card .price-desc { font-size: 13px; color: var(--gray); margin-bottom: 20px; line-height: 1.5; }
    .price-amount {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 4px;
    }
    .price-amount em { color: var(--gold); }
    .price-per { font-size: 12px; color: var(--gray); margin-bottom: 20px; }
    .price-features { list-style: none; margin-bottom: 24px; }
    .price-features li {
      font-size: 13px;
      color: #374151;
      padding: 6px 0;
      border-bottom: 1px solid #f3f4f6;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .price-features li::before { content: "✓"; color: var(--green); font-weight: 700; }
    .price-cta {
      display: block;
      text-align: center;
      padding: 12px 20px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      transition: all 0.2s;
    }
    .price-cta.primary { background: var(--gold); color: var(--navy); }
    .price-cta.primary:hover { background: var(--gold-light); }
    .price-cta.secondary { background: var(--navy); color: var(--white); }
    .price-cta.secondary:hover { background: var(--navy-light); }
    .price-cta.outline { border: 2px solid var(--navy); color: var(--navy); }
    .price-cta.outline:hover { background: var(--navy); color: var(--white); }
    .price-note {
      font-size: 12px;
      color: var(--gray);
      text-align: center;
      margin-top: 20px;
      line-height: 1.6;
    }
    .price-note a { color: var(--navy); text-decoration: underline; }

    /* Steps */
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
      margin-top: 40px;
    }
    .step-item { text-align: center; }
    .step-number {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
    }
    .step-item h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
    .step-item p { font-size: 13px; color: var(--gray); line-height: 1.6; }

    /* Specialists */
    .specialists-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      margin-top: 40px;
    }
    .specialist-card {
      background: var(--white);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(0,0,0,0.08);
      display: flex;
      gap: 0;
    }
    .specialist-img {
      width: 160px;
      flex-shrink: 0;
      object-fit: cover;
      object-position: top;
    }
    .specialist-info { padding: 24px; }
    .specialist-info h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      color: var(--navy);
      margin-bottom: 4px;
    }
    .specialist-crm { font-size: 12px; color: var(--gold); font-weight: 600; margin-bottom: 12px; }
    .specialist-info p { font-size: 13px; color: var(--gray); line-height: 1.6; }

    /* Testimonials Section */
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 40px;
    }

    /* Media */
    .media-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-top: 40px;
    }
    .media-card {
      background: var(--white);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      cursor: pointer;
      transition: transform 0.2s;
    }
    .media-card:hover { transform: translateY(-3px); }
    .media-thumb {
      position: relative;
      aspect-ratio: 16/9;
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .media-thumb img { width: 100%; height: 100%; object-fit: cover; opacity: 0.7; }
    .play-btn {
      position: absolute;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: rgba(255,255,255,0.9);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .play-btn::after {
      content: "";
      border-left: 16px solid var(--navy);
      border-top: 10px solid transparent;
      border-bottom: 10px solid transparent;
      margin-left: 4px;
    }
    .media-badge {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--gold);
      padding: 10px 14px 4px;
    }
    .media-card h4 { font-size: 13px; font-weight: 600; color: var(--navy); padding: 0 14px 6px; }
    .media-card p { font-size: 12px; color: var(--gray); padding: 0 14px 14px; line-height: 1.5; }

    /* FAQ */
    .faq-list { margin-top: 40px; max-width: 800px; }
    .faq-item { border-bottom: 1px solid #e5e7eb; }
    .faq-question {
      width: 100%;
      background: none;
      border: none;
      text-align: left;
      padding: 18px 0;
      font-size: 15px;
      font-weight: 600;
      color: var(--navy);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
    }
    .faq-question .icon {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
      transition: transform 0.2s;
    }
    .faq-answer {
      font-size: 14px;
      color: #4b5563;
      line-height: 1.7;
      padding-bottom: 18px;
      display: none;
    }
    .faq-item.open .faq-answer { display: block; }
    .faq-item.open .icon { transform: rotate(45deg); }
    .faq-cta { margin-top: 24px; font-size: 14px; color: var(--gray); }
    .faq-cta a { color: var(--navy); font-weight: 600; text-decoration: underline; }

    /* Final CTA */
    .final-cta {
      background: var(--navy);
      padding: 64px 24px;
      text-align: center;
    }
    .final-cta .urgency-badge {
      display: inline-block;
      background: rgba(201,169,97,0.2);
      border: 1px solid var(--gold);
      color: var(--gold);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.1em;
      padding: 6px 18px;
      border-radius: 20px;
      margin-bottom: 24px;
    }
    .final-cta h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      color: var(--white);
      margin-bottom: 16px;
      line-height: 1.2;
    }
    .final-cta h2 em { color: var(--gold); font-style: italic; }
    .final-cta p { font-size: 15px; color: rgba(255,255,255,0.75); max-width: 560px; margin: 0 auto 32px; line-height: 1.7; }
    .final-cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: #25d366;
      color: var(--white);
      padding: 16px 36px;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 700;
      transition: background 0.2s;
    }
    .final-cta-btn:hover { background: #1fb855; }
    .final-cta-trust {
      margin-top: 16px;
      font-size: 13px;
      color: rgba(255,255,255,0.5);
    }
    .final-cta-info {
      margin-top: 12px;
      font-size: 13px;
      color: rgba(255,255,255,0.5);
    }
    .final-cta-info strong { color: rgba(255,255,255,0.75); }

    /* Addresses */
    .addresses-section { background: var(--navy); padding: 48px 24px; }
    .addresses-inner { max-width: 1100px; margin: 0 auto; }
    .addresses-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
      margin-top: 24px;
    }
    .address-card { text-align: center; }
    .address-card h4 { font-size: 14px; font-weight: 700; color: var(--gold); margin-bottom: 6px; }
    .address-card p { font-size: 12px; color: rgba(255,255,255,0.7); margin-bottom: 8px; }
    .address-card a {
      font-size: 12px;
      color: var(--cream);
      border: 1px solid rgba(255,255,255,0.3);
      padding: 4px 12px;
      border-radius: 4px;
      display: inline-block;
    }

    /* Footer */
    .lp-footer {
      background: #0f1f2e;
      padding: 24px;
      text-align: center;
    }
    .lp-footer p { font-size: 12px; color: rgba(255,255,255,0.4); line-height: 1.7; }
    .lp-footer a { color: rgba(255,255,255,0.6); text-decoration: underline; }

    /* Sticky CTA Mobile */
    .sticky-cta {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      display: none;
      grid-template-columns: 1fr auto;
      z-index: 200;
      box-shadow: 0 -4px 16px rgba(0,0,0,0.15);
    }
    .sticky-cta .btn-wa { border-radius: 0; margin: 0; font-size: 14px; padding: 14px; }
    .sticky-cta .btn-phone { border-radius: 0; width: auto; padding: 14px 20px; }

    /* Responsive */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; gap: 32px; }
      .pricing-grid { grid-template-columns: 1fr; max-width: 480px; margin-left: auto; margin-right: auto; }
      .steps-grid { grid-template-columns: 1fr 1fr; }
      .specialists-grid { grid-template-columns: 1fr; }
      .testimonials-grid { grid-template-columns: 1fr; }
      .media-grid { grid-template-columns: 1fr 1fr; }
      .addresses-grid { grid-template-columns: 1fr 1fr; }
      .sticky-cta { display: grid; }
    }
    @media (max-width: 600px) {
