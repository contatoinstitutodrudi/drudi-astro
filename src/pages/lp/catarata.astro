// LP Catarata — Redesign com padrão visual do Instituto da Catarata
// Header minimalista, foco em conversão, estética premium navy/dourado
const WA_LINK = "https://wa.me/5511916544653";
const WA_PRECO = `${WA_LINK}?text=Olá! Gostaria de receber o preço da cirurgia de catarata.`;
const WA_CONVENIO = `${WA_LINK}?text=Olá! Gostaria de verificar se meu convênio cobre a cirurgia de catarata.`;
const WA_DUVIDA = `${WA_LINK}?text=Olá! Tenho uma dúvida sobre a cirurgia de catarata.`;
const WA_PREMIUM = `${WA_LINK}?text=Olá! Tenho interesse no Pacote Premium de catarata com lente multifocal.`;
const WA_DISPONIBILIDADE = `${WA_LINK}?text=Olá! Gostaria de verificar a disponibilidade de horários para cirurgia de catarata.`;
const PHONE = "tel:+5511916544653";
const PHONE_DISPLAY = "(11) 91654-4653";

const unidades = [
  { nome: "Guarulhos Centro", endereco: "R. Sete de Setembro, 375", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Guarulhos" },
  { nome: "Santana — São Paulo", endereco: "R. Dr. César, 130", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Santana" },
  { nome: "Tatuapé — São Paulo", endereco: "R. Tuiuti, 2429", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Tatuape" },
  { nome: "Lapa — São Paulo", endereco: "R. Barão de Jundiaí, 221", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Lapa" },
  { nome: "São Miguel — São Paulo", endereco: "R. Bernardo Marcondes, 108", maps: "https://maps.google.com/?q=Drudi+e+Almeida+Sao+Miguel" },
];

const faq = [
  { q: "A cirurgia de catarata é dolorosa?", a: "Não. O procedimento é realizado com anestesia local e sedação leve, garantindo total conforto. A maioria dos pacientes relata apenas uma leve pressão durante a cirurgia, sem dor." },
  { q: "Quanto tempo leva a recuperação?", a: "A recuperação é rápida. No dia seguinte à cirurgia, a maioria dos pacientes já percebe melhora significativa na visão. Atividades cotidianas como ler e assistir TV podem ser retomadas em 24–48h." },
  { q: "Preciso de acompanhante no dia da cirurgia?", a: "Sim. É necessário um acompanhante adulto para levá-lo para casa após o procedimento, pois você estará com o olho ocluído e sob efeito da sedação." },
  { q: "Meu convênio cobre a cirurgia de catarata?", a: "Sim. A cirurgia de catarata por facoemulsificação é coberta pelos principais planos de saúde. As lentes premium (multifocais, tóricas) podem ter cobertura parcial. Consulte nossa equipe para verificar seu plano." },
  { q: "Qual a diferença entre lente monofocal e multifocal?", a: "A lente monofocal corrige a visão para uma distância (geralmente longe), podendo necessitar de óculos para perto. A lente multifocal permite enxergar bem de perto, intermediário e longe sem óculos, oferecendo maior independência visual." },
  { q: "A catarata pode voltar após a cirurgia?", a: "Não. A catarata não retorna após a cirurgia, pois o cristalino opacificado é substituído por uma lente artificial permanente. Em alguns casos, pode ocorrer opacificação da cápsula posterior (catarata secundária), tratada com um procedimento a laser simples e indolor." },
];

const depoimentos = [
  { nome: "Patricia Oliveira", iniciais: "PO", local: "Cirurgia de Catarata — Santana", texto: "Fiz minha cirurgia de catarata com o Dr. Fernando e o resultado superou todas as expectativas. Equipe muito profissional e acolhedora. Recomendo de olhos fechados!" },
  { nome: "Fernando Costa", iniciais: "FC", local: "Acompanhante — Guarulhos", texto: "Minha mãe de 78 anos ficou com medo, mas a equipe explicou cada etapa com paciência. No dia seguinte ela já enxergava perfeitamente. Atendimento humanizado de verdade." },
  { nome: "Maria Regina S.", iniciais: "MR", local: "Cirurgia de Catarata — Guarulhos", texto: "Fiz a cirurgia de catarata com o Dr. Fernando e no dia seguinte já estava enxergando com nitidez. Equipe incrível, muito profissional e acolhedora!" },
];
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cirurgia de Catarata em SP | Drudi e Almeida Clínicas Oftalmológicas</title>
  <meta name="description" content="Cirurgia de catarata a partir de R$ 2.800 em até 10x sem juros. Pacote completo com consulta, exames, lente importada e cirurgia. 5 unidades em SP e Guarulhos." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href="https://institutodrudiealmeida.com.br/instituto/catarata/" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #2c3e50;
      --navy-deep: #1a2637;
      --gold: #c9a961;
      --gold-light: #d4b97a;
      --cream: #fafaf8;
      --cream-dark: #f2f2f0;
      --white: #ffffff;
      --gray: #6b7280;
      --green: #16a34a;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--cream); color: var(--navy); line-height: 1.6; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; }

    /* ── Announcement Bar ── */
    .ann-bar {
      background: var(--navy-deep);
      color: var(--cream);
      text-align: center;
      padding: 9px 16px;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.01em;
    }
    .ann-bar strong { color: var(--gold); }

    /* ── Header ── */
    .lp-header {
      background: var(--white);
      border-bottom: 1px solid rgba(44,62,80,0.1);
      padding: 14px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 200;
      box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    }
    .lp-header img { height: 42px; }
    .header-cta {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .btn-header-phone {
      display: flex;
      align-items: center;
      gap: 7px;
      background: var(--navy);
      color: var(--white);
      padding: 9px 20px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      transition: background 0.2s;
    }
    .btn-header-phone:hover { background: var(--navy-deep); }
    .btn-header-wa {
      display: flex;
      align-items: center;
      gap: 7px;
      background: #25d366;
      color: var(--white);
      padding: 9px 20px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      transition: background 0.2s;
    }
    .btn-header-wa:hover { background: #1fb855; }

    /* ── Hero ── */
    .hero {
      position: relative;
      min-height: 88vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('/images/catarata-hero-art_bd1bf3f5.webp');
      background-size: cover;
      background-position: center;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(105deg, rgba(26,38,55,0.93) 0%, rgba(26,38,55,0.75) 55%, rgba(26,38,55,0.35) 100%);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 32px 60px;
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 64px;
      align-items: center;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(201,169,97,0.15);
      border: 1px solid rgba(201,169,97,0.4);
      color: var(--gold);
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 24px;
    }
    .hero-badge::before { content: "●"; font-size: 7px; }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.6rem, 5vw, 4rem);
      font-weight: 500;
      line-height: 1.1;
      color: var(--white);
      margin-bottom: 20px;
      text-shadow: 0 2px 12px rgba(0,0,0,0.4);
    }
    .hero h1 em { color: var(--gold); font-style: italic; }
    .hero-title-sub {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.3rem, 2.2vw, 1.8rem);
      font-weight: 400;
      font-style: normal;
      color: rgba(245,240,232,0.85);
      letter-spacing: 0.01em;
      display: block;
    }
    .hero-desc {
      font-size: 16px;
      color: rgba(245,240,232,0.85);
      line-height: 1.75;
      margin-bottom: 28px;
      max-width: 520px;
    }
    .hero-checks {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 0;
    }
    .hero-check {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--navy);
      border: 1px solid var(--navy);
      color: #ffffff;
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }
    .hero-check strong { color: var(--gold); }

    /* ── Form Card (hero right) ── */
    .form-card {
      background: rgba(255,255,255,0.97);
      border-radius: 16px;
      padding: 32px 28px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.25);
      border: 1px solid rgba(201,169,97,0.2);
    }
    .form-card-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 6px;
    }
    .form-card-sub {
      font-size: 13px;
      color: var(--gray);
      margin-bottom: 20px;
    }
    .form-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--navy);
      margin-bottom: 6px;
      display: block;
    }
    .form-select {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid #d1d5db;
      border-radius: 8px;
      font-size: 14px;
      color: var(--navy);
      background: var(--white);
      margin-bottom: 16px;
      outline: none;
      transition: border-color 0.2s;
      cursor: pointer;
    }
    .form-select:focus { border-color: var(--gold); }
    .btn-wa-primary {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      width: 100%;
      background: #25d366;
      color: var(--white);
      padding: 14px 20px;
      border-radius: 9px;
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 10px;
      transition: background 0.2s, transform 0.1s;
    }
    .btn-wa-primary:hover { background: #1fb855; transform: translateY(-1px); }
    .btn-phone-secondary {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      background: var(--navy);
      color: var(--white);
      padding: 12px 20px;
      border-radius: 9px;
      font-size: 14px;
      font-weight: 600;
      transition: background 0.2s;
    }
    .btn-phone-secondary:hover { background: var(--navy-deep); }
    .google-rating {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 14px;
      padding-top: 14px;
      border-top: 1px solid #f0ede8;
      font-size: 12px;
      color: var(--gray);
    }
    .stars { color: #f59e0b; letter-spacing: 1px; }
    .gold-divider {
      width: 60px;
      height: 2px;
      background: var(--gold);
      margin: 16px 0;
    }

    /* ── Stats Bar ── */
    .stats-bar {
      background: var(--navy);
      padding: 28px 32px;
    }
    .stats-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      text-align: center;
    }
    .stat-item {}
    .stat-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.2rem;
      font-weight: 600;
      color: var(--gold);
      line-height: 1;
    }
    .stat-label {
      font-size: 12px;
      color: rgba(245,240,232,0.65);
      margin-top: 4px;
      letter-spacing: 0.03em;
    }
    .stat-divider {
      width: 1px;
      background: rgba(255,255,255,0.1);
      margin: 0 auto;
    }

    /* ── Convenios Strip ── */
    .convenios-strip {
      background: var(--white);
      border-top: 1px solid #e8e4d8;
      border-bottom: 1px solid #e8e4d8;
      padding: 28px 32px;
    }
    .convenios-inner { max-width: 1100px; margin: 0 auto; }
    .convenios-label {
      text-align: center;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--gray);
      text-transform: uppercase;
      margin-bottom: 18px;
    }
    .convenios-logos {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 32px;
      flex-wrap: wrap;
    }
    .convenios-logos img { height: 34px; object-fit: contain; filter: grayscale(0.2); opacity: 0.85; transition: opacity 0.2s; }
    .convenios-logos img:hover { opacity: 1; }
    .convenio-cta { text-align: center; margin-top: 14px; font-size: 13px; color: var(--gray); }
    .convenio-cta a { color: var(--navy); font-weight: 600; border-bottom: 1px solid var(--gold); }

    /* ── Sections ── */
    .section { padding: 80px 32px; }
    .section-alt { background: var(--white); }
    .section-dark { background: var(--navy); }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 10px;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.9rem, 3.5vw, 2.8rem);
      font-weight: 500;
      color: var(--navy);
      line-height: 1.2;
      margin-bottom: 12px;
    }
    .section-title em { color: var(--gold); font-style: italic; }
    .section-title-light { color: var(--white); }
    .section-subtitle {
      font-size: 15px;
      color: var(--gray);
      max-width: 580px;
      line-height: 1.75;
      margin-bottom: 0;
    }
    .section-subtitle-light { color: rgba(245,240,232,0.7); }

    /* ── Pricing ── */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 48px;
    }
    .price-card {
      background: var(--white);
      border-radius: 14px;
      padding: 32px 28px;
      border: 1.5px solid #e8e4d8;
      position: relative;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .price-card:hover { box-shadow: 0 8px 32px rgba(44,62,80,0.12); transform: translateY(-3px); }
    .price-card.featured {
      border-color: var(--gold);
      box-shadow: 0 4px 24px rgba(201,169,97,0.2);
    }
    .featured-badge {
      position: absolute;
      top: -13px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--gold);
      color: var(--navy);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.1em;
      padding: 4px 18px;
      border-radius: 20px;
      white-space: nowrap;
    }
    .price-card-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 8px;
    }
    .price-card-desc {
      font-size: 13px;
      color: var(--gray);
      line-height: 1.6;
      margin-bottom: 20px;
      min-height: 48px;
    }
    .price-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.4rem;
      font-weight: 600;
      color: var(--gold);
      line-height: 1;
    }
    .price-value em { font-style: normal; }
    .price-note {
      font-size: 12px;
      color: var(--gray);
      margin-bottom: 20px;
      margin-top: 4px;
    }
    .price-features {
      list-style: none;
      margin-bottom: 28px;
      space-y: 8px;
    }
    .price-features li {
      display: flex;
      align-items: flex-start;
      gap: 9px;
      font-size: 13px;
      color: #374151;
      padding: 5px 0;
      border-bottom: 1px solid #f5f0e8;
    }
    .price-features li:last-child { border-bottom: none; }
    .check-icon { color: var(--gold); font-size: 14px; flex-shrink: 0; margin-top: 1px; }
    .btn-price {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 13px 20px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 700;
      transition: all 0.2s;
    }
    .btn-price-outline {
      background: transparent;
      border: 1.5px solid var(--navy);
      color: var(--navy);
    }
    .btn-price-outline:hover { background: var(--navy); color: var(--white); }
    .btn-price-gold {
      background: var(--gold);
      color: var(--navy);
      border: 1.5px solid var(--gold);
    }
    .btn-price-gold:hover { background: var(--gold-light); }
    .btn-price-navy {
      background: var(--navy);
      color: var(--white);
      border: 1.5px solid var(--navy);
    }
    .btn-price-navy:hover { background: var(--navy-deep); }
    .price-disclaimer {
      margin-top: 24px;
      font-size: 12px;
      color: var(--gray);
      text-align: center;
    }
    .price-disclaimer a { color: var(--navy); border-bottom: 1px solid var(--gold); }

    /* ── Steps ── */
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      margin-top: 48px;
      position: relative;
    }
    .steps-grid::before {
      content: '';
      position: absolute;
      top: 28px;
      left: 12.5%;
      right: 12.5%;
      height: 1px;
      background: linear-gradient(to right, var(--gold), rgba(201,169,97,0.3));
      z-index: 0;
    }
    .step-card {
      text-align: center;
      position: relative;
      z-index: 1;
    }
    .step-number {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--navy);
      border: 2px solid var(--gold);
      color: var(--gold);
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
    }
    .step-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 8px;
    }
    .step-desc { font-size: 13px; color: var(--gray); line-height: 1.65; }

    /* ── Specialists ── */
    .specialists-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      margin-top: 48px;
    }
    .specialist-card {
      display: flex;
      gap: 24px;
      background: var(--white);
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid #e8e4d8;
      transition: box-shadow 0.2s;
    }
    .specialist-card:hover { box-shadow: 0 6px 24px rgba(44,62,80,0.1); }
    .specialist-img {
      width: 160px;
      flex-shrink: 0;
      object-fit: cover;
      object-position: top;
    }
    .specialist-info { padding: 24px 20px 24px 0; }
    .specialist-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 4px;
    }
    .specialist-crm {
      font-size: 11px;
      color: var(--gold);
      font-weight: 600;
      letter-spacing: 0.05em;
      margin-bottom: 10px;
    }
    .specialist-bio { font-size: 13px; color: var(--gray); line-height: 1.65; }

    /* ── Testimonials ── */
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 48px;
    }
    .testimonial-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(201,169,97,0.2);
      border-radius: 14px;
      padding: 28px 24px;
    }
    .testimonial-stars { color: var(--gold); font-size: 15px; letter-spacing: 2px; margin-bottom: 14px; }
    .testimonial-text {
      font-size: 14px;
      color: rgba(245,240,232,0.85);
      font-style: italic;
      line-height: 1.7;
      margin-bottom: 18px;
    }
    .testimonial-author { display: flex; align-items: center; gap: 12px; }
    .author-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--gold);
      color: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 800;
      flex-shrink: 0;
    }
    .author-name { font-size: 13px; font-weight: 700; color: var(--cream); }
    .author-detail { font-size: 12px; color: rgba(245,240,232,0.55); }
    .verified-badge { font-size: 11px; color: #4ade80; font-weight: 500; }

    /* ── FAQ ── */
    .faq-list { max-width: 820px; margin-top: 48px; }
    .faq-item { border-bottom: 1px solid #e8e4d8; }
    .faq-question {
      width: 100%;
      background: none;
      border: none;
      text-align: left;
      padding: 20px 0;
      font-size: 15px;
      font-weight: 600;
      color: var(--navy);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      transition: color 0.2s;
    }
    .faq-question:hover { color: var(--gold); }
    .faq-icon {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 1.5px solid var(--navy);
      color: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
      transition: all 0.25s;
    }
    .faq-item.open .faq-icon { transform: rotate(45deg); background: var(--navy); color: var(--white); border-color: var(--navy); }
    .faq-answer {
      font-size: 14px;
      color: #4b5563;
      line-height: 1.75;
      padding-bottom: 20px;
      display: none;
    }
    .faq-item.open .faq-answer { display: block; }

    /* ── Final CTA ── */
    .final-cta {
      background: var(--navy-deep);
      background-image: url('/images/catarata-hero-art_bd1bf3f5.webp');
      background-size: cover;
      background-position: center 30%;
      position: relative;
      padding: 80px 32px;
      text-align: center;
    }
    .final-cta::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(26,38,55,0.88);
    }
    .final-cta-inner { position: relative; z-index: 1; max-width: 680px; margin: 0 auto; }
    .final-urgency {
      display: inline-block;
      background: rgba(201,169,97,0.15);
      border: 1px solid rgba(201,169,97,0.5);
      color: var(--gold);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      padding: 6px 20px;
      border-radius: 20px;
      margin-bottom: 24px;
      text-transform: uppercase;
    }
    .final-cta h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.2rem, 4vw, 3.2rem);
      color: var(--white);
      margin-bottom: 16px;
      line-height: 1.15;
    }
    .final-cta h2 em { color: var(--gold); font-style: italic; }
    .final-cta p { font-size: 15px; color: rgba(245,240,232,0.75); margin-bottom: 36px; line-height: 1.75; }
    .btn-final-wa {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: #25d366;
      color: var(--white);
      padding: 16px 40px;
      border-radius: 9px;
      font-size: 16px;
      font-weight: 700;
      transition: all 0.2s;
      box-shadow: 0 4px 20px rgba(37,211,102,0.3);
    }
    .btn-final-wa:hover { background: #1fb855; transform: translateY(-2px); box-shadow: 0 6px 28px rgba(37,211,102,0.4); }
    .final-trust { margin-top: 16px; font-size: 13px; color: rgba(245,240,232,0.45); }

    /* ── Addresses ── */
    .addresses-section { background: var(--navy); padding: 56px 32px; }
    .addresses-inner { max-width: 1100px; margin: 0 auto; }
    .addresses-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 500;
      color: var(--white);
      margin-bottom: 32px;
      text-align: center;
    }
    .addresses-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
    }
    .address-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(201,169,97,0.2);
      border-radius: 10px;
      padding: 20px 16px;
      text-align: center;
      transition: background 0.2s;
    }
    .address-card:hover { background: rgba(255,255,255,0.08); }
    .address-card h4 { font-size: 13px; font-weight: 700; color: var(--gold); margin-bottom: 6px; }
    .address-card p { font-size: 12px; color: rgba(245,240,232,0.65); margin-bottom: 12px; line-height: 1.5; }
    .address-map-link {
      font-size: 11px;
      color: var(--cream);
      border: 1px solid rgba(245,240,232,0.25);
      padding: 5px 14px;
      border-radius: 4px;
      display: inline-block;
      transition: border-color 0.2s;
    }
    .address-map-link:hover { border-color: var(--gold); color: var(--gold); }

    /* ── Footer ── */
    .lp-footer {
      background: #0f1f2e;
      padding: 24px 32px;
      text-align: center;
    }
    .lp-footer p { font-size: 12px; color: rgba(255,255,255,0.35); line-height: 1.8; }
    .lp-footer a { color: rgba(255,255,255,0.55); border-bottom: 1px solid rgba(255,255,255,0.2); }

    /* ── Sticky CTA Mobile ── */
    .sticky-cta {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      display: none;
      grid-template-columns: 1fr auto;
      z-index: 300;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.2);
    }
    .sticky-cta .s-wa {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #25d366;
      color: var(--white);
      padding: 15px;
      font-size: 14px;
      font-weight: 700;
    }
    .sticky-cta .s-phone {
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--navy);
      color: var(--white);
      padding: 15px 20px;
    }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
      .hero-content { grid-template-columns: 1fr 380px; gap: 40px; }
      .pricing-grid { grid-template-columns: 1fr; max-width: 480px; margin-left: auto; margin-right: auto; }
      .specialists-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 860px) {
      .hero-content { grid-template-columns: 1fr; }
      .form-card { max-width: 480px; }
      .steps-grid { grid-template-columns: 1fr 1fr; }
      .steps-grid::before { display: none; }
      .testimonials-grid { grid-template-columns: 1fr; }
      .addresses-grid { grid-template-columns: 1fr 1fr; }
      .stats-inner { grid-template-columns: 1fr 1fr; }
      .sticky-cta { display: grid; }
      .lp-header { padding: 12px 20px; }
      .btn-header-wa { display: none; }
    }
    @media (max-width: 600px) {
      .hero { min-height: auto; }
      .hero-content { padding: 60px 20px 40px; }
      .section { padding: 56px 20px; }
      .steps-grid { grid-template-columns: 1fr; }
      .addresses-grid { grid-template-columns: 1fr; }
      .specialist-card { flex-direction: column; }
      .specialist-img { width: 100%; height: 220px; }
          .btn-header-phone { display: none; }
      .lp-header { padding: 10px 16px; }
      .btn-header-wa { font-size: 11px; padding: 7px 12px; }
    }
  </style>
</head>
