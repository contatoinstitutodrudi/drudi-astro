---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { UNITS, SPECIALTIES } from '../../lib/constants';
---
<BaseLayout
  title="Painel Admin — Agendamentos | Drudi e Almeida"
  description="Painel administrativo de agendamentos."
  canonicalPath="/admin/agendamentos"
>
  <div class="min-h-screen bg-[#f8f7f4]">
    <!-- Header -->
    <header class="bg-navy shadow-lg">
      <div class="container py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gold/20 flex items-center justify-center">
            <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <div>
            <span class="font-ui text-sm font-bold text-cream">Drudi e Almeida</span>
            <span class="font-ui text-[10px] text-gold/80 block -mt-0.5">Painel Administrativo</span>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <a href="/" class="font-ui text-xs text-cream/60 hover:text-cream transition-colors hidden sm:flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>Ver site
          </a>
          <button id="btn-logout" class="font-ui text-xs bg-white/10 hover:bg-white/20 text-cream px-3 py-1.5 rounded-lg transition-colors">Sair</button>
        </div>
      </div>
    </header>

    <main class="container py-6">
      <!-- ── Tabs ── -->
      <div class="flex gap-1 mb-6 bg-white rounded-xl p-1 border border-border/40 shadow-sm w-fit">
        <button id="tab-dash" class="tab-btn font-ui text-sm font-semibold px-5 py-2.5 rounded-lg bg-navy text-cream transition-all">Dashboard</button>
        <button id="tab-list" class="tab-btn font-ui text-sm font-semibold px-5 py-2.5 rounded-lg text-muted-foreground hover:text-navy transition-all">Agendamentos</button>
        <button id="tab-agenda" class="tab-btn font-ui text-sm font-semibold px-5 py-2.5 rounded-lg text-muted-foreground hover:text-navy transition-all">Agenda</button>
        <button id="tab-novo" class="tab-btn font-ui text-sm font-semibold px-5 py-2.5 rounded-lg text-muted-foreground hover:text-navy transition-all">+ Novo</button>
        <button id="tab-block" class="tab-btn font-ui text-sm font-semibold px-5 py-2.5 rounded-lg text-muted-foreground hover:text-navy transition-all">Bloqueios</button>
        <button id="tab-leads" class="tab-btn font-ui text-sm font-semibold px-5 py-2.5 rounded-lg text-muted-foreground hover:text-navy transition-all">📧 Leads E-books</button>
      </div>

      <!-- ═══════════ TAB: DASHBOARD ═══════════ -->
      <div id="view-dash">
        <!-- KPI Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          <div class="bg-white rounded-xl border border-border/40 p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-xl bg-navy/8 flex items-center justify-center"><svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></div>
              <div>
                <div class="font-ui text-[10px] text-muted-foreground uppercase tracking-wider">Total</div>
                <div id="kpi-total" class="font-display text-2xl text-navy font-bold">—</div>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl border border-border/40 p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-xl bg-gold/10 flex items-center justify-center"><svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div>
              <div>
                <div class="font-ui text-[10px] text-muted-foreground uppercase tracking-wider">Hoje</div>
                <div id="kpi-today" class="font-display text-2xl text-navy font-bold">—</div>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl border border-border/40 p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center"><svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
              <div>
                <div class="font-ui text-[10px] text-muted-foreground uppercase tracking-wider">Confirmados</div>
                <div id="kpi-confirmed" class="font-display text-2xl text-emerald-600 font-bold">—</div>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl border border-border/40 p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center"><svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
              <div>
                <div class="font-ui text-[10px] text-muted-foreground uppercase tracking-wider">Pendentes</div>
                <div id="kpi-pending" class="font-display text-2xl text-amber-600 font-bold">—</div>
              </div>
            </div>
          </div>
        </div>
        <!-- Charts row -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
          <div class="bg-white rounded-xl border border-border/40 p-5 shadow-sm">
            <h3 class="font-ui text-sm font-bold text-navy mb-4">Agendamentos por Unidade</h3>
            <div id="chart-units" class="space-y-3"></div>
          </div>
          <div class="bg-white rounded-xl border border-border/40 p-5 shadow-sm">
            <h3 class="font-ui text-sm font-bold text-navy mb-4">Próximos 7 Dias</h3>
            <div id="chart-week" class="space-y-2"></div>
          </div>
        </div>
        <!-- Recent -->
        <div class="bg-white rounded-xl border border-border/40 p-5 shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-ui text-sm font-bold text-navy">Últimos Agendamentos</h3>
            <button id="go-list" class="font-ui text-xs text-gold hover:text-gold/80 font-semibold transition-colors">Ver todos →</button>
          </div>
          <div id="recent-list" class="divide-y divide-border/40"></div>
        </div>
      </div>

      <!-- ═══════════ TAB: AGENDAMENTOS ═══════════ -->
      <div id="view-list" class="hidden">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-5">
          <div>
            <h2 class="font-display text-xl text-navy">Lista de Agendamentos</h2>
            <p class="font-body text-xs text-muted-foreground mt-1" id="count-label">Carregando...</p>
          </div>
          <button id="btn-export" class="inline-flex items-center gap-2 bg-white border border-border text-navy font-ui text-xs font-semibold px-4 py-2.5 rounded-lg hover:bg-navy hover:text-cream transition-all shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>Exportar CSV
          </button>
        </div>
        <!-- Filtros -->
        <div class="bg-white rounded-xl border border-border/40 shadow-sm p-4 mb-5">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <div>
              <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Status</label>
              <select id="filter-status" class="w-full border border-border/60 rounded-lg px-3 py-2 text-sm bg-white text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all">
                <option value="all">Todos</option><option value="pending">Pendente</option><option value="confirmed">Confirmado</option><option value="cancelled">Cancelado</option>
              </select>
            </div>
            <div>
              <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Unidade</label>
              <select id="filter-unit" class="w-full border border-border/60 rounded-lg px-3 py-2 text-sm bg-white text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all">
                <option value="all">Todas</option>
                {UNITS.map(u=><option value={u.value}>{u.value}</option>)}
              </select>
            </div>
            <div>
              <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Especialidade</label>
              <select id="filter-specialty" class="w-full border border-border/60 rounded-lg px-3 py-2 text-sm bg-white text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all">
                <option value="all">Todas</option>
                {SPECIALTIES.map(s=><option value={s.value}>{s.label}</option>)}
              </select>
            </div>
            <div>
              <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Data</label>
              <input id="filter-date" type="date" class="w-full border border-border/60 rounded-lg px-3 py-2 text-sm bg-white text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"/>
            </div>
          </div>
          <div class="flex gap-2 mt-3">
            <button id="btn-filter" class="bg-navy text-cream font-ui text-xs font-bold px-5 py-2 rounded-lg hover:bg-navy/90 transition-colors">Filtrar</button>
            <button id="btn-clear" class="border border-border text-muted-foreground font-ui text-xs px-4 py-2 rounded-lg hover:bg-muted/50 transition-colors">Limpar</button>
          </div>
        </div>
        <!-- Loading -->
        <div id="table-loading" class="text-center py-12">
          <div class="w-6 h-6 border-2 border-navy border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
          <p class="text-muted-foreground text-sm">Carregando...</p>
        </div>
        <!-- Table -->
        <div id="table-container" class="hidden">
          <div class="bg-white rounded-xl border border-border/40 shadow-sm overflow-hidden">
            <div id="cards-view" class="block sm:hidden divide-y divide-border/40"></div>
            <div class="hidden sm:block overflow-x-auto">
              <table class="w-full text-sm">
                <thead><tr class="bg-[#f8f7f4] border-b border-border/40">
                  <th class="text-left font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3">Paciente</th>
                  <th class="text-left font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3">Data / Hora</th>
                  <th class="text-left font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3">Unidade</th>
                  <th class="text-left font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3">Especialidade</th>
                  <th class="text-left font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3">Plano</th>
                  <th class="text-left font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3">Status</th>
                  <th class="text-left font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3">Ações</th>
                </tr></thead>
                <tbody id="table-body" class="divide-y divide-border/30"></tbody>
              </table>
            </div>
          </div>
          <div id="empty-state" class="hidden text-center py-16">
            <svg class="w-12 h-12 text-muted-foreground/30 mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            <p class="text-muted-foreground font-medium text-sm">Nenhum agendamento encontrado</p>
          </div>
        </div>
      </div>

      <!-- ═══════════ TAB: AGENDA SEMANAL ═══════════ -->
      <div id="view-agenda" class="hidden">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-5">
          <div>
            <h2 class="font-display text-xl text-navy">Agenda Semanal</h2>
            <p class="font-body text-xs text-muted-foreground mt-1">Visualize e gerencie os horários por unidade.</p>
          </div>
          <div class="flex items-center gap-2 ml-auto">
            <button id="agenda-prev" class="w-8 h-8 rounded-lg border border-border hover:border-gold/50 flex items-center justify-center text-muted-foreground hover:text-gold transition-all"><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg></button>
            <span id="agenda-week-label" class="font-ui text-sm font-semibold text-navy min-w-[180px] text-center"></span>
            <button id="agenda-next" class="w-8 h-8 rounded-lg border border-border hover:border-gold/50 flex items-center justify-center text-muted-foreground hover:text-gold transition-all"><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg></button>
          </div>
          <div>
            <select id="agenda-unit" class="border border-border/60 rounded-lg px-3 py-2 text-sm bg-white text-navy focus:border-gold outline-none transition-all">
              {UNITS.map(u=><option value={u.value}>{u.value}</option>)}
            </select>
          </div>
        </div>
        <div id="agenda-grid" class="bg-white rounded-xl border border-border/40 shadow-sm overflow-hidden">
          <div class="text-center py-12 text-muted-foreground text-sm">Carregando agenda...</div>
        </div>
      </div>

      <!-- ═══════════ TAB: NOVO AGENDAMENTO ═══════════ -->
      <div id="view-novo" class="hidden">
        <div class="max-w-2xl">
          <div class="mb-5">
            <h2 class="font-display text-xl text-navy">Novo Agendamento Manual</h2>
            <p class="font-body text-xs text-muted-foreground mt-1">Crie um agendamento diretamente pelo painel administrativo.</p>
          </div>
          <div class="bg-white rounded-xl border border-border/40 shadow-sm p-6">
            <form id="form-novo" class="space-y-4">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Nome do Paciente *</label>
                  <input name="patient_name" required type="text" placeholder="Nome completo" class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy placeholder:text-muted-foreground/50 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"/>
                </div>
                <div>
                  <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Telefone (WhatsApp) *</label>
                  <input name="patient_phone" required type="tel" placeholder="(11) 99999-9999" class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy placeholder:text-muted-foreground/50 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"/>
                </div>
              </div>
              <div>
                <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">E-mail (opcional)</label>
                <input name="patient_email" type="email" placeholder="paciente@email.com" class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy placeholder:text-muted-foreground/50 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"/>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Unidade *</label>
                  <select name="unit" required class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all">
                    <option value="" disabled selected>Selecione...</option>
                    {UNITS.map(u=><option value={u.value}>{u.value}</option>)}
                  </select>
                </div>
                <div>
                  <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Especialidade *</label>
                  <select name="specialty" required class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all">
                    <option value="" disabled selected>Selecione...</option>
                    {SPECIALTIES.map(s=><option value={s.value}>{s.label}</option>)}
                  </select>
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Convênio / Particular *</label>
                  <select name="health_plan" required class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all">
                    <option value="" disabled selected>Selecione...</option>
                    {HEALTH_PLANS.map(p=><option value={p}>{p}</option>)}
                  </select>
                </div>
                <div>
                  <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Tipo de Consulta *</label>
                  <select name="appointment_type" required class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all">
                    <option value="primeira_vez">Primeira Consulta</option>
                    <option value="retorno">Retorno</option>
                    <option value="exame">Exame / Procedimento</option>
                  </select>
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Data *</label>
                  <input name="appointment_date" required type="date" class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"/>
                </div>
                <div>
                  <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Horário *</label>
                  <select name="appointment_time" required class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all">
                    <option value="" disabled selected>Selecione...</option>
                    <option value="8:0">08h</option>
                    <option value="8:30">08h30</option>
                    <option value="9:0">09h</option>
                    <option value="9:30">09h30</option>
                    <option value="10:0">10h</option>
                    <option value="10:30">10h30</option>
                    <option value="11:0">11h</option>
                    <option value="11:30">11h30</option>
                    <option value="12:0">12h</option>
                    <option value="12:30">12h30</option>
                    <option value="13:0">13h</option>
                    <option value="13:30">13h30</option>
                    <option value="14:0">14h</option>
                    <option value="14:30">14h30</option>
                    <option value="15:0">15h</option>
                    <option value="15:30">15h30</option>
                    <option value="16:0">16h</option>
                    <option value="16:30">16h30</option>
                    <option value="17:0">17h</option>
                    <option value="17:30">17h30</option>
                  </select>
                </div>
              </div>
              <div>
                <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Observações (opcional)</label>
                <textarea name="notes" rows={2} placeholder="Informações adicionais..." class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy placeholder:text-muted-foreground/50 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all resize-none"></textarea>
              </div>
              <div id="novo-err" class="hidden">
                <p class="font-ui text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-3"></p>
              </div>
              <div id="novo-ok" class="hidden">
                <p class="font-ui text-sm text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-lg px-4 py-3">Agendamento criado com sucesso!</p>
              </div>
              <button type="submit" id="btn-novo" class="w-full bg-navy text-cream font-ui text-sm font-bold py-3 rounded-xl hover:bg-navy/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                <span id="btn-novo-txt">Criar Agendamento</span>
                <span id="btn-novo-spin" class="hidden">Criando...</span>
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- ═══════════ TAB: BLOQUEIOS ═══════════ -->
      <div id="view-block" class="hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Bloquear dia -->
          <div class="bg-white rounded-xl border border-border/40 shadow-sm p-6">
            <h3 class="font-ui text-sm font-bold text-navy mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
              Bloquear Dia
            </h3>
            <div class="space-y-3">
              <div>
                <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Unidade</label>
                <select id="block-unit" class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy focus:border-gold outline-none transition-all">
                  {UNITS.map(u=><option value={u.value}>{u.value}</option>)}
                </select>
              </div>
              <div>
                <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Data</label>
                <input id="block-date" type="date" class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy focus:border-gold outline-none transition-all"/>
              </div>
              <div>
                <label class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1 block">Motivo (opcional)</label>
                <input id="block-reason" type="text" placeholder="Ex: Feriado, manutenção..." class="w-full border border-border/60 rounded-lg px-3 py-2.5 text-sm bg-white text-navy placeholder:text-muted-foreground/50 focus:border-gold outline-none transition-all"/>
              </div>
              <button id="btn-block" class="w-full bg-red-600 text-white font-ui text-sm font-bold py-2.5 rounded-lg hover:bg-red-700 transition-colors">Bloquear Dia</button>
