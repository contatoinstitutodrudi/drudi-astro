            </div>
            <button id="btn-leads-buscar" class="bg-navy text-cream font-ui text-sm font-bold px-5 py-2 rounded-lg hover:bg-navy/90 transition-colors">Filtrar</button>
            <button id="btn-leads-export" class="bg-emerald-600 text-white font-ui text-sm font-bold px-5 py-2 rounded-lg hover:bg-emerald-700 transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              Exportar CSV
            </button>
          </div>
        </div>

        <!-- Tabela de Leads -->
        <div class="bg-white rounded-xl border border-border/40 shadow-sm overflow-hidden">
          <div class="p-4 border-b border-border/40 flex items-center justify-between">
            <h3 class="font-ui text-sm font-bold text-navy">Leads Captados</h3>
            <span id="leads-count-label" class="font-ui text-xs text-muted-foreground">Carregando...</span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="bg-navy/4 border-b border-border/40">
                  <th class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3 text-left">Nome</th>
                  <th class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3 text-left">E-mail</th>
                  <th class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3 text-left">Telefone</th>
                  <th class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3 text-left">E-book</th>
                  <th class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3 text-left">E-mail</th>
                  <th class="font-ui text-[10px] font-bold text-muted-foreground uppercase tracking-wider px-4 py-3 text-left">Data</th>
                </tr>
              </thead>
              <tbody id="leads-tbody">
                <tr><td colspan="6" class="text-center py-8 text-muted-foreground text-sm">Carregando...</td></tr>
              </tbody>
            </table>
          </div>
          <!-- Paginação -->
          <div id="leads-pagination" class="p-4 border-t border-border/40 flex items-center justify-between hidden">
            <button id="leads-prev" class="font-ui text-xs font-semibold text-navy border border-border/60 px-4 py-2 rounded-lg hover:bg-navy/5 transition-colors disabled:opacity-40" disabled>← Anterior</button>
            <span id="leads-page-info" class="font-ui text-xs text-muted-foreground"></span>
            <button id="leads-next" class="font-ui text-xs font-semibold text-navy border border-border/60 px-4 py-2 rounded-lg hover:bg-navy/5 transition-colors disabled:opacity-40">Próxima →</button>
          </div>
        </div>

        <!-- Distribuição por E-book -->
        <div class="bg-white rounded-xl border border-border/40 shadow-sm p-5 mt-4">
          <h3 class="font-ui text-sm font-bold text-navy mb-4">Distribuição por E-book</h3>
          <div id="leads-stats-grid" class="grid grid-cols-2 md:grid-cols-5 gap-3">
            <p class="text-muted-foreground text-sm col-span-5 text-center py-4">Carregando...</p>
          </div>
        </div>
      </div>

    </main>
  </div>
</BaseLayout>

<script>
// ============================================================
// Painel Admin — Dashboard + Agendamentos + Bloqueios
// ============================================================
type Appt={id:number;patient_name:string;patient_phone:string;patient_email:string|null;unit:string;specialty:string;health_plan:string;appointment_date:string;appointment_hour:number;appointment_minute:number;appointment_type:string;status:'pending'|'confirmed'|'cancelled';notes:string|null;created_at:number};
type Block={id:number;unit:string;date:string;reason:string|null};

let allData:Appt[]=[];
const SL:Record<string,{l:string;c:string}>={pending:{l:'Pendente',c:'bg-amber-100 text-amber-800'},confirmed:{l:'Confirmado',c:'bg-emerald-100 text-emerald-700'},cancelled:{l:'Cancelado',c:'bg-red-100 text-red-700'}};
const TL:Record<string,string>={primeira_vez:'Primeira Consulta',retorno:'Retorno',exame:'Exame / Procedimento'};
const MO=['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
const UNITS_ARR=[{value:'Santana'},{value:'Tatuapé'},{value:'Lapa'},{value:'São Miguel'},{value:'Guarulhos'}];
const UC:Record<string,string>={Santana:'#3b82f6',Tatuapé:'#8b5cf6',Lapa:'#f59e0b',['São Miguel']:'#10b981',Guarulhos:'#ef4444'};

const $=(id:string)=>document.getElementById(id)!;
function fmtD(d:string){const[y,m,day]=d.split('-');return`${day}/${m}/${y}`}
function fmtH(h:number,m:number){return`${String(h).padStart(2,'0')}h${m>0?String(m).padStart(2,'0'):''}`}
function fmtDLong(d:string){const[y,m,day]=d.split('-');return`${day} de ${MO[+m-1]} de ${y}`}
function today(){const d=new Date();return`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`}

// ── Tabs ──
function switchTab(tab:string){
  ['dash','list','agenda','novo','block','leads'].forEach(t=>{
    $(`view-${t}`)?.classList.toggle('hidden',t!==tab);
    $(`tab-${t}`)?.className.toString();
    const el=$(`tab-${t}`);
    if(el)el.className=`tab-btn font-ui text-sm font-semibold px-5 py-2.5 rounded-lg transition-all ${t===tab?'bg-navy text-cream':'text-muted-foreground hover:text-navy'}`;
  });
  if(tab==='list')loadList();
  if(tab==='block')loadBlocks();
  if(tab==='agenda')loadAgenda();
  if(tab==='leads')loadLeads();
}
$('tab-dash').addEventListener('click',()=>switchTab('dash'));
$('tab-list').addEventListener('click',()=>switchTab('list'));
$('tab-agenda').addEventListener('click',()=>switchTab('agenda'));
$('tab-novo').addEventListener('click',()=>switchTab('novo'));
$('tab-block').addEventListener('click',()=>switchTab('block'));
$('go-list')?.addEventListener('click',()=>switchTab('list'));
$('tab-leads').addEventListener('click',()=>switchTab('leads'));

// ── Agenda Semanal ──
let agendaWeekOffset=0;
async function loadAgenda(){
  const unit=($('agenda-unit') as HTMLSelectElement).value;
  const d=new Date();
  d.setDate(d.getDate()-d.getDay()+1+agendaWeekOffset*7); // segunda-feira
  const days:string[]=[];
  for(let i=0;i<6;i++){const dd=new Date(d);dd.setDate(d.getDate()+i);days.push(`${dd.getFullYear()}-${String(dd.getMonth()+1).padStart(2,'0')}-${String(dd.getDate()).padStart(2,'0')}`);}
  const start=days[0],end=days[days.length-1];
  const wl=$('agenda-week-label');if(wl)wl.textContent=`${fmtD(start)} – ${fmtD(end)}`;
  const grid=$('agenda-grid');if(!grid)return;
  grid.innerHTML='<div class="text-center py-8 text-muted-foreground text-sm">Carregando...</div>';
  try{
    const r=await fetch(`/api/admin/agendamentos/?status=all&unit=${encodeURIComponent(unit)}&specialty=all`);
    if(r.status===401){window.location.href='/admin/login';return;}
    const appts:Appt[]=await r.json();
    const byDay:Record<string,Appt[]>={};
    days.forEach(d=>byDay[d]=[]);
    appts.filter(a=>a.appointment_date>=start&&a.appointment_date<=end&&a.unit===unit).forEach(a=>{if(byDay[a.appointment_date])byDay[a.appointment_date].push(a);});
    const WDN=['Seg','Ter','Qua','Qui','Sex','Sáb'];
    let html='<div class="grid grid-cols-3 sm:grid-cols-6 divide-x divide-border/40">';
    days.forEach((d,i)=>{
      const list=byDay[d]||[];
      const isToday=d===today();
      html+=`<div class="${isToday?'bg-gold/5':''}"><div class="px-3 py-2 border-b border-border/40 text-center"><div class="font-ui text-[10px] font-bold ${isToday?'text-gold':'text-muted-foreground'} uppercase">${WDN[i]}</div><div class="font-ui text-sm font-bold ${isToday?'text-gold':'text-navy'}">${d.split('-')[2]}</div></div><div class="p-2 space-y-1 min-h-[120px]">`;
      list.sort((a,b)=>a.appointment_hour*60+a.appointment_minute-(b.appointment_hour*60+b.appointment_minute)).forEach(a=>{
        const sc=SL[a.status]?.c||'';
        html+=`<div class="rounded-md px-2 py-1.5 cursor-pointer hover:opacity-80 transition-opacity ${sc}" title="${a.patient_name} — ${a.specialty}"><div class="font-ui text-[10px] font-bold">${fmtH(a.appointment_hour,a.appointment_minute)}</div><div class="font-body text-[10px] truncate">${a.patient_name.split(' ')[0]}</div></div>`;
      });
      if(list.length===0)html+='<div class="text-center py-4"><span class="text-[10px] text-muted-foreground/50">livre</span></div>';
      html+='</div></div>';
    });
    html+='</div>';
    grid.innerHTML=html;
  }catch{grid.innerHTML='<div class="text-center py-8 text-red-500 text-sm">Erro ao carregar agenda.</div>';}
}
$('agenda-prev')?.addEventListener('click',()=>{agendaWeekOffset--;loadAgenda();});
$('agenda-next')?.addEventListener('click',()=>{agendaWeekOffset++;loadAgenda();});
$('agenda-unit')?.addEventListener('change',()=>loadAgenda());

// ── Novo Agendamento Manual ──
$('form-novo')?.addEventListener('submit',async(e)=>{
  e.preventDefault();
  const form=e.target as HTMLFormElement;
  const fd=new FormData(form);
  const [h,m]=(fd.get('appointment_time') as string).split(':').map(Number);
  const payload={patient_name:fd.get('patient_name'),patient_phone:fd.get('patient_phone'),patient_email:fd.get('patient_email')||null,unit:fd.get('unit'),specialty:fd.get('specialty'),health_plan:fd.get('health_plan'),appointment_type:fd.get('appointment_type'),appointment_date:fd.get('appointment_date'),appointment_hour:h,appointment_minute:m,notes:fd.get('notes')||null};
  const btn=$('btn-novo') as HTMLButtonElement;
  const txt=$('btn-novo-txt'),spin=$('btn-novo-spin');
  const errDiv=$('novo-err'),okDiv=$('novo-ok');
  btn.disabled=true;txt.classList.add('hidden');spin.classList.remove('hidden');
  errDiv.classList.add('hidden');okDiv.classList.add('hidden');
  try{
    const r=await fetch('/api/agendamento/criar/',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    const d=await r.json();
    if(r.ok&&d.success){okDiv.classList.remove('hidden');form.reset();loadDash();}
    else{errDiv.querySelector('p')!.textContent=d.error||'Erro ao criar agendamento.';errDiv.classList.remove('hidden');}
  }catch{errDiv.querySelector('p')!.textContent='Erro de conexão.';errDiv.classList.remove('hidden');}
  finally{btn.disabled=false;txt.classList.remove('hidden');spin.classList.add('hidden');}
});

// ── Dashboard ──
async function loadDash(){
  try{
    const r=await fetch('/api/admin/agendamentos/?status=all&unit=all&specialty=all');
    if(r.status===401){window.location.href='/admin/login';return;}
    allData=await r.json();
    renderDash();
  }catch{console.error('Erro ao carregar dashboard');}
}

function renderDash(){
  const td=today();
  const active=allData.filter(a=>a.status!=='cancelled');
  const todayA=active.filter(a=>a.appointment_date===td);
  const confirmed=allData.filter(a=>a.status==='confirmed');
  const pending=allData.filter(a=>a.status==='pending');

  $('kpi-total').textContent=String(active.length);
  $('kpi-today').textContent=String(todayA.length);
  $('kpi-confirmed').textContent=String(confirmed.length);
  $('kpi-pending').textContent=String(pending.length);

  // Chart: by unit
  const byUnit:Record<string,number>={};
  UNITS_ARR.forEach(u=>byUnit[u.value]=0);
  active.forEach(a=>{if(byUnit[a.unit]!==undefined)byUnit[a.unit]++;});
  const maxU=Math.max(...Object.values(byUnit),1);
  const cu=$('chart-units');cu.innerHTML='';
  Object.entries(byUnit).forEach(([u,c])=>{
    const pct=Math.round(c/maxU*100);
    cu.innerHTML+=`<div class="flex items-center gap-3"><span class="font-ui text-xs text-navy w-20 truncate font-semibold">${u}</span><div class="flex-1 h-7 bg-gray-100 rounded-full overflow-hidden"><div class="h-full rounded-full transition-all duration-700" style="width:${pct}%;background:${UC[u]||'#6b7280'}"></div></div><span class="font-ui text-xs text-navy font-bold w-8 text-right">${c}</span></div>`;
  });

  // Chart: next 7 days
  const cw=$('chart-week');cw.innerHTML='';
  const WD=['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  const days:string[]=[];
  for(let i=0;i<7;i++){const d=new Date();d.setDate(d.getDate()+i);days.push(d.toISOString().split('T')[0]);}
  const byDay=days.map(d=>({d,c:active.filter(a=>a.appointment_date===d).length}));
  const maxD=Math.max(...byDay.map(x=>x.c),1);
  byDay.forEach(({d,c})=>{
    const dt=new Date(d+'T12:00:00');
    const pct=Math.round(c/maxD*100);
    const isToday=d===td;
    cw.innerHTML+=`<div class="flex items-center gap-3"><span class="font-ui text-xs w-16 ${isToday?'text-gold font-bold':'text-muted-foreground'}">${WD[dt.getDay()]} ${dt.getDate()}/${dt.getMonth()+1}</span><div class="flex-1 h-6 bg-gray-100 rounded-full overflow-hidden"><div class="h-full rounded-full transition-all duration-700 ${isToday?'bg-gold':'bg-navy/60'}" style="width:${pct}%"></div></div><span class="font-ui text-xs font-bold w-6 text-right ${isToday?'text-gold':'text-navy'}">${c}</span></div>`;
  });

  // Recent 5
  const rl=$('recent-list');rl.innerHTML='';
  const recent=allData.sort((a,b)=>b.created_at-a.created_at).slice(0,5);
  if(recent.length===0){rl.innerHTML='<p class="text-muted-foreground text-sm text-center py-4">Nenhum agendamento ainda.</p>';return;}
  recent.forEach(a=>{
    const st=SL[a.status]??{l:a.status,c:'bg-gray-100 text-gray-700'};
    rl.innerHTML+=`<div class="flex items-center justify-between py-3"><div class="flex items-center gap-3"><div class="w-9 h-9 rounded-full bg-navy/8 flex items-center justify-center font-ui text-xs font-bold text-navy">${a.patient_name.charAt(0).toUpperCase()}</div><div><div class="font-ui text-sm font-semibold text-navy">${a.patient_name}</div><div class="font-body text-xs text-muted-foreground">${fmtD(a.appointment_date)} · ${fmtH(a.appointment_hour,a.appointment_minute)} · ${a.unit}</div></div></div><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold ${st.c}">${st.l}</span></div>`;
  });
}

// ── Lista ──
let listData:Appt[]=[];
async function loadList(){
  const status=($('filter-status')as HTMLSelectElement).value;
  const unit=($('filter-unit')as HTMLSelectElement).value;
  const specialty=($('filter-specialty')as HTMLSelectElement).value;
  const date=($('filter-date')as HTMLInputElement).value;
  $('table-loading').classList.remove('hidden');$('table-container').classList.add('hidden');
  const p=new URLSearchParams({status,unit,specialty});if(date)p.set('date',date);
  try{
    const r=await fetch(`/api/admin/agendamentos/?${p}`);
    if(r.status===401){window.location.href='/admin/login';return;}
    listData=await r.json();renderList();
  }catch{alert('Erro ao carregar.');}
  $('table-loading').classList.add('hidden');$('table-container').classList.remove('hidden');
}

function renderList(){
  $('count-label').textContent=`${listData.length} agendamento${listData.length!==1?'s':''} encontrado${listData.length!==1?'s':''}`;
  const tb=$('table-body'),cv=$('cards-view'),em=$('empty-state');
  tb.innerHTML='';cv.innerHTML='';
  if(listData.length===0){em.classList.remove('hidden');return;}
  em.classList.add('hidden');
  listData.forEach(a=>{
    const st=SL[a.status]??{l:a.status,c:'bg-gray-100 text-gray-700'};
    const tr=document.createElement('tr');tr.className='hover:bg-[#f8f7f4]/60 transition-colors';
    tr.innerHTML=`
      <td class="px-4 py-3"><div class="font-semibold text-navy text-sm">${a.patient_name}</div><div class="text-xs text-muted-foreground">${a.patient_phone}</div>${a.patient_email?`<div class="text-xs text-muted-foreground">${a.patient_email}</div>`:''}</td>
      <td class="px-4 py-3"><div class="font-semibold text-sm">${fmtD(a.appointment_date)}</div><div class="text-xs text-muted-foreground">${fmtH(a.appointment_hour,a.appointment_minute)}</div></td>
      <td class="px-4 py-3 text-sm">${a.unit}</td>
      <td class="px-4 py-3 text-sm">${a.specialty}</td>
      <td class="px-4 py-3 text-sm text-muted-foreground">${a.health_plan}</td>
      <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold ${st.c}">${st.l}</span></td>
      <td class="px-4 py-3"><div class="flex items-center gap-1">
        ${a.status!=='confirmed'?`<button onclick="updSt(${a.id},'confirmed')" class="text-[10px] bg-emerald-50 text-emerald-700 border border-emerald-200 px-2 py-1 rounded-md hover:bg-emerald-100 font-bold transition-colors">Confirmar</button>`:''}
        ${a.status!=='cancelled'?`<button onclick="updSt(${a.id},'cancelled')" class="text-[10px] bg-red-50 text-red-700 border border-red-200 px-2 py-1 rounded-md hover:bg-red-100 font-bold transition-colors">Cancelar</button>`:''}
        ${a.status!=='pending'?`<button onclick="updSt(${a.id},'pending')" class="text-[10px] bg-amber-50 text-amber-700 border border-amber-200 px-2 py-1 rounded-md hover:bg-amber-100 font-bold transition-colors">Pendente</button>`:''}
      </div></td>`;
    tb.appendChild(tr);
    const card=document.createElement('div');card.className='p-4';
    card.innerHTML=`<div class="flex items-start justify-between mb-2"><div><div class="font-semibold text-navy text-sm">${a.patient_name}</div><div class="text-xs text-muted-foreground">${a.patient_phone}</div></div><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold ${st.c}">${st.l}</span></div><div class="grid grid-cols-2 gap-1 text-xs text-muted-foreground mb-3"><div><b class="text-navy">Data:</b> ${fmtD(a.appointment_date)} ${fmtH(a.appointment_hour,a.appointment_minute)}</div><div><b class="text-navy">Unidade:</b> ${a.unit}</div><div><b class="text-navy">Espec.:</b> ${a.specialty}</div><div><b class="text-navy">Plano:</b> ${a.health_plan}</div></div><div class="flex gap-1.5">${a.status!=='confirmed'?`<button onclick="updSt(${a.id},'confirmed')" class="text-[10px] bg-emerald-50 text-emerald-700 border border-emerald-200 px-2.5 py-1.5 rounded-md hover:bg-emerald-100 font-bold">Confirmar</button>`:''}${a.status!=='cancelled'?`<button onclick="updSt(${a.id},'cancelled')" class="text-[10px] bg-red-50 text-red-700 border border-red-200 px-2.5 py-1.5 rounded-md hover:bg-red-100 font-bold">Cancelar</button>`:''}${a.status!=='pending'?`<button onclick="updSt(${a.id},'pending')" class="text-[10px] bg-amber-50 text-amber-700 border border-amber-200 px-2.5 py-1.5 rounded-md hover:bg-amber-100 font-bold">Pendente</button>`:''}</div>`;
    cv.appendChild(card);
  });
}

async function updSt(id:number,status:string){
  try{
    const r=await fetch('/api/admin/status/',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,status})});
    if(r.status===401){window.location.href='/admin/login';return;}
    const d=await r.json();if(d.success){loadList();loadDash();}else alert('Erro ao atualizar.');
  }catch{alert('Erro de conexão.');}
}

// ── CSV ──
function exportCSV(){
  if(listData.length===0){alert('Nenhum dado.');return;}
  const h=['ID','Nome','Telefone','E-mail','Unidade','Especialidade','Plano','Data','Hora','Tipo','Status','Obs'];
  const rows=listData.map(a=>[a.id,a.patient_name,a.patient_phone,a.patient_email??'',a.unit,a.specialty,a.health_plan,fmtD(a.appointment_date),fmtH(a.appointment_hour,a.appointment_minute),TL[a.appointment_type]??a.appointment_type,SL[a.status]?.l??a.status,a.notes??''].map(v=>`"${String(v).replace(/"/g,'""')}"`).join(','));
  const csv='\uFEFF'+[h.join(','),...rows].join('\n');
  const b=new Blob([csv],{type:'text/csv;charset=utf-8;'});
  const u=URL.createObjectURL(b);const a=document.createElement('a');a.href=u;a.download=`agendamentos-${today()}.csv`;a.click();URL.revokeObjectURL(u);
}

// ── Bloqueios ──
async function loadBlocks(){
  try{
    const r=await fetch('/api/admin/bloqueios/');
    if(r.status===401){window.location.href='/admin/login';return;}
    const data=await r.json() as Block[];
    const bl=$('blocked-list');bl.innerHTML='';
    if(data.length===0){bl.innerHTML='<p class="text-muted-foreground text-sm text-center py-4">Nenhum dia bloqueado.</p>';return;}
    data.forEach(b=>{
      bl.innerHTML+=`<div class="flex items-center justify-between bg-red-50/50 border border-red-200/50 rounded-lg px-4 py-3"><div><div class="font-ui text-sm font-semibold text-navy">${b.unit} — ${fmtDLong(b.date)}</div>${b.reason?`<div class="font-body text-xs text-muted-foreground">${b.reason}</div>`:''}</div><button onclick="rmBlock(${b.id})" class="text-xs text-red-600 hover:text-red-800 font-bold transition-colors">Remover</button></div>`;
    });
  }catch{console.error('Erro ao carregar bloqueios');}
}

$('btn-block')?.addEventListener('click',async()=>{
  const unit=($('block-unit')as HTMLSelectElement).value;
  const date=($('block-date')as HTMLInputElement).value;
  const reason=($('block-reason')as HTMLInputElement).value;
  if(!date){alert('Selecione uma data.');return;}
  try{
    const r=await fetch('/api/admin/bloqueios/',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({unit,date,reason:reason||null})});
    if(r.status===401){window.location.href='/admin/login';return;}
    const d=await r.json();
    if(d.success){($('block-date')as HTMLInputElement).value='';($('block-reason')as HTMLInputElement).value='';loadBlocks();}
    else alert(d.error||'Erro ao bloquear.');
  }catch{alert('Erro de conexão.');}
});

async function rmBlock(id:number){
  if(!confirm('Remover bloqueio?'))return;
  try{
    const r=await fetch('/api/admin/bloqueios/',{method:'DELETE',headers:{'Content-Type':'application/json'},body:JSON.stringify({id})});
    if(r.status===401){window.location.href='/admin/login';return;}
    loadBlocks();
  }catch{alert('Erro de conexão.');}
}

// ── Logout ──
$('btn-logout').addEventListener('click',async()=>{await fetch('/api/admin/logout/',{method:'POST'});window.location.href='/admin/login';});
$('btn-filter')?.addEventListener('click',loadList);
$('btn-clear')?.addEventListener('click',()=>{($('filter-status')as HTMLSelectElement).value='all';($('filter-unit')as HTMLSelectElement).value='all';($('filter-specialty')as HTMLSelectElement).value='all';($('filter-date')as HTMLInputElement).value='';loadList();});
$('btn-export')?.addEventListener('click',exportCSV);

// Expor globais
(window as any).updSt=updSt;
(window as any).rmBlock=rmBlock;

// ── Leads E-books ──
const EBOOK_LABELS:Record<string,string>={catarata:'Catarata',ceratocone:'Ceratocone',glaucoma:'Glaucoma',retina:'Retina',estrabismo:'Estrabismo'};
let leadsPage=1;

async function loadLeads(page=1){
  leadsPage=page;
  const slug=($('leads-filter-slug') as HTMLSelectElement).value;
  const params=new URLSearchParams({page:String(page)});
  if(slug)params.set('slug',slug);
  const tbody=$('leads-tbody');
  const countLbl=$('leads-count-label');
  if(tbody)tbody.innerHTML='<tr><td colspan="6" class="text-center py-8 text-muted-foreground text-sm">Carregando...</td></tr>';
  try{
    const r=await fetch(`/api/admin/ebook-leads?${params}`,{credentials:'include'});
    if(!r.ok){if(tbody)tbody.innerHTML='<tr><td colspan="6" class="text-center py-8 text-red-500 text-sm">Erro ao carregar leads.</td></tr>';return;}
    const d=await r.json() as {leads:any[];total:number;page:number;pages:number;stats:any[]};
    // KPIs
    const totalLeads=d.total;
    const emailsSent=d.leads.reduce((s:number,l:any)=>s+(l.email_sent?1:0),0);
    const topEbook=d.stats[0];
    const kpiTotal=$('leads-kpi-total');if(kpiTotal)kpiTotal.textContent=String(totalLeads);
    const kpiEmails=$('leads-kpi-emails');if(kpiEmails)kpiEmails.textContent=String(d.stats.reduce((s:number,x:any)=>s+(x.emails_enviados||0),0));
    const kpiEbooks=$('leads-kpi-ebooks');if(kpiEbooks)kpiEbooks.textContent=String(d.stats.length);
    const kpiTop=$('leads-kpi-top');if(kpiTop)kpiTop.textContent=topEbook?`${EBOOK_LABELS[topEbook.ebook_slug]||topEbook.ebook_slug} (${topEbook.total})`:'—';
    if(countLbl)countLbl.textContent=`${totalLeads} lead${totalLeads!==1?'s':''} encontrado${totalLeads!==1?'s':''}`;
    // Tabela
    if(tbody){
      if(d.leads.length===0){
        tbody.innerHTML='<tr><td colspan="6" class="text-center py-10 text-muted-foreground text-sm">Nenhum lead encontrado.</td></tr>';
      }else{
        tbody.innerHTML=d.leads.map((l:any)=>{
          const dt=new Date(l.created_at);
          const dtStr=`${String(dt.getDate()).padStart(2,'0')}/${String(dt.getMonth()+1).padStart(2,'0')}/${dt.getFullYear()} ${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')}`;
          const ebookLabel=EBOOK_LABELS[l.ebook_slug]||l.ebook_slug;
          const emailBadge=l.email_sent
            ?'<span class="inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 font-ui text-[10px] font-bold px-2 py-0.5 rounded-full">✓ Enviado</span>'
            :'<span class="inline-flex items-center gap-1 bg-amber-100 text-amber-700 font-ui text-[10px] font-bold px-2 py-0.5 rounded-full">Pendente</span>';
          return`<tr class="border-b border-border/30 hover:bg-navy/2 transition-colors">
            <td class="px-4 py-3 font-body text-sm text-navy font-medium">${l.name}</td>
            <td class="px-4 py-3"><a href="mailto:${l.email}" class="font-body text-sm text-navy hover:text-gold transition-colors">${l.email}</a></td>
            <td class="px-4 py-3"><a href="https://wa.me/55${l.phone.replace(/\D/g,'')}" target="_blank" class="font-body text-sm text-navy hover:text-gold transition-colors">${l.phone}</a></td>
            <td class="px-4 py-3"><span class="inline-flex items-center gap-1 bg-navy/8 text-navy font-ui text-[10px] font-bold px-2 py-1 rounded-full">${ebookLabel}</span></td>
            <td class="px-4 py-3">${emailBadge}</td>
            <td class="px-4 py-3 font-body text-xs text-muted-foreground">${dtStr}</td>
          </tr>`;
        }).join('');
      }
    }
    // Paginação
    const pag=$('leads-pagination');
    const prev=$('leads-prev') as HTMLButtonElement;
    const next=$('leads-next') as HTMLButtonElement;
    const info=$('leads-page-info');
    if(pag)pag.classList.toggle('hidden',d.pages<=1);
    if(prev)prev.disabled=d.page<=1;
    if(next)next.disabled=d.page>=d.pages;
    if(info)info.textContent=`Página ${d.page} de ${d.pages}`;
    // Stats grid
    const statsGrid=$('leads-stats-grid');
    if(statsGrid){
      if(d.stats.length===0){
        statsGrid.innerHTML='<p class="text-muted-foreground text-sm col-span-5 text-center py-4">Sem dados ainda.</p>';
      }else{
        statsGrid.innerHTML=d.stats.map((s:any)=>{
          const pct=totalLeads>0?Math.round((s.total/totalLeads)*100):0;
          return`<div class="bg-navy/4 rounded-xl p-4 text-center">
            <div class="font-display text-2xl text-navy font-bold">${s.total}</div>
            <div class="font-ui text-xs text-muted-foreground mt-1">${EBOOK_LABELS[s.ebook_slug]||s.ebook_slug}</div>
            <div class="mt-2 bg-border/40 rounded-full h-1.5"><div class="bg-navy rounded-full h-1.5" style="width:${pct}%"></div></div>
            <div class="font-ui text-[10px] text-muted-foreground mt-1">${pct}%</div>
          </div>`;
        }).join('');
      }
    }
  }catch(e){
    if(tbody)tbody.innerHTML='<tr><td colspan="6" class="text-center py-8 text-red-500 text-sm">Erro de conexão.</td></tr>';
  }
}

$('btn-leads-buscar')?.addEventListener('click',()=>loadLeads(1));
$('leads-filter-slug')?.addEventListener('change',()=>loadLeads(1));
$('leads-prev')?.addEventListener('click',()=>loadLeads(leadsPage-1));
$('leads-next')?.addEventListener('click',()=>loadLeads(leadsPage+1));
$('btn-leads-export')?.addEventListener('click',()=>{
  const slug=($('leads-filter-slug') as HTMLSelectElement).value;
  const params=new URLSearchParams({export:'csv'});
  if(slug)params.set('slug',slug);
  window.open(`/api/admin/ebook-leads?${params}`,'_blank');
});

// Init
loadDash();
</script>
