          <!-- Dias bloqueados -->
          <div class="bg-white rounded-xl border border-border/40 shadow-sm p-6">
            <h3 class="font-ui text-sm font-bold text-navy mb-4">Dias Bloqueados</h3>
            <div id="blocked-list" class="space-y-2 max-h-80 overflow-y-auto">
              <p class="text-muted-foreground text-sm text-center py-4">Carregando...</p>
            </div>
          </div>
