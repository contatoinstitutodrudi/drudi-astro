---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { verifyAdminToken, getAdminTokenFromRequest } from '../../lib/auth';
import { UNITS, SPECIALTIES } from '../../lib/constants';

// Verificar autenticação
const env = (Astro.locals as { runtime: { env: Env } }).runtime.env;
const token = getAdminTokenFromRequest(Astro.request);
if (!token || !(await verifyAdminToken(env.ADMIN_JWT_SECRET, token))) {
  return Astro.redirect('/admin/login');
}
---

<BaseLayout
  title="Painel Admin — Agendamentos | Drudi e Almeida"
  description="Painel administrativo de agendamentos."
  canonicalPath="/admin/agendamentos"
>
  <div class="min-h-screen bg-gray-50">
    <!-- Header Admin -->
    <header class="bg-navy text-cream shadow-md">
      <div class="container py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/images/logo-horizontal.png" alt="Drudi e Almeida" class="h-8" onerror="this.style.display='none'" />
          <span class="font-ui text-sm font-semibold text-cream/80 hidden sm:block">Painel Admin</span>
        </div>
        <div class="flex items-center gap-3">
          <a href="/" class="font-ui text-xs text-cream/70 hover:text-cream transition-colors hidden sm:block">← Ver site</a>
          <button id="btn-logout" class="font-ui text-xs bg-cream/10 hover:bg-cream/20 text-cream px-3 py-1.5 rounded-lg transition-colors">
            Sair
          </button>
        </div>
      </div>
    </header>

    <main class="container py-8">
      <!-- Título + Exportar -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <div>
          <h1 class="font-display text-2xl text-navy">Agendamentos</h1>
          <p class="font-body text-sm text-muted-foreground mt-1" id="count-label">Carregando...</p>
        </div>
        <button id="btn-export"
          class="inline-flex items-center gap-2 border border-border bg-white text-foreground font-ui text-sm font-semibold px-4 py-2 rounded-lg hover:bg-muted/50 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Exportar CSV
        </button>
      </div>

      <!-- Filtros -->
      <div class="bg-white rounded-xl border border-border/60 shadow-sm p-4 mb-6">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div>
            <label class="font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1.5 block">Status</label>
            <select id="filter-status" class="w-full border border-border rounded-lg px-2.5 py-2 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30">
              <option value="all">Todos</option>
              <option value="pending">Pendente</option>
              <option value="confirmed">Confirmado</option>
              <option value="cancelled">Cancelado</option>
            </select>
          </div>
          <div>
            <label class="font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1.5 block">Unidade</label>
            <select id="filter-unit" class="w-full border border-border rounded-lg px-2.5 py-2 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30">
              <option value="all">Todas</option>
              {UNITS.map(u => <option value={u.value}>{u.value}</option>)}
            </select>
          </div>
          <div>
            <label class="font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1.5 block">Especialidade</label>
            <select id="filter-specialty" class="w-full border border-border rounded-lg px-2.5 py-2 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30">
              <option value="all">Todas</option>
              {SPECIALTIES.map(s => <option value={s.value}>{s.label}</option>)}
            </select>
          </div>
          <div>
            <label class="font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1.5 block">Data</label>
            <input id="filter-date" type="date"
              class="w-full border border-border rounded-lg px-2.5 py-2 text-sm bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-navy/30" />
          </div>
        </div>
        <div class="flex gap-2 mt-3">
          <button id="btn-filter" class="bg-navy text-cream font-ui text-sm font-semibold px-4 py-2 rounded-lg hover:bg-navy/90 transition-colors">
            Filtrar
          </button>
          <button id="btn-clear" class="border border-border text-foreground font-ui text-sm px-4 py-2 rounded-lg hover:bg-muted/50 transition-colors">
            Limpar
          </button>
        </div>
      </div>

      <!-- Loading -->
      <div id="table-loading" class="text-center py-12">
        <svg class="w-8 h-8 animate-spin text-navy mx-auto mb-3" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
        </svg>
        <p class="text-muted-foreground text-sm">Carregando agendamentos...</p>
      </div>

      <!-- Tabela -->
      <div id="table-container" class="hidden">
        <div class="bg-white rounded-xl border border-border/60 shadow-sm overflow-hidden">
          <!-- Mobile: cards -->
          <div id="cards-view" class="block sm:hidden divide-y divide-border/50"></div>
          <!-- Desktop: table -->
          <div class="hidden sm:block overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50 border-b border-border/60">
                  <th class="text-left font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide px-4 py-3">Paciente</th>
                  <th class="text-left font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide px-4 py-3">Data / Hora</th>
                  <th class="text-left font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide px-4 py-3">Unidade</th>
                  <th class="text-left font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide px-4 py-3">Especialidade</th>
                  <th class="text-left font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide px-4 py-3">Plano</th>
                  <th class="text-left font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide px-4 py-3">Status</th>
                  <th class="text-left font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide px-4 py-3">Ações</th>
                </tr>
              </thead>
              <tbody id="table-body" class="divide-y divide-border/40"></tbody>
            </table>
          </div>
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="hidden text-center py-16">
          <svg class="w-12 h-12 text-muted-foreground/40 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <p class="text-muted-foreground font-medium">Nenhum agendamento encontrado</p>
          <p class="text-muted-foreground text-xs mt-1">Tente ajustar os filtros</p>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
// ============================================================
// Painel Admin — Vanilla JS
// ============================================================
type Appointment = {
  id: number;
  patient_name: string;
  patient_phone: string;
  patient_email: string | null;
  unit: string;
  specialty: string;
  health_plan: string;
  appointment_date: string;
  appointment_hour: number;
  appointment_minute: number;
  appointment_type: string;
  status: 'pending' | 'confirmed' | 'cancelled';
  notes: string | null;
  created_at: number;
};

let currentData: Appointment[] = [];

const STATUS_LABELS: Record<string, { label: string; cls: string }> = {
  pending: { label: 'Pendente', cls: 'bg-amber-100 text-amber-800' },
  confirmed: { label: 'Confirmado', cls: 'bg-green-100 text-green-800' },
  cancelled: { label: 'Cancelado', cls: 'bg-red-100 text-red-700' },
};

function formatDate(d: string) {
  const [y, m, day] = d.split('-');
  return `${day}/${m}/${y}`;
}
function formatHour(h: number, m: number) {
  return `${String(h).padStart(2, '0')}h${m > 0 ? String(m).padStart(2, '0') : ''}`;
}

async function loadData() {
  const status = (document.getElementById('filter-status') as HTMLSelectElement).value;
  const unit = (document.getElementById('filter-unit') as HTMLSelectElement).value;
  const specialty = (document.getElementById('filter-specialty') as HTMLSelectElement).value;
  const date = (document.getElementById('filter-date') as HTMLInputElement).value;

  document.getElementById('table-loading')!.classList.remove('hidden');
  document.getElementById('table-container')!.classList.add('hidden');

  const params = new URLSearchParams({ status, unit, specialty });
  if (date) params.set('date', date);

  try {
    const res = await fetch(`/api/admin/agendamentos?${params}`);
    if (res.status === 401) { window.location.href = '/admin/login'; return; }
    const data = await res.json() as Appointment[];
    currentData = data;
    renderTable(data);
  } catch {
    alert('Erro ao carregar agendamentos.');
  }

  document.getElementById('table-loading')!.classList.add('hidden');
  document.getElementById('table-container')!.classList.remove('hidden');
}

function renderTable(data: Appointment[]) {
  const countLabel = document.getElementById('count-label')!;
  countLabel.textContent = `${data.length} agendamento${data.length !== 1 ? 's' : ''} encontrado${data.length !== 1 ? 's' : ''}`;

  const tbody = document.getElementById('table-body')!;
  const cards = document.getElementById('cards-view')!;
  const empty = document.getElementById('empty-state')!;

  tbody.innerHTML = '';
  cards.innerHTML = '';

  if (data.length === 0) {
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');

  data.forEach(appt => {
    const st = STATUS_LABELS[appt.status] ?? { label: appt.status, cls: 'bg-gray-100 text-gray-700' };

    // Desktop row
    const tr = document.createElement('tr');
    tr.className = 'hover:bg-gray-50/60 transition-colors';
    tr.innerHTML = `
      <td class="px-4 py-3">
        <div class="font-medium text-navy text-sm">${appt.patient_name}</div>
        <div class="text-xs text-muted-foreground">${appt.patient_phone}</div>
        ${appt.patient_email ? `<div class="text-xs text-muted-foreground">${appt.patient_email}</div>` : ''}
      </td>
      <td class="px-4 py-3">
        <div class="font-medium text-sm">${formatDate(appt.appointment_date)}</div>
        <div class="text-xs text-muted-foreground">${formatHour(appt.appointment_hour, appt.appointment_minute)}</div>
      </td>
      <td class="px-4 py-3 text-sm">${appt.unit}</td>
      <td class="px-4 py-3 text-sm">${appt.specialty}</td>
      <td class="px-4 py-3 text-sm text-muted-foreground">${appt.health_plan}</td>
      <td class="px-4 py-3">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${st.cls}">${st.label}</span>
      </td>
      <td class="px-4 py-3">
        <div class="flex items-center gap-1.5">
          ${appt.status !== 'confirmed' ? `<button onclick="updateStatus(${appt.id},'confirmed')" class="text-xs bg-green-50 text-green-700 border border-green-200 px-2 py-1 rounded-md hover:bg-green-100 transition-colors font-medium">Confirmar</button>` : ''}
          ${appt.status !== 'cancelled' ? `<button onclick="updateStatus(${appt.id},'cancelled')" class="text-xs bg-red-50 text-red-700 border border-red-200 px-2 py-1 rounded-md hover:bg-red-100 transition-colors font-medium">Cancelar</button>` : ''}
          ${appt.status !== 'pending' ? `<button onclick="updateStatus(${appt.id},'pending')" class="text-xs bg-amber-50 text-amber-700 border border-amber-200 px-2 py-1 rounded-md hover:bg-amber-100 transition-colors font-medium">Pendente</button>` : ''}
        </div>
      </td>
    `;
    tbody.appendChild(tr);

    // Mobile card
    const card = document.createElement('div');
    card.className = 'p-4';
    card.innerHTML = `
      <div class="flex items-start justify-between mb-2">
        <div>
          <div class="font-medium text-navy text-sm">${appt.patient_name}</div>
          <div class="text-xs text-muted-foreground">${appt.patient_phone}</div>
        </div>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${st.cls}">${st.label}</span>
      </div>
      <div class="grid grid-cols-2 gap-1 text-xs text-muted-foreground mb-3">
        <div><span class="font-medium text-foreground">Data:</span> ${formatDate(appt.appointment_date)} ${formatHour(appt.appointment_hour, appt.appointment_minute)}</div>
        <div><span class="font-medium text-foreground">Unidade:</span> ${appt.unit}</div>
        <div><span class="font-medium text-foreground">Especialidade:</span> ${appt.specialty}</div>
        <div><span class="font-medium text-foreground">Plano:</span> ${appt.health_plan}</div>
      </div>
      <div class="flex gap-1.5">
        ${appt.status !== 'confirmed' ? `<button onclick="updateStatus(${appt.id},'confirmed')" class="text-xs bg-green-50 text-green-700 border border-green-200 px-2.5 py-1.5 rounded-md hover:bg-green-100 transition-colors font-medium">Confirmar</button>` : ''}
        ${appt.status !== 'cancelled' ? `<button onclick="updateStatus(${appt.id},'cancelled')" class="text-xs bg-red-50 text-red-700 border border-red-200 px-2.5 py-1.5 rounded-md hover:bg-red-100 transition-colors font-medium">Cancelar</button>` : ''}
        ${appt.status !== 'pending' ? `<button onclick="updateStatus(${appt.id},'pending')" class="text-xs bg-amber-50 text-amber-700 border border-amber-200 px-2.5 py-1.5 rounded-md hover:bg-amber-100 transition-colors font-medium">Pendente</button>` : ''}
      </div>
    `;
    cards.appendChild(card);
  });
}

async function updateStatus(id: number, status: string) {
  try {
    const res = await fetch('/api/admin/status', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, status }),
    });
    if (res.status === 401) { window.location.href = '/admin/login'; return; }
    const data = await res.json() as { success?: boolean };
    if (data.success) loadData();
    else alert('Erro ao atualizar status.');
  } catch {
    alert('Erro de conexão.');
  }
}

// Exportar CSV
function exportCSV() {
  if (currentData.length === 0) { alert('Nenhum dado para exportar.'); return; }

  const headers = ['ID', 'Nome', 'Telefone', 'E-mail', 'Unidade', 'Especialidade', 'Plano', 'Data', 'Hora', 'Tipo', 'Status', 'Observações'];
  const typeLabel: Record<string, string> = { primeira_vez: 'Primeira Consulta', retorno: 'Retorno', exame: 'Exame/Procedimento' };
  const statusLabel: Record<string, string> = { pending: 'Pendente', confirmed: 'Confirmado', cancelled: 'Cancelado' };

  const rows = currentData.map(a => [
    a.id,
    a.patient_name,
    a.patient_phone,
    a.patient_email ?? '',
    a.unit,
    a.specialty,
    a.health_plan,
    formatDate(a.appointment_date),
    formatHour(a.appointment_hour, a.appointment_minute),
    typeLabel[a.appointment_type] ?? a.appointment_type,
    statusLabel[a.status] ?? a.status,
    a.notes ?? '',
  ].map(v => `"${String(v).replace(/"/g, '""')}"`).join(','));

  const csv = '\uFEFF' + [headers.join(','), ...rows].join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `agendamentos-${new Date().toISOString().slice(0, 10)}.csv`;
  a.click();
  URL.revokeObjectURL(url);
}

// Logout
document.getElementById('btn-logout')!.addEventListener('click', async () => {
  await fetch('/api/admin/logout', { method: 'POST' });
  window.location.href = '/admin/login';
});

document.getElementById('btn-filter')!.addEventListener('click', loadData);
document.getElementById('btn-clear')!.addEventListener('click', () => {
  (document.getElementById('filter-status') as HTMLSelectElement).value = 'all';
  (document.getElementById('filter-unit') as HTMLSelectElement).value = 'all';
  (document.getElementById('filter-specialty') as HTMLSelectElement).value = 'all';
  (document.getElementById('filter-date') as HTMLInputElement).value = '';
  loadData();
});
document.getElementById('btn-export')!.addEventListener('click', exportCSV);

// Expor updateStatus globalmente (usado nos botões inline)
(window as unknown as Record<string, unknown>).updateStatus = updateStatus;

// Carregar ao iniciar
loadData();
</script>
