        <!-- Links para os institutos -->
        <div class="mt-10 pt-8 border-t border-cream/15">
          <p class="font-ui text-xs font-semibold tracking-wider uppercase text-cream/40 mb-4">Nossos Institutos</p>
          <div class="flex flex-wrap gap-2">
            {[
              { name: "Instituto da Catarata", href: "/instituto/catarata" },
              { name: "Instituto do Ceratocone", href: "/instituto/ceratocone" },
              { name: "Instituto do Glaucoma", href: "/instituto/glaucoma" },
              { name: "Instituto da Retina", href: "/instituto/retina" },
              { name: "Instituto de Estrabismo", href: "/instituto/estrabismo" },
            ].map(inst => (
              <a href={inst.href} class="font-ui text-xs font-semibold px-4 py-2 rounded-full border border-cream/15 text-cream/55 hover:text-gold hover:border-gold/40 transition-colors">{inst.name}</a>
