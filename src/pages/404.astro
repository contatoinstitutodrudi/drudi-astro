---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página não encontrada | Drudi e Almeida"
  description="A página que você procura não foi encontrada. Acesse o site da Drudi e Almeida Oftalmologia para encontrar o que precisa."
  canonicalPath="/404"
>
  <style>
    .eye-svg {
      animation: blink 3s ease-in-out infinite;
    }
    @keyframes blink {
      0%, 90%, 100% { transform: scaleY(1); }
      95% { transform: scaleY(0.1); }
    }
    .pupil {
      animation: look 4s ease-in-out infinite;
    }
    @keyframes look {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(6px); }
      75% { transform: translateX(-6px); }
    }
  </style>

  <section class="min-h-[80vh] flex items-center justify-center bg-gradient-to-b from-cream to-white py-20">
    <div class="container text-center max-w-2xl">

      <!-- Olho animado -->
      <div class="flex justify-center mb-8">
        <svg class="eye-svg w-32 h-20" viewBox="0 0 120 80" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Pálpebra superior e inferior -->
          <path d="M10 40 Q60 5 110 40 Q60 75 10 40Z" fill="#f0ede6" stroke="#1a2b4a" stroke-width="2.5"/>
          <!-- Íris -->
          <circle cx="60" cy="40" r="18" fill="#1a2b4a"/>
          <!-- Pupila com animação -->
          <circle class="pupil" cx="60" cy="40" r="10" fill="#0a1525"/>
          <!-- Reflexo -->
          <circle cx="66" cy="34" r="4" fill="white" opacity="0.8"/>
          <circle cx="55" cy="44" r="2" fill="white" opacity="0.5"/>
          <!-- Detalhes da íris -->
          <circle cx="60" cy="40" r="18" fill="none" stroke="#c9a961" stroke-width="1" opacity="0.4"/>
        </svg>
      </div>

      <!-- Código 404 -->
      <div class="font-display text-8xl md:text-9xl font-bold text-navy/10 leading-none mb-2 select-none">
        404
      </div>

      <div class="-mt-4 mb-6">
        <span class="inline-block bg-gold/15 border border-gold/30 text-gold font-ui text-xs font-bold tracking-widest uppercase px-4 py-1.5 rounded-full">
          Página não encontrada
        </span>
      </div>

      <h1 class="font-display text-3xl md:text-4xl text-navy mb-4 leading-tight">
        Parece que esta página<br class="hidden md:block" /> saiu do nosso campo de visão
      </h1>

      <p class="font-body text-base text-muted-foreground leading-relaxed mb-10 max-w-lg mx-auto">
        A página que você procura pode ter sido movida, renomeada ou simplesmente não existe. 
        Mas não se preocupe — nossa equipe está aqui para ajudar você a encontrar o que precisa.
      </p>

      <!-- Ações -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-navy text-cream font-ui text-sm font-bold px-7 py-3.5 rounded-md hover:bg-navy/90 transition-colors"
        >
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Ir para a Home
        </a>
        <a
          href="https://wa.me/5511916544653?text=Olá! Preciso de ajuda para encontrar uma informação no site."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white font-ui text-sm font-bold px-6 py-3.5 rounded-lg hover:bg-[#1ebe5d] transition-all shadow-[0_4px_14px_rgba(37,211,102,0.35)]"
        >
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Falar pelo WhatsApp
        </a>
      </div>

      <!-- Links rápidos -->
      <div class="border-t border-border/40 pt-8">
        <p class="font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-4">Páginas populares</p>
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { href: "/instituto/catarata", label: "Instituto da Catarata" },
            { href: "/instituto/ceratocone", label: "Instituto do Ceratocone" },
            { href: "/instituto/glaucoma", label: "Instituto do Glaucoma" },
            { href: "/instituto/retina", label: "Instituto da Retina" },
            { href: "/convenios", label: "Convênios" },
            { href: "/contato", label: "Contato" },
            { href: "/blog", label: "Blog" },
          ].map(link => (
            <a
              href={link.href}
              class="font-ui text-xs font-semibold px-4 py-2 border border-border/60 rounded-full text-navy hover:border-gold hover:text-gold transition-all"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
