<script>
  // =============================================
  // Interatividade dos cards de unidades
  // =============================================
  const unitCards = document.querySelectorAll<HTMLButtonElement>('.unit-card');
  const mapFrame = document.getElementById('map-frame') as HTMLIFrameElement;

  unitCards.forEach((card) => {
    card.addEventListener('click', () => {
      const idx = parseInt(card.dataset.index || '0');
      const mapQuery = card.dataset.mapQuery || '';

      // Atualizar estilos de todos os cards
      unitCards.forEach((c, j) => {
        const nameEl = c.querySelector('.unit-name') as HTMLElement;
        const addrEl = c.querySelector('.unit-address') as HTMLElement;
        const iconWrap = c.querySelector('.w-10') as HTMLElement;

        if (j === idx) {
          // Card ativo: fundo navy, textos claros
          c.classList.add('active-unit', 'bg-navy', 'border-navy', 'shadow-lg');
          c.classList.remove('bg-white', 'border-border/60');
          if (nameEl) { nameEl.classList.remove('text-navy'); nameEl.classList.add('text-cream'); }
          if (addrEl) { addrEl.classList.remove('text-muted-foreground'); addrEl.classList.add('text-cream/70'); }
          if (iconWrap) { iconWrap.classList.remove('bg-gold/10'); iconWrap.classList.add('bg-gold/20'); }
          // Botão "Ver no Mapa" do card ativo
          const mapBtn = c.querySelector('a') as HTMLElement;
          if (mapBtn) {
            mapBtn.classList.remove('bg-navy/5', 'text-navy', 'hover:bg-navy/10');
            mapBtn.classList.add('bg-gold/20', 'text-gold', 'hover:bg-gold/30');
          }
        } else {
          // Card inativo: fundo branco, textos escuros
          c.classList.remove('active-unit', 'bg-navy', 'border-navy', 'shadow-lg');
          c.classList.add('bg-white', 'border-border/60');
          if (nameEl) { nameEl.classList.add('text-navy'); nameEl.classList.remove('text-cream'); }
          if (addrEl) { addrEl.classList.add('text-muted-foreground'); addrEl.classList.remove('text-cream/70'); }
          if (iconWrap) { iconWrap.classList.add('bg-gold/10'); iconWrap.classList.remove('bg-gold/20'); }
          // Botão "Ver no Mapa" do card inativo
          const mapBtn = c.querySelector('a') as HTMLElement;
          if (mapBtn) {
            mapBtn.classList.add('bg-navy/5', 'text-navy', 'hover:bg-navy/10');
            mapBtn.classList.remove('bg-gold/20', 'text-gold', 'hover:bg-gold/30');
          }
        }
      });

      // Atualizar o mapa com a URL correta
      if (mapFrame && mapQuery) {
        mapFrame.src = `https://maps.google.com/maps?q=${mapQuery}&output=embed&hl=pt-BR&z=16`;
      }
    });
  });

  // =============================================
  // Formulário de contato via WhatsApp
  // =============================================
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const nome = data.get('nome') || '';
    const telefone = data.get('telefone') || '';
    const email = data.get('email') || '';
    const assunto = data.get('assunto') || 'Não especificado';
    const unidade = data.get('unidade') || 'Não especificada';
    const mensagem = data.get('mensagem') || '';
    const msg = `Olá! Meu nome é ${nome}.\n\nAssunto: ${assunto}\nUnidade preferida: ${unidade}\n\n${mensagem}\n\nContato: ${email} | ${telefone}`;
    window.open(`https://wa.me/5511916544653?text=${encodeURIComponent(msg.toString())}`, '_blank');
  });
</script>
