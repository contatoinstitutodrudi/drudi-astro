---
import BaseLayout from '../layouts/BaseLayout.astro';

const WHATSAPP_LINK = "https://wa.me/5511916544653?text=Olá! Gostaria de agendar uma consulta.";
const PHONE = "(11) 5430-2421";
const PHONE_WA = "(11) 91654-4653";

const unidades = [
  {
    name: "Unidade Santana",
    address: "Rua Dr. César, 130",
    neighborhood: "Santana",
    city: "São Paulo - SP",
    mapQuery: "Drudi+e+Almeida+Rua+Dr+Cesar+130+Santana+São+Paulo+SP",
    mapEmbed: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3657.0!2d-46.6297!3d-23.4958!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94cef5b5b5b5b5b5%3A0x0!2sDrudi+e+Almeida+Santana!5e0!3m2!1spt-BR!2sbr!4v1700000000000",
    phone: "(11) 5026-8521",
  },
  {
    name: "Unidade Tatuapé",
    address: "Rua Tuiuti, 2429",
    neighborhood: "Tatuapé",
    city: "São Paulo - SP",
    mapQuery: "Drudi+e+Almeida+Rua+Tuiuti+2429+Tatuapé+São+Paulo+SP",
    mapEmbed: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3658.0!2d-46.5568!3d-23.5401!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce5b5b5b5b5b5b%3A0x0!2sDrudi+e+Almeida+Tatuapé!5e0!3m2!1spt-BR!2sbr!4v1700000000001",
    phone: "(11) 5026-8521",
  },
  {
    name: "Unidade Lapa",
    address: "Rua Barão de Jundiaí, 221",
    neighborhood: "Lapa",
    city: "São Paulo - SP",
    mapQuery: "Drudi+e+Almeida+Rua+Barão+de+Jundiaí+221+Lapa+São+Paulo+SP",
    mapEmbed: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3658.0!2d-46.7012!3d-23.5201!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce5b5b5b5b5b5c%3A0x0!2sDrudi+e+Almeida+Lapa!5e0!3m2!1spt-BR!2sbr!4v1700000000002",
    phone: "(11) 5026-8521",
  },
  {
    name: "Unidade São Miguel",
    address: "Rua Bernardo Marcondes, 108",
    neighborhood: "São Miguel Paulista",
    city: "São Paulo - SP",
    mapQuery: "Drudi+e+Almeida+Rua+Bernardo+Marcondes+108+São+Miguel+Paulista+São+Paulo+SP",
    mapEmbed: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3658.0!2d-46.4401!3d-23.4901!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce5b5b5b5b5b5d%3A0x0!2sDrudi+e+Almeida+São+Miguel!5e0!3m2!1spt-BR!2sbr!4v1700000000003",
    phone: "(11) 5026-8521",
  },
  {
    name: "Unidade Guarulhos",
    address: "Rua Sete de Setembro, 375",
    neighborhood: "Centro",
    city: "Guarulhos - SP",
    mapQuery: "Drudi+e+Almeida+Rua+Sete+de+Setembro+375+Guarulhos+SP",
    mapEmbed: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3658.0!2d-46.5301!3d-23.4601!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce5b5b5b5b5b5e%3A0x0!2sDrudi+e+Almeida+Guarulhos!5e0!3m2!1spt-BR!2sbr!4v1700000000004",
    phone: "(11) 5026-8521",
  },
];
---

<BaseLayout
  title="Contato — Fale Conosco | Drudi e Almeida"
  description="Entre em contato com a Drudi e Almeida Oftalmologia. Telefone: (11) 5430-2421. WhatsApp: (11) 91654-4653. 5 unidades em SP e Guarulhos."
>

  <!-- ========== HERO ========== -->
  <!-- Imagem: biblioteca/escritório com livros e janela — igual ao site publicado -->
  <section class="relative min-h-[65vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/images/contato-hero-bg.webp')"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy/85 via-navy/60 to-transparent"></div>

    <div class="relative container py-20">
      <div class="max-w-2xl">
        <nav class="flex items-center gap-2 font-ui text-xs text-cream/60 mb-6">
          <a href="/" class="hover:text-cream transition-colors">Home</a>
          <span>/</span>
          <span class="text-cream">Contato</span>
        </nav>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-cream leading-[1.1] mb-5">
          <span class="text-gold italic">Contato</span> e Unidades em São Paulo
        </h1>
        <p class="font-body text-lg text-cream/80 leading-relaxed mb-8">
          Estamos prontos para atender você. Agende sua consulta ou tire suas dúvidas em qualquer uma das nossas 5 unidades.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-gold text-navy font-ui text-sm font-bold px-6 py-3 rounded-md hover:bg-gold-light transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Falar pelo WhatsApp
          </a>
          <a href={`tel:+55${PHONE.replace(/\D/g, "")}`}
            class="inline-flex items-center gap-2 border border-cream/30 text-cream font-ui text-sm font-semibold px-6 py-3 rounded-md hover:bg-cream/10 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Ligar Agora
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- ========== CANAIS DE CONTATO ========== -->
  <section class="py-10 bg-white border-b border-border/40">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <!-- WhatsApp -->
        <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-4 p-5 rounded-xl border border-border/40 hover:border-emerald-400 hover:shadow-md transition-all group">
          <div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-emerald-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <p class="font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide">WhatsApp</p>
            <p class="font-display text-base text-navy group-hover:text-emerald-600 transition-colors">{PHONE_WA}</p>
          </div>
        </a>

        <!-- Telefone -->
        <a href={`tel:+55${PHONE.replace(/\D/g, "")}`}
          class="flex items-center gap-4 p-5 rounded-xl border border-border/40 hover:border-navy/40 hover:shadow-md transition-all group">
          <div class="w-12 h-12 rounded-xl bg-navy/10 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <p class="font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide">Telefone</p>
            <p class="font-display text-base text-navy group-hover:text-gold transition-colors">{PHONE}</p>
          </div>
        </a>

        <!-- E-mail -->
        <a href="mailto:contato@drudiealmeida.com"
          class="flex items-center gap-4 p-5 rounded-xl border border-border/40 hover:border-gold/40 hover:shadow-md transition-all group">
          <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <p class="font-ui text-xs font-semibold text-muted-foreground uppercase tracking-wide">E-mail</p>
            <p class="font-display text-base text-navy group-hover:text-gold transition-colors">contato@drudiealmeida.com</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== UNIDADES + MAPA ========== -->
  <section class="section-padding bg-white">
    <div class="container">
      <div class="text-center mb-10">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold">Nossas Unidades</span>
        <h2 class="font-display text-3xl md:text-4xl text-navy mt-3 mb-3">5 Unidades para Atendê-lo</h2>
        <p class="font-body text-base text-muted-foreground max-w-2xl mx-auto leading-relaxed">
          Escolha a unidade mais próxima de você. Todas contam com a mesma estrutura de excelência e corpo clínico especializado.
        </p>
        <div class="gold-line max-w-[80px] mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
        <!-- Cards das unidades -->
        <div class="space-y-3" id="unit-list">
          {unidades.map((unit, i) => (
            <button
              class={`unit-card w-full text-left p-5 rounded-xl border transition-all duration-300 ${i === 0 ? 'active-unit bg-navy border-navy shadow-lg' : 'bg-white border-border/60 hover:border-gold/30 hover:shadow-md'}`}
              data-index={i}
              data-map-embed={unit.mapEmbed}
              data-map-query={unit.mapQuery}
            >
              <div class="flex items-start justify-between gap-3">
                <div class="flex items-start gap-3">
                  <div class={`w-10 h-10 rounded-lg flex items-center justify-center shrink-0 ${i === 0 ? 'bg-gold/20' : 'bg-gold/10'}`}>
                    <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  </div>
                  <div>
                    <p class={`unit-name font-display text-base font-semibold ${i === 0 ? 'text-cream' : 'text-navy'}`}>{unit.name}</p>
                    <p class={`unit-address font-body text-sm mt-0.5 ${i === 0 ? 'text-cream/70' : 'text-muted-foreground'}`}>{unit.address}</p>
                    <p class="font-ui text-xs mt-0.5 text-gold">{unit.neighborhood} · {unit.city}</p>
                  </div>
                </div>
                <a
                  href={`https://www.google.com/maps/search/?api=1&query=${unit.mapQuery}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`shrink-0 inline-flex items-center gap-1 font-ui text-xs font-semibold px-3 py-1.5 rounded-lg transition-colors ${i === 0 ? 'bg-gold/20 text-gold hover:bg-gold/30' : 'bg-navy/5 text-navy hover:bg-navy/10'}`}
                  onclick="event.stopPropagation()"
                >
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  Ver no Mapa
                </a>
              </div>
            </button>
          ))}
        </div>

        <!-- Mapa Google Maps embed funcional -->
        <div class="sticky top-24">
          <div class="rounded-2xl overflow-hidden shadow-xl border border-border/40 h-[480px] bg-slate-100">
            <iframe
              id="map-frame"
              src={`https://maps.google.com/maps?q=${unidades[0].mapQuery}&output=embed&hl=pt-BR&z=16`}
              class="w-full h-full border-0"
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
              title="Mapa das unidades Drudi e Almeida"
            ></iframe>
          </div>
          <div class="mt-4 p-4 bg-slate-50 rounded-xl border border-border/40">
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span class="font-ui text-xs font-semibold text-navy">Horário de Funcionamento</span>
            </div>
            <p class="font-body text-sm text-muted-foreground">Segunda a Sexta: 8h às 18h</p>
            <p class="font-body text-sm text-muted-foreground">Sábado: 8h às 12h</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FORMULÁRIO DE CONTATO ========== -->
  <!-- Fundo off-white quase branco, como solicitado -->
  <section class="section-padding" style="background-color: #f9f8f6;">
    <div class="container">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-10">
          <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold">Fale Conosco</span>
          <h2 class="font-display text-3xl md:text-4xl text-navy mt-3">Envie uma Mensagem</h2>
          <p class="font-body text-base text-muted-foreground max-w-xl mx-auto mt-4 leading-relaxed">
            Preencha o formulário e entraremos em contato pelo WhatsApp.
          </p>
          <div class="gold-line max-w-[60px] mx-auto mt-5"></div>
        </div>

        <form id="contact-form" class="space-y-5 bg-white rounded-2xl shadow-sm border border-border/30 p-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="font-ui text-xs font-semibold text-navy/70 uppercase tracking-wide mb-1.5 block">Nome *</label>
              <input type="text" name="nome" required placeholder="Seu nome completo"
                class="w-full border border-border/60 rounded-lg px-4 py-3 font-body text-sm text-navy bg-white focus:ring-2 focus:ring-gold/30 focus:border-gold outline-none transition-all" />
            </div>
            <div>
              <label class="font-ui text-xs font-semibold text-navy/70 uppercase tracking-wide mb-1.5 block">Telefone *</label>
              <input type="tel" name="telefone" required placeholder="(11) 99999-9999"
                class="w-full border border-border/60 rounded-lg px-4 py-3 font-body text-sm text-navy bg-white focus:ring-2 focus:ring-gold/30 focus:border-gold outline-none transition-all" />
            </div>
          </div>

          <div>
            <label class="font-ui text-xs font-semibold text-navy/70 uppercase tracking-wide mb-1.5 block">E-mail</label>
            <input type="email" name="email" placeholder="seu@email.com"
              class="w-full border border-border/60 rounded-lg px-4 py-3 font-body text-sm text-navy bg-white focus:ring-2 focus:ring-gold/30 focus:border-gold outline-none transition-all" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="font-ui text-xs font-semibold text-navy/70 uppercase tracking-wide mb-1.5 block">Assunto</label>
              <select name="assunto" class="w-full border border-border/60 rounded-lg px-4 py-3 font-body text-sm text-navy bg-white focus:ring-2 focus:ring-gold/30 focus:border-gold outline-none transition-all">
                <option value="">Selecione</option>
                <option>Agendamento de Consulta</option>
                <option>Dúvida sobre Tratamento</option>
                <option>Informações sobre Convênios</option>
                <option>Resultado de Exame</option>
                <option>Outros</option>
              </select>
            </div>
            <div>
              <label class="font-ui text-xs font-semibold text-navy/70 uppercase tracking-wide mb-1.5 block">Unidade</label>
              <select name="unidade" class="w-full border border-border/60 rounded-lg px-4 py-3 font-body text-sm text-navy bg-white focus:ring-2 focus:ring-gold/30 focus:border-gold outline-none transition-all">
                <option value="">Selecione</option>
                {unidades.map(u => (
                  <option>{u.name}</option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label class="font-ui text-xs font-semibold text-navy/70 uppercase tracking-wide mb-1.5 block">Mensagem</label>
            <textarea name="mensagem" rows={4} placeholder="Descreva sua dúvida ou necessidade..."
              class="w-full border border-border/60 rounded-lg px-4 py-3 font-body text-sm text-navy bg-white focus:ring-2 focus:ring-gold/30 focus:border-gold outline-none transition-all resize-none"></textarea>
          </div>

          <button type="submit"
            class="w-full inline-flex items-center justify-center gap-2 bg-navy text-cream font-ui text-sm font-bold px-6 py-4 rounded-lg hover:bg-navy/90 transition-all shadow-lg">
