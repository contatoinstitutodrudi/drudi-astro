<script>
  // Filtro por categoria
  const catBtns = document.querySelectorAll('.cat-btn');
  const equipCards = document.querySelectorAll('.equip-card');
  const equipEmpty = document.getElementById('equip-empty');
  const searchInput = document.getElementById('equip-search') as HTMLInputElement;

  let activeCategory = '';
  let searchTerm = '';

  function filterEquipamentos() {
    let visible = 0;
    equipCards.forEach((card) => {
      const el = card as HTMLElement;
      const cat = el.dataset.cat || '';
      const nome = el.dataset.nome || '';
      const modelo = el.dataset.modelo || '';
      const desc = el.dataset.desc || '';

      const matchesCat = activeCategory === '' || cat === activeCategory;
      const matchesSearch = searchTerm === '' ||
        nome.includes(searchTerm) ||
        modelo.includes(searchTerm) ||
        desc.includes(searchTerm);

      if (matchesCat && matchesSearch) {
        el.style.display = '';
        visible++;
      } else {
        el.style.display = 'none';
      }
    });

    if (equipEmpty) {
      equipEmpty.classList.toggle('hidden', visible > 0);
    }
  }

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      catBtns.forEach(b => {
        b.classList.remove('bg-navy', 'text-cream', 'border-navy');
        b.classList.add('border-border/60', 'text-navy');
      });
      btn.classList.add('bg-navy', 'text-cream', 'border-navy');
      btn.classList.remove('border-border/60');
      activeCategory = (btn as HTMLElement).dataset.cat || '';
      filterEquipamentos();
    });
  });

  searchInput?.addEventListener('input', () => {
    searchTerm = searchInput.value.toLowerCase().trim();
    filterEquipamentos();
  });
</script>
