---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';

const token = Astro.url.searchParams.get('token') ?? '';
---

<BaseLayout
  title="Cancelar Consulta | Drudi e Almeida"
  description="Cancelamento de consulta na Drudi e Almeida Oftalmologia."
  canonicalPath="/cancelar"
>
  <section class="min-h-[60vh] flex items-center section-padding">
    <div class="container">
      <div class="max-w-md mx-auto text-center">
        <div id="loading" class="py-12">
          <svg class="w-10 h-10 animate-spin text-navy mx-auto mb-4" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
          <p class="text-muted-foreground">Processando cancelamento...</p>
        </div>

        <div id="success" class="hidden py-8">
          <div class="w-16 h-16 mx-auto rounded-full bg-emerald-100 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h1 class="font-display text-2xl text-navy mb-2">Consulta Cancelada</h1>
          <p class="text-muted-foreground mb-6">Seu cancelamento foi processado com sucesso.</p>
          <div class="bg-[#f8f7f4] border border-border/50 rounded-xl p-5 text-left mb-6 space-y-2">
            <p class="font-body text-sm text-muted-foreground"><span class="font-semibold text-navy">Paciente:</span> <span id="cancel-name"></span></p>
            <p class="font-body text-sm text-muted-foreground"><span class="font-semibold text-navy">Data:</span> <span id="cancel-date"></span></p>
            <p class="font-body text-sm text-muted-foreground"><span class="font-semibold text-navy">Unidade:</span> <span id="cancel-unit"></span></p>
          </div>
          <p class="font-body text-sm text-muted-foreground mb-6">Se desejar, você pode agendar uma nova consulta a qualquer momento.</p>
          <a href="/agendar" class="inline-flex items-center gap-2 bg-navy text-cream font-ui text-sm font-semibold px-6 py-3 rounded-lg hover:bg-navy/90 transition-colors">
            Agendar nova consulta
          </a>
        </div>

        <div id="already" class="hidden py-12">
          <div class="w-16 h-16 mx-auto rounded-full bg-amber-100 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h2 class="font-display text-2xl text-navy mb-3">Já Cancelado</h2>
          <p class="text-muted-foreground mb-6">Esta consulta já foi cancelada anteriormente.</p>
          <a href="/agendar" class="inline-flex items-center gap-2 bg-navy text-cream font-ui text-sm font-semibold px-6 py-3 rounded-lg hover:bg-navy/90 transition-colors">
            Agendar nova consulta
          </a>
        </div>

        <div id="error" class="hidden py-12">
          <div class="w-16 h-16 mx-auto rounded-full bg-red-100 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </div>
          <h2 class="font-display text-2xl text-navy mb-3">Link Inválido</h2>
          <p class="text-muted-foreground mb-6">O link de cancelamento é inválido ou expirou.</p>
          <a href="/" class="inline-flex items-center gap-2 border border-border text-foreground font-ui text-sm font-semibold px-6 py-3 rounded-lg hover:bg-muted/50 transition-colors">
            Voltar ao início
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ token }}>
(async function () {
  const show = (id) => document.getElementById(id).classList.remove('hidden');
  const hide = (id) => document.getElementById(id).classList.add('hidden');

  if (!token) {
    hide('loading');
    show('error');
    return;
  }

  try {
    const res = await fetch('/api/agendamento/cancelar/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token }),
    });
    const data = await res.json();
    hide('loading');
    if (res.status === 409) {
      if (data.error && data.error.includes('já foi cancelado')) show('already');
      else show('error');
    } else if (data.success) {
      // Preencher detalhes na tela de sucesso
      const appt = data.appointment;
      const nameEl = document.getElementById('cancel-name');
      const dateEl = document.getElementById('cancel-date');
      const unitEl = document.getElementById('cancel-unit');
      if (nameEl && appt) nameEl.textContent = appt.patient_name;
      if (dateEl && appt) {
        const [y,m,d] = appt.appointment_date.split('-');
        const months = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
        const h = String(appt.appointment_hour).padStart(2,'0');
        const mi = appt.appointment_minute > 0 ? String(appt.appointment_minute).padStart(2,'0') : '';
        dateEl.textContent = `${d} de ${months[+m-1]} de ${y} às ${h}h${mi}`;
      }
      if (unitEl && appt) unitEl.textContent = appt.unit;
      show('success');
    } else {
      show('error');
    }
  } catch {
    hide('loading');
    show('error');
  }
})();
</script>
