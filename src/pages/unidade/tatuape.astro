---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocalBusinessSchema from "../../components/LocalBusinessSchema.astro";

const unidade = {
  slug: "tatuape",
  nome: "Tatuapé",
  titulo: "Clínica Oftalmológica em Tatuapé",
  subtitulo: "Nossa unidade no Tatuapé oferece atendimento especializado com infraestrutura completa e equipe altamente qualificada. Localizada em uma das regiões mais acessíveis da zona leste, próxima ao metrô.",
  rua: "Rua Tuiuti, 2429",
  bairro: "Tatuapé",
  cidade: "São Paulo — SP",
  cep: "03307-005",
  telefone: "(11) 5430-2421",
  whatsapp: "5511916544653",
  horario: { semana: "08:00 — 18:00", sabado: "08:00 — 12:00" },
  referencias: [
    "Próximo ao Metrô Carrão",
    "Shopping Metrô Tatuapé",
    "Fácil acesso pela Radial Leste"
  ],
  mapQuery: "Drudi+e+Almeida+Rua+Tuiuti+2429+Tatuapé+São+Paulo+SP",
  heroImg: "/images/sala_espera_sofa_bege_v3_5717e0c0.webp",
  outrasUnidades: [
    { nome: "Guarulhos", rua: "Rua Sete de Setembro, 375, Centro", slug: "guarulhos" },
    { nome: "Lapa", rua: "Rua Barão de Jundiaí, 221, Lapa", slug: "lapa" },
    { nome: "Santana", rua: "Rua Dr. César, 130, Santana", slug: "santana" },
    { nome: "São Miguel Paulista", rua: "Rua Bernardo Marcondes, 108, São Miguel Paulista", slug: "sao-miguel" },
  ]
};
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<BaseLayout
  title="Oftalmologista em Tatuapé — Drudi e Almeida"
  description="Clínica oftalmológica no Tatuapé, São Paulo. Rua Tuiuti, 2429. Consultas, exames e cirurgias com os melhores especialistas. Agende: (11) 5430-2421."
  canonicalPath="/unidade/tatuape"
>
  <LocalBusinessSchema
    slot="head-schema"
    nome="Tatuapé"
    url="/unidade/tatuape"
    image="/images/sala_espera_sofa_bege_v3_5717e0c0.webp"
    rua="Rua Tuiuti, 2429"
    bairro="Tatuapé"
    cidade="São Paulo"
    cep="03307-002"
    lat={-23.5423}
    lng={-46.5726}
    telefone="(11) 5430-2421"
    whatsapp="5511916544653"
  />
  <!-- ========== HERO ========== -->
  <section class="relative min-h-[55vh] flex items-center overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${unidade.heroImg}')`}
    ></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy/85 via-navy/60 to-navy/30"></div>

    <div class="relative container pb-16 pt-28">

      <div class="max-w-2xl">
                <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Unidades", href: "/contato" }, { label: "Tatuapé" }]} />

        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-cream leading-[1.1] mb-4">
          Clínica Oftalmológica em<br />
          <em class="text-gold italic">{unidade.nome}</em>
        </h1>
        <p class="font-body text-lg text-cream/80 leading-relaxed mb-8 max-w-xl">
          {unidade.subtitulo}
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href={`https://wa.me/${unidade.whatsapp}?text=Olá! Gostaria de agendar uma consulta na unidade ${unidade.nome}.`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-gold text-navy font-ui text-sm font-bold px-7 py-3.5 rounded-md hover:bg-gold-light transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Agendar pelo WhatsApp
          </a>
          <a
            href={`tel:${unidade.telefone.replace(/\D/g,'')}`}
            class="inline-flex items-center gap-2 border border-cream/30 text-cream font-ui text-sm font-semibold px-7 py-3.5 rounded-md hover:bg-cream/10 transition-colors"
          >
            Ligar: {unidade.telefone}
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- ========== COMO CHEGAR + MAPA ========== -->
  <section class="section-padding bg-background">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold">INFORMAÇÕES</span>
          <h2 class="font-display text-3xl text-navy mt-3 mb-8">Como chegar</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-navy/8 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h3 class="font-ui text-sm font-semibold text-navy mb-1">Endereço</h3>
                <p class="font-body text-sm text-muted-foreground">{unidade.rua}<br />{unidade.bairro}, {unidade.cidade}<br />CEP: {unidade.cep}</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-navy/8 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <h3 class="font-ui text-sm font-semibold text-navy mb-1">Horário de Funcionamento</h3>
                <div class="space-y-1 font-body text-sm text-muted-foreground">
                  <div class="flex justify-between gap-8"><span>Segunda a Sexta</span><span class="font-semibold text-navy">{unidade.horario.semana}</span></div>
                  <div class="flex justify-between gap-8"><span>Sábado</span><span class="font-semibold text-navy">{unidade.horario.sabado}</span></div>
                  <div class="flex justify-between gap-8"><span>Domingo e Feriados</span><span class="font-semibold text-navy">Fechado</span></div>
                </div>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-navy/8 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/></svg>
              </div>
              <div>
                <h3 class="font-ui text-sm font-semibold text-navy mb-1">Telefones</h3>
                <div class="space-y-1 font-body text-sm text-muted-foreground">
                  <p><a href={`tel:${unidade.telefone.replace(/\D/g,'')}`} class="hover:text-gold transition-colors">{unidade.telefone}</a> (fixo)</p>
                  <p><a href={`https://wa.me/${unidade.whatsapp}`} target="_blank" rel="noopener noreferrer" class="hover:text-gold transition-colors">(11) 91654-4653</a> (WhatsApp)</p>
                </div>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-navy/8 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
              </div>
              <div>
                <h3 class="font-ui text-sm font-semibold text-navy mb-1">Referências</h3>
                <ul class="space-y-1 font-body text-sm text-muted-foreground">
                  {unidade.referencias.map(ref => <li>• {ref}</li>)}
                </ul>
              </div>
            </div>
            <a href={`https://www.google.com/maps/search/?api=1&query=${unidade.mapQuery}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-navy text-cream font-ui text-sm font-semibold px-5 py-2.5 rounded-md hover:bg-navy/90 transition-colors mt-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
              Abrir no Google Maps
            </a>
          </div>
        </div>
        <div class="rounded-xl overflow-hidden shadow-lg border border-border/50 h-[450px]">
          <iframe src={`https://maps.google.com/maps?q=${unidade.mapQuery}&output=embed&hl=pt-BR&z=16`} width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title={`Mapa da unidade ${unidade.nome}`}></iframe>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== TRANSPORTE ========== -->
  <section id="transporte-section" class="section-padding bg-cream/30">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold">COMO CHEGAR DE TRANSPORTE</span>
          <h2 class="font-display text-3xl text-navy mt-3 mb-8">Acesso à unidade</h2>
          <div class="space-y-5">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-lg bg-navy/8 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                </svg>
              </div>
              <div>
                <h4 class="font-ui text-sm font-semibold text-navy">Metrô</h4>
                <p class="font-body text-sm text-muted-foreground">Metrô Tatuapé (Linha 3-Vermelha) — 10 min a pé</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-lg bg-navy/8 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h8M8 11h8M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z"/>
                </svg>
              </div>
              <div>
                <h4 class="font-ui text-sm font-semibold text-navy">Ônibus</h4>
                <p class="font-body text-sm text-muted-foreground">Linhas 2756-10, 2756-21 — parada próxima</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-lg bg-navy/8 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2 2h10l2-2z"/>
                </svg>
              </div>
              <div>
                <h4 class="font-ui text-sm font-semibold text-navy">Carro</h4>
                <p class="font-body text-sm text-muted-foreground">Estacionamento rotativo disponível na Rua Tuiuti</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl border border-border/50 p-8">
          <h3 class="font-display text-xl text-navy mb-4">Sobre esta unidade</h3>
          <p class="font-body text-base text-muted-foreground leading-relaxed">
            A unidade do Tatuapé serve a zona leste de São Paulo com atendimento oftalmológico completo. Localizada na Rua Tuiuti, próxima ao Metrô Tatuapé e ao Shopping Anália Franco, é referência em oftalmologia para os bairros do Tatuapé, Carrão, Vila Formosa e região.
          </p>
          <div class="mt-6 pt-6 border-t border-border/50">
            <p class="font-ui text-xs font-semibold text-navy mb-3">EQUIPAMENTOS DISPONÍVEIS</p>
            <ul class="space-y-2 font-body text-sm text-muted-foreground">
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-gold flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Tomógrafo de Coerência Óptica (OCT)</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-gold flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Topógrafo de Córnea</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-gold flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Campo Visual Computadorizado</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-gold flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Retinógrafo Digital</li>
              <li class="flex items-center gap-2"><svg class="w-4 h-4 text-gold flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Biometria Óptica (IOL Master)</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- ========== ESPECIALIDADES ========== -->
  <section class="section-padding bg-cream/30">
    <div class="container">
      <div class="text-center mb-12">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold">ESPECIALIDADES</span>
        <h2 class="font-display text-3xl text-navy mt-3 mb-4">Atendemos todas as especialidades em {unidade.nome}</h2>
        <p class="font-body text-base text-muted-foreground max-w-2xl mx-auto">Nossa unidade em {unidade.nome} conta com equipe especializada e equipamentos de ponta para todas as áreas da oftalmologia.</p>
        <div class="gold-line max-w-[80px] mx-auto mt-6"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { nome: "Catarata", desc: "Cirurgia de catarata com lentes premium", href: "/instituto/catarata", logo: "/images/logo-catarata-128_4016b3c8.webp" },
          { nome: "Ceratocone", desc: "Crosslinking e lentes especiais", href: "/instituto/ceratocone", logo: "/images/logo-ceratocone-128_5f37b031.webp" },
          { nome: "Glaucoma", desc: "Diagnóstico precoce e tratamento", href: "/instituto/glaucoma", logo: "/images/logo-glaucoma-128_c3ccf9c1.webp" },
          { nome: "Retina", desc: "Vitrectomia e injeções intravítreas", href: "/instituto/retina", logo: "/images/logo-retina-128_88ef0fac.webp" },
          { nome: "Estrabismo", desc: "Cirurgia para crianças e adultos", href: "/instituto/estrabismo", logo: "/images/logo-estrabismo-128_b8ca4997.webp" },
        ].map(esp => (
          <a href={esp.href} class="group flex items-center gap-4 bg-white rounded-xl border border-border/50 p-5 hover:shadow-md hover:border-gold/30 transition-all duration-300">
            <img src={esp.logo} alt={esp.nome} class="w-12 h-12 object-contain flex-shrink-0" />
            <div>
              <h3 class="font-ui text-sm font-bold text-navy group-hover:text-gold transition-colors">{esp.nome}</h3>
              <p class="font-body text-xs text-muted-foreground mt-0.5">{esp.desc}</p>
            </div>
            <svg class="w-4 h-4 text-muted-foreground group-hover:text-gold ml-auto flex-shrink-0 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CONVÊNIOS ========== -->
  <section class="section-padding bg-background">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-display text-2xl text-navy mb-4">Convênios aceitos nesta unidade</h2>
        <p class="font-body text-base text-muted-foreground mb-6">Atendemos os principais convênios e planos de saúde. Também realizamos atendimento particular.</p>
        <div class="flex flex-wrap justify-center gap-4 mb-8">
          {[
            { nome: "Prevent Senior", logo: "/images/prevent-senior-resized_d5845445.webp" },
            { nome: "Bradesco Saúde", logo: "/images/bradesco-resized_aae8535a.webp" },
            { nome: "Mediservice", logo: "/images/tech-mediservice-rPLmRznR_d6cff695.webp" },
            { nome: "Instituto Pró-PM", logo: "/images/logo-propm_0b938536.webp" },
            { nome: "Amil", logo: "/images/amil-resized_65f90601.webp" },
            { nome: "Unimed Seguros", logo: "/images/unimed-resized_954ff1a4.webp" },
            { nome: "Ameplam", logo: "/images/ameplam-resized_f387254f.webp" },
          ].map(conv => (
            <div class="bg-white border border-border/50 rounded-lg p-3 flex items-center justify-center w-28 h-16">
              <img src={conv.logo} alt={conv.nome} class="max-h-10 max-w-full object-contain" />
            </div>
          ))}
        </div>
        <a href="/convenios" class="inline-flex items-center gap-2 text-navy font-ui text-sm font-semibold hover:text-gold transition-colors">
          Ver todos os convênios aceitos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== OUTRAS UNIDADES ========== -->
  <section class="section-padding bg-cream/30">
    <div class="container">
      <div class="text-center mb-10">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold">MAIS PERTO DE VOCÊ</span>
        <h2 class="font-display text-3xl text-navy mt-3">Conheça nossas outras unidades</h2>
        <div class="gold-line max-w-[80px] mx-auto mt-6"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {unidade.outrasUnidades.map(u => (
          <a href={`/unidade/${u.slug}`} class="group bg-white rounded-xl border border-border/50 p-5 hover:shadow-md hover:border-gold/30 transition-all duration-300">
            <div class="w-10 h-10 rounded-lg bg-navy/8 flex items-center justify-center mb-3">
