              Receber Preço
            </a>
            <a href="/agendar"
              class="w-full inline-flex flex-col items-center justify-center gap-0.5 bg-white text-navy font-ui font-bold px-6 py-3 rounded-lg border-2 border-navy hover:bg-navy hover:text-white transition-all shadow-sm">
              <span class="flex items-center gap-2 text-sm leading-tight">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Agendar Online
              </span>
              <span class="text-[11px] font-medium leading-tight" style="color:#c9a961">Consulta em até 48h</span>
