---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSchema from '../../components/FAQSchema.astro';

const WHATSAPP_LINK = "https://wa.me/5511916544653?text=Olá! Gostaria de receber informações sobre o tratamento de glaucoma.";
const PHONE = "(11) 91654-4653";

const unidades = [
  { id: "guarulhos-centro", name: "Guarulhos Centro", address: "Guarulhos - SP" },
  { id: "lapa", name: "Lapa", address: "São Paulo - SP" },
  { id: "santana", name: "Santana", address: "São Paulo - SP" },
  { id: "sao-miguel", name: "São Miguel", address: "São Paulo - SP" },
  { id: "tatuape", name: "Tatuapé", address: "São Paulo - SP" },
];

const tiposGlaucoma = [
  { title: "Glaucoma Primário de Ângulo Aberto (GPAA)", desc: "O tipo mais comum (90% dos casos). A drenagem do humor aquoso torna-se ineficiente, causando aumento gradual da pressão intraocular. Progressão lenta e indolor — o paciente geralmente não percebe até estágios avançados.", badge: "Mais Comum", badgeColor: "bg-emerald-100 text-emerald-800" },
  { title: "Glaucoma de Ângulo Fechado", desc: "Emergência médica. A íris bloqueia subitamente a drenagem do humor aquoso, causando aumento rápido da pressão. Sintomas: dor ocular severa, vermelhidão, visão turva, halos ao redor de luzes, náusea e vômito.", badge: "Emergência", badgeColor: "bg-red-100 text-red-800" },
  { title: "Glaucoma de Tensão Normal", desc: "O dano ao nervo óptico ocorre mesmo com pressão intraocular dentro da faixa normal (< 21 mmHg). Frequentemente associado a condições vasculares como enxaqueca, síndrome de Raynaud e apneia do sono.", badge: "Especial", badgeColor: "bg-blue-100 text-blue-800" },
  { title: "Glaucoma Congênito / Infantil", desc: "Presente ao nascimento ou nos primeiros anos de vida. Causado por desenvolvimento anormal do sistema de drenagem ocular. Sinais: olhos grandes (buftalmo), lacrimejamento excessivo, fotofobia e opacidade corneana.", badge: "Pediátrico", badgeColor: "bg-violet-100 text-violet-800" },
];

const sintomas = [
  { num: 1, title: "Perda Gradual da Visão Periférica", desc: "O glaucoma ataca primeiro a visão lateral (periférica). O paciente começa a perder a capacidade de enxergar objetos ao lado sem virar a cabeça. Essa perda é tão gradual que muitos só percebem quando já é significativa." },
  { num: 2, title: "Visão em Túnel", desc: "Em estágios avançados, o campo visual se estreita progressivamente, como se o paciente olhasse através de um tubo. A visão central pode estar preservada, mas tudo ao redor desaparece. Atividades como dirigir e caminhar tornam-se perigosas." },
  { num: 3, title: "Dor Ocular e Vermelhidão (Ângulo Fechado)", desc: "No glaucoma de ângulo fechado agudo, a pressão sobe rapidamente causando dor intensa no olho, vermelhidão, visão embaçada e halos coloridos ao redor de luzes. Pode ser acompanhado de náusea e vômito. É uma emergência médica." },
  { num: 4, title: "Dificuldade de Adaptação ao Escuro", desc: "Pacientes com glaucoma podem notar dificuldade para se adaptar a ambientes com pouca iluminação. A transição de ambientes claros para escuros torna-se mais lenta, e a visão noturna fica comprometida." },
];

const exames = [
  { title: "Tonometria de Goldmann", desc: "Padrão-ouro para medir a pressão intraocular (PIO). O tonômetro de aplanação de Goldmann mede a força necessária para aplanar uma área da córnea. Valores normais: 10-21 mmHg. Valores elevados indicam risco de glaucoma." },
  { title: "Campo Visual Computadorizado (Humphrey)", desc: "Exame fundamental que mapeia a sensibilidade de toda a visão periférica e central. Detecta áreas de perda visual (escotomas) que o paciente ainda não percebe. Essencial para diagnóstico e acompanhamento da progressão." },
  { title: "OCT do Nervo Óptico", desc: "A Tomografia de Coerência Óptica (OCT) mede a espessura da camada de fibras nervosas da retina ao redor do disco óptico. Detecta dano estrutural antes mesmo da perda funcional no campo visual — diagnóstico ultra-precoce." },
  { title: "Gonioscopia", desc: "Exame que avalia o ângulo da câmara anterior do olho — a região onde o humor aquoso é drenado. Fundamental para classificar o glaucoma como de ângulo aberto ou fechado e definir a estratégia de tratamento." },
  { title: "Fundoscopia / Retinografia", desc: "Avaliação direta do nervo óptico para verificar a relação escavação/disco (C/D ratio). Uma escavação aumentada sugere dano glaucomatoso. A retinografia documenta fotograficamente o nervo para comparação ao longo do tempo." },
  { title: "Paquimetria Corneana", desc: "Mede a espessura da córnea. Córneas mais finas podem subestimar a PIO real, enquanto córneas mais espessas podem superestimá-la. Fator de correção essencial para a interpretação correta da tonometria." },
];

const fatoresRisco = [
  { factor: "Idade acima de 40 anos", detail: "O risco aumenta significativamente após os 40 e dobra a cada década" },
  { factor: "Histórico familiar", detail: "Parentes de 1º grau com glaucoma aumentam o risco em 4-9 vezes" },
  { factor: "Pressão intraocular elevada", detail: "Principal fator de risco modificável — quanto maior, maior o risco" },
  { factor: "Descendência africana", detail: "Risco 6-8x maior de desenvolver glaucoma e 15x maior de cegueira" },
  { factor: "Miopia elevada", detail: "Olhos míopes têm nervo óptico mais vulnerável ao dano glaucomatoso" },
  { factor: "Córneas mais finas", detail: "Espessura corneana < 555 μm é fator de risco independente" },
  { factor: "Diabetes e hipertensão", detail: "Doenças vasculares comprometem a irrigação do nervo óptico" },
  { factor: "Uso de corticosteroides", detail: "Uso prolongado de corticoides (colírios, pomadas, sistêmicos) pode elevar a PIO" },
];

const colirios = [
  { title: "Análogos de Prostaglandina", exemplos: "Latanoprost, Bimatoprost, Travoprost", desc: "Aumentam a drenagem do humor aquoso pela via uveoescleral. Uso 1x/dia à noite.", reducao: "25-33%" },
  { title: "Betabloqueadores", exemplos: "Timolol, Betaxolol", desc: "Reduzem a produção de humor aquoso pelo corpo ciliar. Uso 2x/dia.", reducao: "20-25%" },
  { title: "Inibidores da Anidrase Carbônica", exemplos: "Dorzolamida, Brinzolamida", desc: "Reduzem a produção de humor aquoso. Disponíveis em colírio e comprimido.", reducao: "15-20%" },
  { title: "Alfa-2 Agonistas", exemplos: "Brimonidina, Apraclonidina", desc: "Reduzem a produção e aumentam a drenagem do humor aquoso.", reducao: "20-25%" },
  { title: "Inibidores de Rho-Kinase", exemplos: "Netarsudil", desc: "Nova classe que atua diretamente na malha trabecular, melhorando a drenagem convencional.", reducao: "15-20%" },
];

const procedimentosLaser = [
  { title: "Trabeculoplastia Seletiva a Laser (SLT)", desc: "Procedimento ambulatorial que estimula o sistema de drenagem natural do olho (malha trabecular) sem destruir tecido. Pode ser repetido. Eficaz como tratamento inicial ou complementar aos colírios.", tags: ["Reduz PIO em 20-30%", "Efeito dura 3-5 anos", "Pode ser repetido"] },
  { title: "Iridotomia Periférica a Laser (YAG)", desc: "Cria uma pequena abertura na íris para permitir a passagem do humor aquoso da câmara posterior para a anterior. Tratamento definitivo para o glaucoma de ângulo fechado e profilático para olhos em risco.", tags: ["Procedimento de 5 minutos", "Ambulatorial", "Prevenção de crises agudas"] },
  { title: "Ciclofotocoagulação", desc: "Laser aplicado no corpo ciliar para reduzir a produção de humor aquoso. Reservado para casos refratários que não responderam a outros tratamentos. Pode ser transescleral ou endoscópica.", tags: ["Para casos avançados", "Reduz produção de humor aquoso"] },
];

const cirurgias = [
  { badge: "Convencional", title: "Trabeculectomia", desc: "Padrão-ouro cirúrgico. Cria uma fístula controlada que permite a drenagem do humor aquoso para um espaço sob a conjuntiva (bolha filtrante). Reduz significativamente a PIO.", tags: ["Taxa de sucesso: 70-90%", "Redução de PIO: 30-50%"] },
  { badge: "Implante", title: "Implante de Válvula de Drenagem", desc: "Dispositivos como a válvula de Ahmed ou Baerveldt são implantados para criar uma via alternativa de drenagem do humor aquoso. Indicados quando a trabeculectomia falha ou não é possível.", tags: ["Para casos refratários", "Controle de longo prazo"] },
  { badge: "Minimamente Invasiva", title: "MIGS — Cirurgia Minimamente Invasiva", desc: "Nova geração de procedimentos com menor trauma cirúrgico: iStent, Xen Gel Stent, Hydrus Microstent. Perfil de segurança mais favorável, recuperação mais rápida e podem ser combinados com cirurgia de catarata.", tags: ["Recuperação rápida", "Menor risco", "Pode combinar com catarata"] },
  { badge: "Não-Penetrante", title: "Esclerectomia Profunda / Canaloplastia", desc: "Técnicas não-penetrantes que melhoram a drenagem sem criar uma abertura completa na parede do olho. Menor risco de complicações como hipotonia. A canaloplastia dilata o canal de Schlemm com um microcateter.", tags: ["Não-penetrante", "Menor risco de hipotonia"] },
];

const comoFunciona = [
  { step: 1, title: "Agende uma consulta de avaliação", desc: "Entre em contato pelo WhatsApp ou telefone. Nossa equipe agenda sua consulta com um especialista em glaucoma na unidade mais conveniente para você." },
  { step: 2, title: "Avaliação completa com exames modernos", desc: "Realizamos tonometria, campo visual computadorizado, OCT do nervo óptico e gonioscopia. Na maioria dos casos, os exames são feitos no mesmo dia da consulta." },
  { step: 3, title: "Diagnóstico e plano de tratamento individualizado", desc: "Com base nos resultados, o especialista explica o estágio da doença e apresenta as opções de tratamento — colírios, laser ou cirurgia — de forma clara e acolhedora." },
  { step: 4, title: "Acompanhamento contínuo e monitoramento", desc: "O glaucoma exige acompanhamento regular. Realizamos consultas periódicas para verificar a pressão, o campo visual e a estabilidade do nervo óptico, ajustando o tratamento conforme necessário." },
];

const cuidados = [
  { title: "Use os colírios no horário certo", desc: "A eficácia do tratamento depende da regularidade. Use os colírios sempre no mesmo horário, mesmo quando se sentir bem. A interrupção pode levar à progressão silenciosa da doença." },
  { title: "Não falte às consultas de acompanhamento", desc: "O glaucoma pode progredir sem sintomas perceptíveis. Consultas regulares (a cada 3–6 meses) são essenciais para detectar progressão precocemente e ajustar o tratamento." },
  { title: "Evite atividades que elevam a pressão ocular", desc: "Exercícios de alta intensidade, instrumentos de sopro e posições invertidas podem elevar temporariamente a PIO. Converse com seu médico sobre as atividades físicas mais seguras para o seu caso." },
  { title: "Informe todos os médicos sobre o glaucoma", desc: "Alguns medicamentos sistêmicos (corticosteroides, anticolinérgicos) podem elevar a PIO ou interagir com os colírios antiglaucomatosos. Sempre informe seu histórico oftalmológico a qualquer médico que te atenda." },
];

const faqItems = [
  { question: "Glaucoma tem cura?", answer: "Não existe cura para o glaucoma, mas a doença pode ser controlada com tratamento adequado. O objetivo é reduzir a pressão intraocular para estabilizar o nervo óptico e impedir a progressão da perda visual. Com diagnóstico precoce e adesão ao tratamento, a grande maioria dos pacientes mantém visão funcional por toda a vida." },
  { question: "O tratamento com colírios é para a vida toda?", answer: "Na maioria dos casos, sim. O glaucoma é uma doença crônica que requer controle contínuo da pressão intraocular. Os colírios geralmente precisam ser usados indefinidamente. Em alguns casos, procedimentos a laser (SLT) ou cirurgia podem reduzir ou eliminar a necessidade de colírios, mas isso varia de paciente para paciente." },
  { question: "Alguém na minha família tem glaucoma. Eu também terei?", answer: "Ter parentes de 1º grau com glaucoma aumenta seu risco em 4 a 9 vezes. No entanto, ter histórico familiar não significa que você desenvolverá a doença — apenas que você tem maior risco. A melhor estratégia é realizar consultas oftalmológicas regulares, especialmente após os 40 anos, para diagnóstico precoce." },
  { question: "Pressão ocular alta sempre significa glaucoma?", answer: "Não necessariamente. A hipertensão ocular (PIO > 21 mmHg) é um fator de risco importante, mas nem toda pessoa com pressão alta desenvolve glaucoma. Por outro lado, existe o glaucoma de tensão normal, onde o dano ao nervo óptico ocorre mesmo com pressão dentro da faixa normal. O diagnóstico correto requer avaliação completa do nervo óptico e do campo visual." },
  { question: "Qual a diferença entre SLT e cirurgia convencional?", answer: "A SLT (Trabeculoplastia Seletiva a Laser) é um procedimento ambulatorial, não invasivo, que estimula o sistema de drenagem natural do olho. É reversível, pode ser repetido e tem recuperação imediata. A cirurgia convencional (trabeculectomia) cria uma nova via de drenagem e é indicada quando colírios e laser não são suficientes. Tem maior eficácia na redução da PIO, mas também maior risco de complicações." },
  { question: "O que são as cirurgias MIGS?", answer: "MIGS (Minimally Invasive Glaucoma Surgery) é uma nova geração de procedimentos cirúrgicos com menor trauma ao olho. Incluem dispositivos como iStent, Xen Gel Stent e Hydrus Microstent. São indicados para glaucoma leve a moderado, têm recuperação mais rápida, menor risco de complicações e podem ser realizados simultaneamente com a cirurgia de catarata." },
  { question: "Posso ficar cego por causa do glaucoma?", answer: "O glaucoma é a segunda causa de cegueira permanente no mundo. No entanto, a cegueira por glaucoma é evitável na grande maioria dos casos com diagnóstico precoce e tratamento adequado. O problema é que muitos pacientes não sabem que têm a doença até estágios avançados. Por isso, consultas regulares são fundamentais — especialmente para quem tem fatores de risco." },
  { question: "Com que frequência devo fazer exames?", answer: "Para pacientes em tratamento, geralmente recomendamos consultas a cada 3 a 6 meses, com campo visual e OCT pelo menos uma vez ao ano. Para pessoas com fatores de risco mas sem diagnóstico, recomendamos avaliação anual após os 40 anos. A frequência pode variar conforme o estágio da doença e a estabilidade do tratamento." },
  { question: "Colírios de glaucoma têm efeitos colaterais?", answer: "Sim, como qualquer medicamento. Os análogos de prostaglandina podem causar escurecimento da íris, crescimento dos cílios e vermelhidão. Os betabloqueadores podem afetar a frequência cardíaca e são contraindicados em pacientes com asma. Os inibidores da anidrase carbônica podem causar ardência e gosto amargo. É importante informar ao médico todos os medicamentos que usa para evitar interações." },
  { question: "Posso dirigir se tenho glaucoma?", answer: "Depende do estágio da doença. Em estágios iniciais e com tratamento adequado, a maioria dos pacientes pode dirigir normalmente. Em estágios avançados, a perda de campo visual periférico pode comprometer a segurança ao volante. Seu oftalmologista pode realizar testes específicos de campo visual para avaliar se sua visão atende aos requisitos legais para condução de veículos." },
  { question: "O glaucoma tem cura?", answer: "O glaucoma não tem cura, mas tem tratamento eficaz que interrompe sua progressão. Com diagnóstico precoce e tratamento adequado — colírios, laser SLT ou cirurgia — é possível preservar a visão por toda a vida. O principal problema é que o glaucoma não causa sintomas nos estágios iniciais, por isso o exame oftalmológico anual é fundamental para diagnóstico precoce." },
  { question: "Quais são os sintomas do glaucoma?", answer: "Na maioria dos casos (glaucoma de ângulo aberto), o glaucoma não causa sintomas perceptíveis até estágios avançados. A perda de visão começa pela periferia e progride lentamente. Apenas o glaucoma agudo (de ângulo fechado) causa sintomas súbitos: dor intensa no olho, visão turva, halos coloridos ao redor de luzes, náusea e vômito — situação de emergência médica." },
  { question: "O laser SLT substitui os colírios para glaucoma?", answer: "Sim, em muitos casos. O estudo LiGHT (Lancet 2019) demonstrou que o laser SLT (trabeculoplastia seletiva a laser) é tão eficaz quanto os colírios como primeira linha de tratamento, com 74,2% dos pacientes sem necessidade de medicação adicional após 3 anos. O SLT é um procedimento ambulatorial, indolor, com duração de 5 a 10 minutos, e pode ser repetido." },
];

const clinicas = [
  { name: "Guarulhos Centro", city: "Guarulhos - SP", address: "Rua Sete de Setembro, 375", phone: "(11) 5430-2421", mapsUrl: "https://www.google.com/maps/search/Drudi+e+Almeida+Guarulhos+Rua+Sete+de+Setembro+375", image: "/images/clinica_guarulhos_8e7690c7.webp" },
  { name: "Lapa", city: "São Paulo - SP", address: "Rua Barão de Jundiaí, 221", phone: "(11) 5430-2421", mapsUrl: "https://www.google.com/maps/search/Drudi+e+Almeida+Lapa+Rua+Barao+de+Jundiai+221", image: "/images/consultorio_lapa_be866546.webp" },
  { name: "Santana", city: "São Paulo - SP", address: "Rua Dr. César, 130", phone: "(11) 5430-2421", mapsUrl: "https://www.google.com/maps/search/Drudi+e+Almeida+Santana+Rua+Dr+Cesar+130", image: "/images/sala_espera_sofa_bege_v1_3860a616.webp" },
  { name: "São Miguel Paulista", city: "São Paulo - SP", address: "Rua Bernardo Marcondes, 108", phone: "(11) 5430-2421", mapsUrl: "https://www.google.com/maps/search/Drudi+e+Almeida+Sao+Miguel+Rua+Bernardo+Marcondes+108", image: "/images/sala_espera_sofa_bege_v4_0b2982e6.webp" },
  { name: "Tatuapé", city: "São Paulo - SP", address: "Rua Tuiuti, 2429", phone: "(11) 5430-2421", mapsUrl: "https://www.google.com/maps/search/Drudi+e+Almeida+Tatuape+Rua+Tuiuti+2429", image: "/images/sala_espera_sofa_bege_v3_5717e0c0.webp" },
];
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<BaseLayout
  title="Glaucoma: Diagnóstico e Tratamento em SP | Drudi e Almeida"
  description="Instituto do Glaucoma: diagnóstico precoce, colírios, laser SLT e cirurgia MIGS. Especialistas em glaucoma em 5 unidades em São Paulo e Guarulhos."
  canonicalPath="/instituto/glaucoma"
  ogImage="/images/og-glaucoma_07645bdd.webp"
  heroImage="/images/glaucoma-hero-inst.webp"
>
  <FAQSchema items={faqItems} slot="head-schema" />
  <script type="application/ld+json" slot="head-schema" set:html={JSON.stringify({"@context": "https://schema.org", "@type": "MedicalClinic", "name": "Instituto do Glaucoma — Drudi e Almeida", "medicalSpecialty": "http://schema.org/Optometric", "url": "https://institutodrudiealmeida.com.br/instituto/glaucoma/", "telephone": "+551154302421", "priceRange": "$$", "description": "Diagnóstico precoce e tratamento contínuo do glaucoma: trabeculoplastia seletiva a laser (SLT), trabeculectomia, implante de válvula de Ahmed e colírios.", "image": {"@type": "ImageObject", "url": "https://institutodrudiealmeida.com.br/images/hero-monet-resized_00e348d0.webp", "width": 1920, "height": 1080}, "address": {"@type": "PostalAddress", "streetAddress": "Rua Dr. César, 130", "addressLocality": "São Paulo", "addressRegion": "SP", "postalCode": "02013-001", "addressCountry": "BR"}, "parentOrganization": {"@type": "MedicalOrganization", "name": "Drudi e Almeida Clínicas Oftalmológicas", "url": "https://institutodrudiealmeida.com.br/"}, "aggregateRating": {"@type": "AggregateRating", "ratingValue": "4.9", "bestRating": "5", "worstRating": "1", "reviewCount": "312"}})} />
  <script type="application/ld+json" slot="head-schema" set:html={JSON.stringify({"@context": "https://schema.org", "@type": "HowTo", "name": "Como é feito o diagnóstico e tratamento do glaucoma", "description": "Protocolo de diagnóstico e tratamento do glaucoma na Drudi e Almeida Oftalmologia.", "step": [{"@type": "HowToStep", "position": 1, "name": "Tonometria", "text": "Medida da pressão intraocular com tonômetro de aplanação de Goldmann. Pressão normal: 10-21 mmHg."}, {"@type": "HowToStep", "position": 2, "name": "Gonioscopia", "text": "Avaliação do ângulo camerular para classificar o tipo de glaucoma (aberto ou fechado)."}, {"@type": "HowToStep", "position": 3, "name": "OCT de nervo óptico", "text": "Tomografia de coerência óptica (OCT) da camada de fibras nervosas para detectar perda estrutural precoce."}, {"@type": "HowToStep", "position": 4, "name": "Campo visual computadorizado", "text": "Perimetria automatizada (Humphrey 750i) para mapear a perda funcional do campo visual."}, {"@type": "HowToStep", "position": 5, "name": "Tratamento individualizado", "text": "Colírios hipotensores, laser (trabeculoplastia seletiva — SLT) ou cirurgia (trabeculectomia), conforme o estágio e tipo de glaucoma."}]})} />

  <script type="application/ld+json" slot="head-schema" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalCondition",
    "name": "Glaucoma",
    "alternateName": "Neuropatia Óptica Glaucomatosa",
    "description": "Grupo de doenças que causam dano progressivo ao nervo óptico, geralmente associado à pressão intraocular elevada. Principal causa de cegueira irreversível no mundo.",
    "code": { "@type": "MedicalCode", "code": "H40", "codingSystem": "ICD-10" },
    "possibleTreatment": [
      {
        "@type": "MedicalProcedure",
        "name": "Trabeculoplastia a Laser (SLT)",
        "procedureType": "http://schema.org/SurgicalProcedure",
        "description": "Laser seletivo aplicado na malha trabecular para melhorar a drenagem do humor aquoso e reduzir a pressão intraocular."
      },
      {
        "@type": "MedicalProcedure",
        "name": "Trabeculectomia",
        "procedureType": "http://schema.org/SurgicalProcedure",
        "description": "Cirurgia filtrante que cria uma via alternativa de drenagem do humor aquoso para reduzir a pressão intraocular em casos refratários."
      }
    ],
    "signOrSymptom": [
      { "@type": "MedicalSymptom", "name": "Perda de campo visual periférico" },
      { "@type": "MedicalSymptom", "name": "Pressão intraocular elevada" },
      { "@type": "MedicalSymptom", "name": "Dor ocular intensa (glaucoma agudo)" },
      { "@type": "MedicalSymptom", "name": "Halos coloridos ao redor de luzes" }
    ],
    "associatedAnatomy": { "@type": "AnatomicalStructure", "name": "Nervo Óptico" },
    "relevantSpecialty": "http://schema.org/Optometric"
  })} />

  <!-- ========== 1. HERO ========== -->
  <section class="relative min-h-[85vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/glaucoma-hero_degas_a3f7c912.webp')"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy/92 via-navy/75 to-transparent"></div>

    <div class="relative container pb-14 pt-[100px] md:pt-[120px]">
      <div class="max-w-2xl">


                <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Institutos", href: "/institutos" }, { label: "Instituto do Glaucoma" }]} />


        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.1] mb-6 aos-element" style="color:#ffffff !important; text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
          <em class="text-gold italic">Glaucoma</em> -<br class="hidden md:block" />
          diagnóstico precoce para preservar sua visão
        </h1>

        <p class="font-body text-lg text-cream/80 leading-relaxed mb-8 max-w-xl aos-element">
          O glaucoma é o "ladrão silencioso da visão". Selecione sua unidade e receba informações sobre diagnóstico e tratamento com especialistas.
        </p>

        <!-- Form -->
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-cream/10 max-w-md aos-element">
          <div class="space-y-4">
