      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-5 max-w-4xl mx-auto">
        {[
          { name: "Instituto da Catarata", href: "/instituto/catarata", logo: "/images/logo-catarata-128_4016b3c8.webp", desc: "Cirurgia de catarata com facoemulsificação e lentes premium. Especialistas renomados em SP." },
          { name: "Instituto do Ceratocone", href: "/instituto/ceratocone", logo: "/images/logo-ceratocone-128_5f37b031.webp", desc: "Crosslinking, anel de Ferrara e lentes de contato especiais para ceratocone." },
          { name: "Instituto da Retina", href: "/instituto/retina", logo: "/images/logo-retina-128_88ef0fac.webp", desc: "Vitrectomia, injeções intravítreas e tratamento de doenças da retina." },
          { name: "Instituto de Estrabismo", href: "/instituto/estrabismo", logo: "/images/logo-estrabismo-128_b8ca4997.webp", desc: "Cirurgia de estrabismo para crianças e adultos com técnicas modernas." },
