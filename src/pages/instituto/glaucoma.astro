  <!-- ========== 12. A IMPORTÂNCIA DO CAMPO VISUAL ========== -->
  <section class="section-padding" style="background:#faf9f7">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center max-w-5xl mx-auto">
