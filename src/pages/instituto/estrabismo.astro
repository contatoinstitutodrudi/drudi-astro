            <h3 class="font-display text-lg text-navy mb-4">Recuperação</h3>
            <div class="space-y-3">
              {[
                { periodo: "1-3 dias", desc: "Vermelhidão e desconforto leve. Uso de colírios antibióticos e anti-inflamatórios." },
