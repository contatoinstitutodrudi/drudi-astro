---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSchema from '../../components/FAQSchema.astro';

const WHATSAPP_LINK = "https://wa.me/5511916544653?text=Olá! Gostaria de saber mais sobre o tratamento de ceratocone.";
const PHONE = "(11) 91654-4653";

const unidades = [
  { id: "guarulhos-centro", name: "Guarulhos Centro", address: "Guarulhos - SP" },
  { id: "lapa", name: "Lapa", address: "São Paulo - SP" },
  { id: "santana", name: "Santana", address: "São Paulo - SP" },
  { id: "sao-miguel", name: "São Miguel", address: "São Paulo - SP" },
  { id: "tatuape", name: "Tatuapé", address: "São Paulo - SP" },
];

const comoFunciona = [
  { step: 1, title: "Agende uma consulta de avaliação", description: "Entre em contato pelo WhatsApp ou telefone e agende sua consulta com um de nossos especialistas em córnea e ceratocone." },
  { step: 2, title: "Exames de mapeamento da córnea", description: "Realizamos exames com o Pentacam AXL e OCT de segmento anterior para mapear com precisão o formato da sua córnea e estadiar o ceratocone." },
  { step: 3, title: "Plano de tratamento personalizado", description: "Com base nos exames, nossos especialistas definem o melhor tratamento: crosslinking, lentes especiais, anéis intracorneanos ou transplante de córnea." },
  { step: 4, title: "Acompanhamento contínuo", description: "O ceratocone exige acompanhamento regular. Nossa equipe monitora a progressão e ajusta o tratamento para preservar sua visão a longo prazo." },
];

const sintomasZigzag = [
  { title: "Visão embaçada progressiva", description: "A visão vai ficando progressivamente mais turva, especialmente para longe. Óculos e lentes convencionais não conseguem corrigir completamente a visão, pois o astigmatismo irregular causado pelo ceratocone não é corrigível com lentes comuns.", image: "/images/ceratocone-sintoma-visao-emba_2ddb7aa2.webp" },
  { title: "Sensibilidade à luz (fotofobia)", description: "Pacientes com ceratocone frequentemente apresentam desconforto intenso com luzes fortes, brilho excessivo e reflexos. Dirigir à noite torna-se especialmente difícil devido aos halos ao redor dos faróis.", image: "/images/fotofobia-ceratocone_9b8447b7.webp" },
  { title: "Troca frequente de óculos", description: "Como a córnea muda de formato progressivamente, o grau dos óculos precisa ser alterado com frequência — às vezes a cada poucos meses. Mesmo com óculos novos, a visão pode não ficar totalmente nítida.", image: "/images/ceratocone-sintoma-oculos_6db1f062.webp" },
  { title: "Visão dupla e halos luminosos", description: "Imagens fantasmas ou duplicadas em um mesmo olho (diplopia monocular) e halos luminosos ao redor das luzes são sinais característicos do astigmatismo irregular causado pelo ceratocone.", image: "/images/ceratocone-sintoma-halos_2ab35670.webp" },
  { title: "Coceira persistente nos olhos", description: "Muitos pacientes com ceratocone têm histórico de alergia ocular e coceira crônica. O ato de coçar os olhos vigorosamente é um dos principais fatores de risco para o desenvolvimento e progressão da doença.", image: "/images/ceratocone-sintoma-coceira_6ad37407.webp" },
];

const tratamentos = [
  { step: 1, title: "Lentes de contato especiais", description: "As lentes rígidas gás-permeáveis (RGP) e as lentes esclerais são a primeira linha de tratamento para melhorar a visão. Elas criam uma superfície regular sobre a córnea irregular, proporcionando visão nítida." },
  { step: 2, title: "Crosslinking corneano", description: "O procedimento padrão-ouro para estabilizar o ceratocone. Combina colírio de riboflavina com luz UV para fortalecer as fibras de colágeno da córnea, interrompendo a progressão em mais de 95% dos casos." },
  { step: 3, title: "Anéis intracorneanos (Anel de Ferrara)", description: "Pequenos segmentos de plástico implantados na córnea para aplanar sua curvatura e melhorar a acuidade visual. Podem adiar ou eliminar a necessidade de transplante em ceratocones leves a moderados." },
  { step: 4, title: "Transplante de córnea (DALK/PKP)", description: "Para casos avançados, o transplante de córnea é indicado. A técnica DALK (lamelar anterior profunda) preserva o endotélio do paciente, com menor risco de rejeição e recuperação mais rápida." },
];

const faqItems = [
  { question: "Coçar os olhos pode causar ceratocone?", answer: "Sim. O ato de coçar os olhos de forma crônica e vigorosa é um dos principais fatores de risco associados ao desenvolvimento e à progressão do ceratocone. Estudos mostram que o trauma mecânico repetitivo enfraquece as fibras de colágeno da córnea. É fundamental evitar esse hábito, especialmente em pacientes com alergia ocular." },
  { question: "Ceratocone tem cura?", answer: "O ceratocone não tem cura no sentido de reverter completamente a condição, mas os tratamentos modernos são extremamente eficazes. O crosslinking corneano estabiliza a progressão em mais de 95% dos casos. As lentes de contato especiais e os anéis intracorneanos melhoram significativamente a visão. Em casos avançados, o transplante de córnea tem taxa de sucesso superior a 90%." },
  { question: "O Crosslinking é doloroso?", answer: "O procedimento é realizado com anestesia por colírios e é bem tolerado. Durante o procedimento, o paciente pode sentir leve desconforto. Nos primeiros 2-3 dias após, pode haver dor leve a moderada, sensibilidade à luz e lacrimejamento, controlados com medicação. A recuperação visual completa ocorre em 1-3 meses." },
  { question: "Quem tem ceratocone pode fazer LASIK?", answer: "Não. A cirurgia refrativa a laser tradicional (LASIK/PRK) é contraindicada em pacientes com ceratocone, pois afina ainda mais a córnea, podendo desestabilizar e agravar significativamente a doença. Existem alternativas como lentes de contato especiais, anéis intracorneanos e, em alguns casos, lentes intraoculares fácicas." },
  { question: "Qual a diferença entre lente escleral e lente rígida?", answer: "A lente rígida gás-permeável (RGP) é menor e apoia-se diretamente sobre a córnea. A lente escleral é maior e apoia-se na esclera (parte branca do olho), sem tocar a córnea — criando uma câmara de líquido que hidrata e protege. As esclerais oferecem conforto superior e melhor acuidade visual em ceratocones avançados." },
  { question: "O anel de Ferrara pode substituir o transplante?", answer: "Em muitos casos, sim. Os segmentos intracorneanos (anel de Ferrara) podem adiar ou até eliminar a necessidade de transplante em ceratocones leves a moderados. Eles aplanam a córnea e melhoram a acuidade visual. Os resultados são estáveis por mais de 5 anos. Podem ser combinados com crosslinking para resultados ainda melhores." },
  { question: "Ceratocone é hereditário?", answer: "Existe um componente genético importante. Parentes de primeiro grau de pacientes com ceratocone têm 15 a 67 vezes mais risco de desenvolver a doença. Por isso, recomendamos que filhos e irmãos de pacientes com ceratocone realizem exames de topografia corneana preventivos a partir dos 10 anos de idade." },
  { question: "A partir de que idade o ceratocone para de progredir?", answer: "Geralmente, a progressão do ceratocone tende a estabilizar por volta dos 35-40 anos de idade. No entanto, isso varia de paciente para paciente. O crosslinking pode ser realizado em qualquer idade para estabilizar a doença precocemente, sendo especialmente importante em pacientes jovens com progressão documentada." },
];

const clinicas = [
  { name: "Guarulhos Centro", city: "Guarulhos - SP", address: "Rua Sete de Setembro, 375", phone: "(11) 5430-2421", mapsUrl: "https://www.google.com/maps/search/Drudi+e+Almeida+Guarulhos+Rua+Sete+de+Setembro+375", image: "/images/clinica_guarulhos_8e7690c7.webp" },
  { name: "Lapa", city: "São Paulo - SP", address: "Rua Barão de Jundiaí, 221", phone: "(11) 5430-2421", mapsUrl: "https://www.google.com/maps/search/Drudi+e+Almeida+Lapa+Rua+Barao+de+Jundiai+221", image: "/images/consultorio_lapa_be866546.webp" },
  { name: "Santana", city: "São Paulo - SP", address: "Rua Dr. César, 130", phone: "(11) 5430-2421", mapsUrl: "https://www.google.com/maps/search/Drudi+e+Almeida+Santana+Rua+Dr+Cesar+130", image: "/images/sala_espera_sofa_bege_v1_3860a616.webp" },
  { name: "São Miguel Paulista", city: "São Paulo - SP", address: "Rua Bernardo Marcondes, 108", phone: "(11) 5430-2421", mapsUrl: "https://www.google.com/maps/search/Drudi+e+Almeida+Sao+Miguel+Rua+Bernardo+Marcondes+108", image: "/images/sala_espera_sofa_bege_v4_0b2982e6.webp" },
  { name: "Tatuapé", city: "São Paulo - SP", address: "Rua Tuiuti, 2429", phone: "(11) 5430-2421", mapsUrl: "https://www.google.com/maps/search/Drudi+e+Almeida+Tatuape+Rua+Tuiuti+2429", image: "/images/sala_espera_sofa_bege_v3_5717e0c0.webp" },
];
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<BaseLayout
  title="Tratamento do Ceratocone com excelentes especialistas | Drudi e Almeida"
  description="Tratamento de ceratocone em SP: crosslinking, anel de Ferrara, lentes esclerais e transplante de córnea. Diagnóstico com Pentacam. 5 unidades. Agende sua consulta."
  canonicalPath="/instituto/ceratocone"
  heroImage="/images/ceratocone-hero_4839850a.webp"
  heroImageSrcset="/images/ceratocone-hero-480w.webp 480w, /images/ceratocone-hero-768w.webp 768w, /images/ceratocone-hero_4839850a.webp 1280w"
>
  <FAQSchema items={faqItems} slot="head-schema" />

  <!-- ========== 1. HERO ========== -->
  <section class="relative min-h-[85vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/ceratocone-hero_4839850a.webp')"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy/90 via-navy/70 to-transparent"></div>

    <div class="relative container pb-14 pt-[100px] md:pt-[120px]">
      <div class="max-w-2xl">


                <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Institutos", href: "/institutos" }, { label: "Instituto do Ceratocone" }]} />


        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.1] mb-6 aos-element" style="color:#ffffff !important; text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
          Tratamento do <em class="text-gold italic">Ceratocone</em><br class="hidden md:block" />com excelentes especialistas
        </h1>

        <p class="font-body text-lg text-cream/80 leading-relaxed mb-8 max-w-xl aos-element">
          Selecione a unidade mais próxima e agende sua consulta com especialistas em córnea e ceratocone.
        </p>

        <!-- Form -->
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-cream/10 max-w-md aos-element">
          <div class="space-y-4">
            <div>
              <label class="font-ui text-xs font-semibold tracking-wider uppercase text-cream/60 mb-2 block">Unidade</label>
              <select id="unidade-hero" class="w-full bg-white text-navy font-body text-sm rounded-lg px-4 py-3 border-0 focus:ring-2 focus:ring-gold">
                <option value="">Selecione a unidade</option>
                {unidades.map(u => (
                  <option value={u.id}>{u.name} — {u.address}</option>
                ))}
              </select>
            </div>
            <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer"
              class="w-full inline-flex items-center justify-center gap-2 bg-gold text-navy font-ui text-sm font-bold px-6 py-3.5 rounded-lg hover:bg-gold/90 transition-all shadow-lg">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              Agendar Avaliação
            </a>
            <a href="/agendar"
              class="w-full inline-flex flex-col items-center justify-center gap-0.5 bg-white text-gold font-ui text-sm font-bold px-6 py-3 rounded-md border-2 border-gold hover:bg-gold hover:text-navy transition-all shadow-sm">
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Agendar Online
              </span>
              <span class="text-white/60 text-[10px] font-normal">Consulta disponível em até 48h</span>
            </a>
            <a href={`tel:+55${PHONE.replace(/\D/g, "")}`}
              class="w-full inline-flex items-center justify-center gap-2 font-ui text-sm font-semibold px-6 py-3 rounded-lg border border-cream/30 text-cream hover:bg-cream/10 transition-all">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.55 5.55l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/></svg>
              Ligar: {PHONE}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 2. AVALIAÇÕES ========== -->
  <section class="py-10 bg-white border-b border-border/40">
    <div class="container">
      <div class="grid grid-cols-3 gap-4 max-w-2xl mx-auto">
        <div class="text-center">
          <div class="flex justify-center mb-2">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-gold fill-gold" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <p class="font-display text-2xl text-navy font-bold">4,9</p>
          <p class="font-body text-xs text-muted-foreground mt-0.5">no Google</p>
        </div>
        <div class="text-center border-x border-border/50 px-4">
          <p class="font-display text-2xl text-navy font-bold">+10</p>
          <p class="font-body text-xs text-muted-foreground mt-0.5">anos de experiência</p>
        </div>
        <div class="text-center">
          <p class="font-display text-2xl text-navy font-bold">5</p>
          <p class="font-body text-xs text-muted-foreground mt-0.5">unidades em SP</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 3. COMO FUNCIONA ========== -->
  <section class="section-padding bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="aos-element">
          <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold">Passo a Passo</span>
          <h2 class="font-display text-3xl md:text-4xl text-navy mt-3 mb-3">Como funciona?</h2>
          <p class="font-body text-base text-muted-foreground mb-10 leading-relaxed">
            Agende sua consulta e descubra como podemos ajudar você a tratar o ceratocone
          </p>
        </div>

        <div class="space-y-6">
          {comoFunciona.map(item => (
            <div class="flex gap-4 aos-element">
              <div class="w-10 h-10 rounded-full bg-navy text-cream flex items-center justify-center shrink-0 font-display text-sm font-bold">
                {item.step}
              </div>
              <div>
                <h3 class="font-display text-base text-navy mb-1">{item.title}</h3>
                <p class="font-body text-sm text-muted-foreground leading-relaxed">{item.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap gap-3 aos-element">
          <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-emerald-600 text-white font-ui text-sm font-bold px-6 py-3.5 rounded-lg hover:bg-emerald-700 transition-all shadow-lg">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Agende pelo WhatsApp
          </a>
          <a href="/agendar"
            class="inline-flex flex-col items-center justify-center gap-0.5 bg-gold text-navy font-ui text-sm font-bold px-6 py-3 rounded-lg hover:bg-gold-light transition-all shadow-md">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Agendar Online
            </span>
            <span class="text-white/60 text-[10px] font-normal">Consulta disponível em até 48h</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 4. NOSSAS UNIDADES ========== -->
  <section class="section-padding" style="background:#faf9f7">
    <div class="container">
      <div class="text-center mb-12 aos-element">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold">Nossas Clínicas</span>
        <h2 class="font-display text-3xl md:text-4xl text-navy mt-3">Conheça nossas unidades</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {clinicas.map(clinica => (
          <div class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-border/40 hover:shadow-lg hover:border-gold/30 transition-all aos-element">
            <div class="relative overflow-hidden">
              <img loading="lazy" src={clinica.image} alt={`Unidade Drudi e Almeida ${clinica.name}`} class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0 bg-gradient-to-t from-navy/60 to-transparent"></div>
              <div class="absolute bottom-3 left-4">
                <span class="font-ui text-xs font-bold text-white bg-gold/80 rounded-full px-3 py-1">{clinica.city}</span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-display text-lg text-navy mb-2">{clinica.name}</h3>
              <div class="flex items-start gap-2 mb-1">
                <svg class="w-3.5 h-3.5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <p class="font-body text-xs text-muted-foreground">{clinica.address}</p>
              </div>
              <div class="flex items-center gap-2 mb-4">
                <svg class="w-3.5 h-3.5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.55 5.55l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/></svg>
                <p class="font-body text-xs text-muted-foreground">{clinica.phone}</p>
              </div>
              <a href={clinica.mapsUrl} target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-navy hover:text-gold font-ui text-xs font-semibold transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Ver no Google Maps
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 5. O QUE É CERATOCONE ========== -->
  <section class="section-padding bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="aos-element">
          <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase text-gold">Entenda</span>
          <h2 class="font-display text-3xl md:text-4xl text-navy mt-3 mb-6">
            O que você precisa saber sobre o <span class="text-gold">ceratocone</span>
          </h2>
          <div class="space-y-4 font-body text-sm text-muted-foreground leading-relaxed">
            <p>O <strong class="text-navy">ceratocone</strong> é uma doença progressiva da córnea em que ela perde sua forma esférica normal e começa a se afinar e projetar para frente, assumindo um formato cônico. Essa deformação causa astigmatismo irregular e miopia progressiva.</p>
            <p>A doença geralmente começa na adolescência ou no início da vida adulta e pode progredir por 10 a 20 anos. O diagnóstico precoce é fundamental, pois o <strong class="text-navy">crosslinking corneano</strong> pode estabilizar a progressão quando realizado nos estágios iniciais.</p>
            <p>Na Drudi e Almeida, utilizamos o <strong class="text-navy">Pentacam AXL</strong> — o exame mais preciso disponível — para mapear a topografia corneana e identificar o ceratocone mesmo em seus estágios mais iniciais, quando o tratamento é mais eficaz.</p>
            <p>Com os tratamentos modernos disponíveis, a grande maioria dos pacientes com ceratocone consegue <strong class="text-navy">manter boa qualidade visual e evitar o transplante de córnea</strong>.</p>
