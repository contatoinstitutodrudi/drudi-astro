import Breadcrumb from '../../components/Breadcrumb.astro';
---

<BaseLayout
  title="Instituto da Retina em SP | Vitrectomia, Anti-VEGF e DMRI | Drudi e Almeida"
  description="Instituto da Retina em São Paulo: tratamento de DMRI, retinopatia diabética, descolamento de retina e injeção intravítrea. Dr. Fernando Drudi, especialista em retina cirúrgica. 5 unidades em SP e Guarulhos."
  keywords="retina SP, instituto da retina São Paulo, injeção intravítrea SP, DMRI tratamento, retinopatia diabética, descolamento de retina, vitrectomia SP, anti-VEGF, mapeamento de retina"
  canonicalPath="/instituto/retina"
>
  <FAQSchema items={faqItems} slot="head-schema" />

  <!-- ========== 1. HERO ========== -->
  <section class="relative min-h-[85vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/retina-hero_cb57f973.webp')"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy/90 via-navy/70 to-transparent"></div>

    <div class="relative container pb-14 pt-28">
      <div class="max-w-2xl">

                <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Institutos", href: "/institutos" }, { label: "Instituto da Retina" }]} />


        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.1] mb-4 aos-element" style="color:#ffffff !important; text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
          Especialistas em <em class="text-gold italic">Retina</em><br class="hidden md:block" />em São Paulo
        </h1>

        <p class="font-body text-lg text-cream/80 leading-relaxed mb-8 max-w-xl aos-element">
          A retina é responsável por transformar luz em visão. Nosso Instituto da Retina oferece diagnóstico avançado e tratamento cirúrgico para todas as doenças retinianas — de DMRI a descolamento de retina. Selecione sua unidade e agende.
        </p>

        <!-- Stats rápidos -->
        <div class="flex flex-wrap gap-6 mb-8 aos-element">
          {[
            { valor: "10+", label: "Anos em retina cirúrgica" },
            { valor: "5", label: "Unidades em SP" },
            { valor: "OCT", label: "Angio-OCT disponível" },
          ].map(s => (
            <div class="text-center">
              <div class="font-display text-2xl font-bold" style="color:#c9a84c">{s.valor}</div>
              <div class="font-ui text-[10px] text-cream/60 mt-0.5">{s.label}</div>
            </div>
