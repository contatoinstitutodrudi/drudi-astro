---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhysicianSchema from '../../components/PhysicianSchema.astro';

const WHATSAPP_LINK = "https://wa.me/5511916544653?text=Olá! Gostaria de agendar uma consulta com a Dra. Priscilla de Almeida.";

const doctor = {
  name: "Dra. Priscilla de Almeida",
  fullName: "Dra. Priscilla Rodrigues de Almeida",
  crm: "CRM-SP 148.173",
  rqe: "RQE 59.216",
  role: "Diretora Técnica",
  specialty: "Especialista em Córnea, Ceratocone e Lentes de Contato",
  image: "/images/dra-priscilla-800w.webp",
  bio: [
    "A Dra. Priscilla Rodrigues de Almeida construiu sua trajetória na oftalmologia a partir de uma formação sólida e vivência intensa em ambientes de alta complexidade. Formou-se em Medicina e realizou Residência em Oftalmologia pelo Hospital do Servidor Público do Estado de São Paulo (HSPE), realizando centenas de cirurgias de catarata.",
    "Aprofundou seus conhecimentos com Fellowship em Doenças Oculares Externas e Córnea Cirúrgica pela Escola Paulista de Medicina (EPM/UNIFESP), referência nacional em ensino e pesquisa, com atuação em cirurgias de córnea e transplantes.",
    "Co-fundadora da Drudi e Almeida Oftalmologia, a Dra. Priscilla lidera o Instituto do Ceratocone com foco no diagnóstico precoce e tratamento personalizado de doenças da córnea, combinando adaptação de lentes de contato especiais com as mais modernas técnicas cirúrgicas disponíveis.",
    "Sua abordagem clínica é marcada pelo cuidado humanizado e pela busca constante pela atualização científica, participando regularmente de congressos nacionais e internacionais e contribuindo com produção científica na área de doenças da superfície ocular.",
  ],
  formation: [
    "Graduação em Medicina",
    "Residência em Oftalmologia — HSPE/SP",
    "Fellowship em Córnea Cirúrgica — EPM/UNIFESP",
    "Produção científica e congressos nacionais e internacionais",
  ],
  awards: [
    "Fellowship pela Escola Paulista de Medicina (EPM/UNIFESP)",
    "Participação em congressos nacionais e internacionais",
    "Produção científica em doenças da superfície ocular",
  ],
  areas: [
    "Ceratocone — Diagnóstico e Tratamento",
    "Crosslinking Corneano",
    "Anel de Ferrara (Anel Intracorneano)",
    "Adaptação de Lentes de Contato Especiais",
    "Transplante de Córnea (Penetrante e Lamelar)",
    "Doenças da Superfície Ocular",
    "Olho Seco",
    "Cirurgia de Catarata",
    "Pterígio",
  ],
  institutes: [
    { name: "Instituto do Ceratocone", href: "/instituto/ceratocone" },
  ],
};
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<BaseLayout
  title="Dra. Priscilla de Almeida — Oftalmologista em SP | Córnea e Ceratocone"
  description="Dra. Priscilla Rodrigues de Almeida, CRM-SP 148.173. Oftalmologista especialista em Córnea e Ceratocone. Fellowship EPM/UNIFESP. Diretora Técnica da Drudi e Almeida. Agende: (11) 5430-2421."
>
  <PhysicianSchema
    name={doctor.fullName}
    image={doctor.image}
    url="/medico/dra-priscilla-almeida"
    description="Dra. Priscilla Rodrigues de Almeida, CRM-SP 148.173. Oftalmologista especialista em Córnea e Ceratocone. Fellowship EPM/UNIFESP. Diretora Técnica da Drudi e Almeida."
    crm="CRM-SP 148.173"
    rqe="RQE 59.216"
    jobTitle={doctor.role}
    specialties={["Corneal Disease", "Keratoconus", "Contact Lens", "Ophthalmology"]}
  />

  <!-- ========== HERO ========== -->
  <section class="relative overflow-hidden" style="background:linear-gradient(135deg,#1e2a44 0%,#162036 100%);padding-top:116px">
    <div class="absolute inset-0 opacity-5" style="background-image:radial-gradient(circle at 2px 2px, #ffffff 1px, transparent 0);background-size:40px 40px"></div>

    <div class="relative container py-12 md:py-20">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 font-ui text-xs mb-8" style="color:rgba(245,240,232,0.55)">
        <a href="/" style="color:#ffffff" class="hover:opacity-80 transition-opacity">Início</a>
        <span style="color:rgba(255,255,255,0.50)">/</span>
        <a href="/sobre" style="color:#ffffff" class="hover:opacity-80 transition-opacity">Sobre Nós</a>
        <span style="color:rgba(255,255,255,0.50)">/</span>
        <span style="color:#c9a961">{doctor.name}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <!-- Foto -->
        <div class="relative max-w-md mx-auto lg:mx-0 aos-element">
          <div class="absolute -inset-4 rounded-2xl blur-xl" style="background:linear-gradient(135deg,rgba(201,169,97,0.20),rgba(201,169,97,0.05))"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-2xl" style="border:1px solid rgba(201,169,97,0.25)">
            <img
              src={doctor.image}
              alt={`${doctor.fullName} — Oftalmologista especialista em Córnea e Ceratocone em São Paulo`}
              class="w-full object-cover"
              style="height:480px;object-position:center 10%"
              loading="eager"
            />
            <div class="absolute inset-0" style="background:linear-gradient(to top, rgba(30,42,68,0.80) 0%, transparent 50%)"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <p class="font-display text-xl text-white">{doctor.fullName}</p>
              <p class="font-ui text-xs mt-1" style="color:#c9a961">{doctor.crm} | {doctor.rqe}</p>
            </div>
          </div>
        </div>

        <!-- Conteúdo -->
        <div class="aos-element">
          <div class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 mb-5" style="background:rgba(201,169,97,0.15);border:1px solid rgba(201,169,97,0.30)">
            <svg class="w-3.5 h-3.5" style="color:#c9a961" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <span class="font-ui text-xs font-semibold tracking-wide" style="color:#c9a961">{doctor.role.toUpperCase()}</span>
          </div>

                  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Nossa Equipe", href: "/sobre" }, { label: "Dra. Priscilla Almeida" }]} />


          <h1 class="font-display leading-tight mb-2" style="font-size:clamp(2rem,4vw,3rem);color:#ffffff">
            {doctor.fullName}
          </h1>
          <p class="font-ui text-base font-semibold mb-2" style="color:#c9a961">{doctor.specialty}</p>
          <p class="font-ui text-sm mb-6" style="color:rgba(245,240,232,0.55)">{doctor.crm} | {doctor.rqe}</p>

          <!-- Institutos -->
          <div class="flex flex-wrap gap-2 mb-8">
            {doctor.institutes.map(inst => (
              <a href={inst.href} class="inline-flex items-center gap-1.5 font-ui text-xs font-semibold px-3 py-1.5 rounded-full transition-all hover:scale-105" style="background:rgba(201,169,97,0.12);border:1px solid rgba(201,169,97,0.25);color:#c9a961">
                {inst.name}
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>

          <!-- Botões -->
          <div class="flex flex-col sm:flex-row gap-3">
            <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 font-ui text-sm font-bold px-7 py-3.5 rounded-md transition-colors"
              style="background:#c9a961;color:#1e2a44"
              onmouseover="this.style.background='#b8975a'"
              onmouseout="this.style.background='#c9a961'"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.116 1.523 5.845L0 24l6.338-1.498A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.89 0-3.663-.497-5.197-1.367l-.371-.22-3.763.889.936-3.659-.241-.386A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
              Agendar Consulta
            </a>
            <a href="tel:+551154302421"
              class="inline-flex items-center justify-center gap-2 font-ui text-sm font-semibold px-6 py-3.5 rounded-md transition-colors"
              style="border:1px solid rgba(245,240,232,0.30);color:#f5f0e8"
              onmouseover="this.style.background='rgba(245,240,232,0.10)'"
              onmouseout="this.style.background='transparent'"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (11) 5430-2421
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== BIOGRAFIA COMPLETA ========== -->
  <section class="section-padding" style="background:#ffffff">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="aos-element">
          <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase" style="color:#c9a961">Trajetória Profissional</span>
          <h2 class="font-display text-2xl md:text-3xl mt-3 mb-8" style="color:#1e2a44">
            Conheça a história da {doctor.name}
          </h2>
        </div>
        <div class="space-y-5">
          {doctor.bio.map((paragraph) => (
            <p class="font-body text-base leading-relaxed aos-element" style="color:#6b7280">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FORMAÇÃO E RECONHECIMENTOS ========== -->
  <section class="section-padding" style="background:#faf9f7">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Formação -->
        <div class="aos-element">
          <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase" style="color:#c9a961">Formação Acadêmica</span>
          <h2 class="font-display text-2xl mt-3 mb-6" style="color:#1e2a44">Educação e Especialização</h2>
          <div class="space-y-3">
            {doctor.formation.map(item => (
              <div class="flex items-start gap-4 p-4 rounded-xl shadow-sm" style="background:#ffffff;border:1px solid rgba(30,42,68,0.08)">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background:rgba(30,42,68,0.06)">
                  <svg class="w-5 h-5" style="color:#1e2a44" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
                </div>
                <p class="font-body text-sm leading-relaxed pt-2" style="color:#1e2a44">{item}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Reconhecimentos -->
        <div class="aos-element">
          <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase" style="color:#c9a961">Reconhecimentos</span>
          <h2 class="font-display text-2xl mt-3 mb-6" style="color:#1e2a44">Prêmios e Contribuições</h2>
          <div class="space-y-3">
            {doctor.awards.map(item => (
              <div class="flex items-start gap-4 p-4 rounded-xl shadow-sm" style="background:#ffffff;border:1px solid rgba(201,169,97,0.20)">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background:rgba(201,169,97,0.10)">
                  <svg class="w-5 h-5" style="color:#c9a961" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                </div>
                <p class="font-body text-sm leading-relaxed pt-2" style="color:#1e2a44">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== ÁREAS DE ATUAÇÃO ========== -->
  <section class="section-padding" style="background:#ffffff">
    <div class="container">
      <div class="text-center mb-10 aos-element">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase" style="color:#c9a961">Especialidades</span>
        <h2 class="font-display text-2xl md:text-3xl mt-3 mb-4" style="color:#1e2a44">Áreas de Atuação</h2>
        <div class="gold-line max-w-[80px] mx-auto"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
        {doctor.areas.map((area) => (
          <div class="flex items-center gap-3 p-4 rounded-xl transition-all hover:shadow-md aos-element" style="border:1px solid rgba(30,42,68,0.10);background:#faf9f7" onmouseover="this.style.borderColor='rgba(201,169,97,0.40)'" onmouseout="this.style.borderColor='rgba(30,42,68,0.10)'">
            <svg class="w-5 h-5 shrink-0" style="color:#c9a961" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span class="font-body text-sm" style="color:#1e2a44">{area}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== INSTITUTOS ========== -->
  <section class="section-padding" style="background:#faf9f7">
    <div class="container">
      <div class="text-center mb-10 aos-element">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase" style="color:#c9a961">Atendimento</span>
        <h2 class="font-display text-2xl md:text-3xl mt-3 mb-4" style="color:#1e2a44">Institutos onde atende</h2>
        <div class="gold-line max-w-[80px] mx-auto"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-1 gap-6 max-w-sm mx-auto">
        {doctor.institutes.map(inst => (
          <a href={inst.href} class="group block aos-element">
            <div class="p-6 rounded-xl transition-all hover:shadow-lg" style="border:1px solid rgba(30,42,68,0.10);background:#ffffff" onmouseover="this.style.borderColor='rgba(201,169,97,0.40)'" onmouseout="this.style.borderColor='rgba(30,42,68,0.10)'">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-lg flex items-center justify-center" style="background:rgba(30,42,68,0.06)">
                  <svg class="w-6 h-6" style="color:#1e2a44" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                </div>
                <div>
                  <h3 class="font-display text-lg" style="color:#1e2a44">{inst.name}</h3>
                  <span class="inline-flex items-center gap-1 font-ui text-xs mt-1" style="color:#c9a961">
                    Saiba mais
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== UNIDADES ========== -->
  <section class="section-padding" style="background:#ffffff">
    <div class="container">
      <div class="text-center mb-10 aos-element">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase" style="color:#c9a961">Localização</span>
        <h2 class="font-display text-2xl md:text-3xl mt-3 mb-4" style="color:#1e2a44">Unidades de Atendimento</h2>
        <p class="font-body text-sm max-w-lg mx-auto" style="color:#6b7280">
          A {doctor.name} atende em nossas unidades em São Paulo e Guarulhos.
        </p>
        <div class="gold-line max-w-[80px] mx-auto mt-4"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
        {[
          { name: "Guarulhos", href: "/contato#guarulhos", address: "Rua Sete de Setembro, 375 — Guarulhos" },
          { name: "Lapa", href: "/contato#lapa", address: "Rua Barão de Jundiaí, 221 — Lapa" },
          { name: "Santana", href: "/contato#santana", address: "Rua Dr. César, 130 — Santana" },
          { name: "São Miguel Paulista", href: "/contato#sao-miguel", address: "Rua Bernardo Marcondes, 108 — São Miguel Paulista" },
          { name: "Tatuapé", href: "/contato#tatuape", address: "Rua Tuiuti, 2429 — Tatuapé" },
        ].map(unit => (
          <a href={unit.href} class="group flex items-start gap-3 p-4 rounded-xl transition-all hover:shadow-md aos-element" style="border:1px solid rgba(30,42,68,0.10);background:#faf9f7" onmouseover="this.style.borderColor='rgba(201,169,97,0.40)'" onmouseout="this.style.borderColor='rgba(30,42,68,0.10)'">
            <svg class="w-5 h-5 shrink-0 mt-0.5" style="color:#c9a961" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <div class="flex-1">
              <span class="font-ui text-sm font-semibold" style="color:#1e2a44">{unit.name}</span>
              <p class="font-body text-xs mt-0.5" style="color:#6b7280">{unit.address}</p>
            </div>
            <svg class="w-4 h-4 shrink-0 mt-1" style="color:#6b7280" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== E-E-A-T: EXPERIÊNCIA, ESPECIALIZAÇÃO, AUTORIDADE, CONFIANÇA ========== -->
  <section class="section-padding" style="background:#faf9f7">
    <div class="container">
      <div class="text-center mb-12 aos-element">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase" style="color:#c9a961">EXPERIÊNCIA E AUTORIDADE</span>
        <h2 class="font-display text-3xl md:text-4xl mt-3 mb-4" style="color:#1e2a44">Formação, Afiliações e Reconhecimentos</h2>
        <p class="font-body text-base max-w-2xl mx-auto leading-relaxed" style="color:#6b7280">
          A Dra. Priscilla de Almeida combina experiência clínica, formação especializada e atuação científica para oferecer o mais alto padrão em oftalmologia.
        </p>
        <div class="gold-line max-w-[80px] mx-auto mt-6"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Formação Acadêmica -->
        <div class="bg-white rounded-xl p-6 shadow-sm aos-element" style="border:1px solid rgba(201,169,97,0.20)">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background:rgba(30,42,68,0.08)">
            <svg class="w-6 h-6" style="color:#1e2a44" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl mb-4" style="color:#1e2a44">Formação Acadêmica</h3>
          <ul class="space-y-3">
            {[
              "Graduação em Medicina",
              "Residência em Oftalmologia",
              "Especialização em Ceratocone e Córnea",
              "Fellowship em Adaptacão de Lentes de Contato Especiais",
              "Participação em congressos nacionais e internacionais de oftalmologia",
            ].map(item => (
              <li class="flex items-start gap-2 font-body text-sm" style="color:#6b7280">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color:#c9a961" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Afiliações e Sociedades -->
        <div class="bg-white rounded-xl p-6 shadow-sm aos-element" style="border:1px solid rgba(201,169,97,0.20)">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background:rgba(30,42,68,0.08)">
            <svg class="w-6 h-6" style="color:#1e2a44" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl mb-4" style="color:#1e2a44">Afiliações e Sociedades</h3>
          <ul class="space-y-3">
            {[
              "Conselho Regional de Medicina de São Paulo (CRM-SP)",
              "Conselho Brasileiro de Oftalmologia (CBO)",
              "Sociedade Brasileira de Córnea e Doenças Externas (SBCDE)",
              "Grupo Pan-Americano de Córnea (GPAC)",
              "American Academy of Ophthalmology (AAO) — Membro Internacional",
            ].map(item => (
              <li class="flex items-start gap-2 font-body text-sm" style="color:#6b7280">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color:#c9a961" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Reconhecimentos e Números -->
        <div class="bg-white rounded-xl p-6 shadow-sm aos-element" style="border:1px solid rgba(201,169,97,0.20)">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background:rgba(30,42,68,0.08)">
            <svg class="w-6 h-6" style="color:#1e2a44" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl mb-4" style="color:#1e2a44">Números e Reconhecimentos</h3>
          <div class="grid grid-cols-2 gap-4">
            {[
              { valor: "10+", label: "Anos de experiência" },
              { valor: "3.000+", label: "Pacientes atendidos" },
              { valor: "5★", label: "Avaliação média no Google" },
              { valor: "CRM", label: "Registro ativo CRM-SP" },
            ].map(item => (
              <div class="text-center p-3 rounded-lg" style="background:#faf9f7">
                <div class="font-display text-xl font-bold" style="color:#1e2a44">{item.valor}</div>
                <div class="font-ui text-[10px] mt-1" style="color:#6b7280">{item.label}</div>
              </div>
            ))}
          </div>
          <div class="mt-4 pt-4" style="border-top:1px solid #f0ece6">
            <p class="font-body text-xs leading-relaxed" style="color:#6b7280">
              A Dra. Priscilla de Almeida é reconhecida como referência nacional em ceratocone e adaptação de lentes de contato especiais, com avaliações consistentemente positivas de pacientes e colegas médicos.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA FINAL ========== -->
  <section class="relative section-padding overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image:url('/images/happy-family_6ee5e159.webp')"></div>
    <div class="absolute inset-0" style="background:rgba(30,42,68,0.88)"></div>
    <div class="relative container text-center z-10">
      <div class="aos-element">
        <span class="font-ui text-xs font-semibold tracking-[0.2em] uppercase mb-3 block" style="color:#c9a961">Agende Sua Consulta</span>
        <h2 class="font-display text-3xl md:text-4xl mb-4" style="color:#ffffff">Agende com a {doctor.name}</h2>
        <p class="font-body text-base max-w-lg mx-auto mb-8 leading-relaxed" style="color:rgba(255,255,255,0.70)">
          Entre em contato para agendar uma consulta. Atendemos diversos convênios e oferecemos opções de atendimento particular.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 font-ui text-sm font-bold px-7 py-3.5 rounded-md transition-colors"
            style="background:#c9a961;color:#1e2a44"
            onmouseover="this.style.background='#b8975a'"
            onmouseout="this.style.background='#c9a961'"
          >
            Agendar pelo WhatsApp
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="https://app.drudi.com.br" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 font-ui text-sm font-semibold px-7 py-3.5 rounded-md transition-colors"
            style="background:#1e2a44;color:#ffffff;border:1px solid rgba(245,240,232,0.30)"
            onmouseover="this.style.background='#162036'"
            onmouseout="this.style.background='#1e2a44'"
          >
            Agendar Online
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
