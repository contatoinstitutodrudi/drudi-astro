---
/**
 * Breadcrumb.astro — Componente padronizado de breadcrumb
 *
 * Uso:
 *   <Breadcrumb items={[
 *     { label: "Home", href: "/" },
 *     { label: "Institutos", href: "/institutos" },
 *     { label: "Instituto da Catarata" }   ← último item sem href = página atual
 *   ]} />
 *
 * Posição padrão: ACIMA do H1, dentro do hero.
 * Estilo: fonte font-ui text-xs, cor cream/55, separador chevron gold/60, item atual em gold.
 */

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className = "" } = Astro.props;
---

<nav
  class:list={["flex items-center flex-wrap gap-1.5 font-ui text-xs mb-5", className]}
  aria-label="Breadcrumb"
>
  {items.map((item, index) => {
    const isLast = index === items.length - 1;
    return (
      <>
        {isLast ? (
          <span
            class="text-gold font-semibold truncate max-w-[200px]"
            aria-current="page"
          >
            {item.label}
          </span>
        ) : (
          <a
            href={item.href}
            class="text-cream/55 hover:text-cream/90 transition-colors duration-150 whitespace-nowrap"
          >
            {item.label}
          </a>
        )}
        {!isLast && (
          <svg
            class="w-3 h-3 flex-shrink-0"
            style="color: rgba(201,168,76,0.5)"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <polyline points="9 18 15 12 9 6" />
          </svg>
        )}
      </>
    );
  })}
</nav>
