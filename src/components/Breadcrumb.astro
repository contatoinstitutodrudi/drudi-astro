---
/**
 * Breadcrumb.astro — Estilo card-pill dourado
 *
 * Uso:
 *   <Breadcrumb items={[
 *     { label: "Home", href: "/" },
 *     { label: "Institutos", href: "/institutos" },
 *     { label: "Instituto da Catarata" }   ← último item sem href = página atual
 *   ]} />
 *
 * Posição padrão: ACIMA do H1, dentro do hero.
 * Estilo: card-pill com fundo gold/13 e borda gold/30, separador chevron, item atual em gold.
 */

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className = "" } = Astro.props;
---

<nav
  aria-label="Breadcrumb"
  class:list={["inline-flex items-center flex-wrap gap-1.5 rounded-full px-4 py-1.5 mb-5 font-ui text-xs", className]}
  style="background:rgba(201,169,97,0.13);border:1px solid rgba(201,169,97,0.30)"
>
  {items.map((item, index) => {
    const isLast = index === items.length - 1;
    return (
      <>
        {isLast ? (
          <span
            class="font-semibold whitespace-nowrap"
            style="color:#c9a961"
            aria-current="page"
          >
            {item.label}
          </span>
        ) : (
          <a
            href={item.href}
            class="transition-colors duration-150 whitespace-nowrap"
            style="color:rgba(245,240,232,0.65)"
          >
            {item.label}
          </a>
        )}
        {!isLast && (
          <svg
            class="w-3 h-3 flex-shrink-0"
            style="color:rgba(201,169,97,0.50)"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <polyline points="9 18 15 12 9 6" />
          </svg>
        )}
      </>
    );
  })}
</nav>
