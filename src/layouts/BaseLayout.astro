---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonicalPath?: string;
  ogImage?: string;
  breadcrumbItems?: Array<{ name: string; item?: string }>;
  heroImage?: string;
  heroImageSrcset?: string;
  heroImageSizes?: string;
}

const {
  title,
  description,
  keywords = 'oftalmologista São Paulo, clínica de olhos SP, cirurgia de catarata, ceratocone, glaucoma, retina, estrabismo, Drudi e Almeida',
  canonicalPath = '/',
  ogImage = '/images/hero-monet-resized_00e348d0.webp',
  breadcrumbItems,
  heroImage,
  heroImageSrcset,
  heroImageSizes = '100vw',
} = Astro.props;

const siteUrl = 'https://institutodrudiealmeida.com.br';
// Garantir trailing slash para alinhar com o sitemap (evita "URL não canônica" no Search Console)
const canonicalUrl = `${siteUrl}${canonicalPath}`.replace(/\/?$/, '/');
const fullTitle = title.includes('Drudi') ? title : `${title} | Drudi e Almeida`;

// Mapa de rótulos para cada canonicalPath
const pathLabels: Record<string, { name: string; parent?: string; parentName?: string }> = {
  '/sobre': { name: 'Sobre Nós' },
  '/contato': { name: 'Contato' },
  '/tecnologia': { name: 'Tecnologia' },
  '/convenios': { name: 'Convênios' },
  '/arte-e-visao': { name: 'Arte e Visão' },
  '/blog': { name: 'Blog' },
  '/lgpd': { name: 'LGPD' },
  '/politica-de-privacidade': { name: 'Política de Privacidade' },
  '/instituto/catarata': { name: 'Instituto da Catarata', parent: '/institutos', parentName: 'Institutos' },
  '/instituto/ceratocone': { name: 'Instituto do Ceratocone', parent: '/institutos', parentName: 'Institutos' },
  '/instituto/glaucoma': { name: 'Instituto do Glaucoma', parent: '/institutos', parentName: 'Institutos' },
  '/instituto/retina': { name: 'Instituto da Retina', parent: '/institutos', parentName: 'Institutos' },
  '/instituto/estrabismo': { name: 'Instituto de Estrabismo', parent: '/institutos', parentName: 'Institutos' },
  '/medico/dr-fernando-drudi': { name: 'Dr. Fernando Drudi', parent: '/sobre', parentName: 'Sobre Nós' },
  '/medico/dra-priscilla-almeida': { name: 'Dra. Priscilla Almeida', parent: '/sobre', parentName: 'Sobre Nós' },
  '/unidade/guarulhos': { name: 'Guarulhos', parent: '/contato', parentName: 'Contato' },
  '/unidade/lapa': { name: 'Lapa', parent: '/contato', parentName: 'Contato' },
  '/unidade/santana': { name: 'Santana', parent: '/contato', parentName: 'Contato' },
  '/unidade/sao-miguel': { name: 'São Miguel Paulista', parent: '/contato', parentName: 'Contato' },
  '/unidade/tatuape': { name: 'Tatuapé', parent: '/contato', parentName: 'Contato' },
};

// Gerar itens do BreadcrumbList
type BreadcrumbListItem = { "@type": string; position: number; name: string; item?: string };

const breadcrumbSegments: BreadcrumbListItem[] = (() => {
  // Se breadcrumbItems for fornecido manualmente, usa-o
  if (breadcrumbItems) {
    return [
      { "@type": "ListItem", "position": 1, "name": "Início", "item": `${siteUrl}/` },
      ...breadcrumbItems.map((b, i) => ({
        "@type": "ListItem",
        "position": i + 2,
        "name": b.name,
        ...(b.item ? { "item": b.item } : {})
      }))
    ];
  }
  // Geração automática baseada no canonicalPath
  if (canonicalPath === '/') {
    return [{ "@type": "ListItem", "position": 1, "name": "Início", "item": `${siteUrl}/` }];
  }
  const info = pathLabels[canonicalPath];
  if (!info) {
    // Fallback genérico para paths não mapeados (ex: /blog/[slug])
    return [
      { "@type": "ListItem", "position": 1, "name": "Início", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": fullTitle.split(' |')[0], "item": canonicalUrl }
    ];
  }
  const items: BreadcrumbListItem[] = [
    { "@type": "ListItem", "position": 1, "name": "Início", "item": `${siteUrl}/` }
  ];
  if (info.parent && info.parentName) {
    items.push({ "@type": "ListItem", "position": 2, "name": info.parentName, "item": `${siteUrl}${info.parent}` });
    items.push({ "@type": "ListItem", "position": 3, "name": info.name, "item": canonicalUrl });
  } else {
    items.push({ "@type": "ListItem", "position": 2, "name": info.name, "item": canonicalUrl });
  }
  return items;
})();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Drudi e Almeida Clínicas Oftalmológicas" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Perf: Preload hero image — suportado em todas as páginas via prop heroImage -->
    {heroImage && (
      <link
        rel="preload"
        as="image"
        href={heroImage}
        imagesrcset={heroImageSrcset}
        imagesizes={heroImageSizes}
        fetchpriority="high"
      />
    )}
    {!heroImage && canonicalPath === '/' && (
      <link
        rel="preload"
        as="image"
        href="/images/hero-monet-resized_00e348d0.webp"
        imagesrcset="/images/hero-monet-480w.webp 480w, /images/hero-monet-768w.webp 768w, /images/hero-monet-resized_00e348d0.webp 1280w"
        imagesizes="100vw"
        fetchpriority="high"
      />
    )}

    <!-- Resource hints: preconnect + dns-prefetch para domínios externos -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
