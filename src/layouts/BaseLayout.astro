    <!-- Mobile menu JS -->
    <script is:inline>
      function initMobileMenu() {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        const overlay = document.getElementById('menu-overlay');
        if (!btn || !menu) return;
        let open = false;

        function openMenu() {
          open = true;
          if (overlay) overlay.style.display = 'block';
          menu.style.display = 'block';
          menu.getBoundingClientRect(); // force reflow for transition
          menu.style.transform = 'translateX(0)';
          document.body.style.overflow = 'hidden';
          const b1 = document.getElementById('bar1');
          const b2 = document.getElementById('bar2');
          const b3 = document.getElementById('bar3');
          if (b1 && b2 && b3) {
            b1.style.transform = 'translateY(8px) rotate(45deg)';
            b2.style.opacity = '0';
            b3.style.transform = 'translateY(-8px) rotate(-45deg)';
          }
        }

        function closeMenu() {
          open = false;
          menu.style.transform = 'translateX(100%)';
          document.body.style.overflow = '';
          const b1 = document.getElementById('bar1');
          const b2 = document.getElementById('bar2');
          const b3 = document.getElementById('bar3');
          if (b1 && b2 && b3) {
            b1.style.transform = '';
            b2.style.opacity = '1';
            b3.style.transform = '';
          }
          setTimeout(() => {
            if (!open) {
              menu.style.display = 'none';
              if (overlay) overlay.style.display = 'none';
            }
          }, 320);
        }

        // Hamburger — clone to remove stale listeners
        const newBtn = btn.cloneNode(true);
        btn.parentNode.replaceChild(newBtn, btn);
        newBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (open) closeMenu(); else openMenu();
        });

        // Close button inside drawer
        const closeBtn = document.getElementById('menu-close-btn');
        if (closeBtn) closeBtn.addEventListener('click', closeMenu);

        // Overlay click closes drawer
        if (overlay) overlay.addEventListener('click', closeMenu);

        // Close on nav link click
        menu.querySelectorAll('a.mob-link').forEach(link => {
          link.addEventListener('click', closeMenu);
        });

        // Accordion logic
        menu.querySelectorAll('.mob-accordion').forEach(acc => {
          const accBtn = acc.querySelector('.mob-acc-btn');
          const accContent = acc.querySelector('.mob-acc-content');
          const accIcon = acc.querySelector('.mob-acc-icon');
          if (!accBtn || !accContent) return;
          accBtn.addEventListener('click', () => {
            const isOpen = accContent.style.display === 'block';
            // Close all accordions
            menu.querySelectorAll('.mob-acc-content').forEach(c => { c.style.display = 'none'; });
            menu.querySelectorAll('.mob-acc-icon').forEach(i => { i.style.transform = ''; });
            // Toggle current
            if (!isOpen) {
              accContent.style.display = 'block';
              if (accIcon) accIcon.style.transform = 'rotate(180deg)';
            }
          });
        });
      }

      function initAOS() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('aos-visible');
            }
          });
        }, { threshold: 0.1 });
        document.querySelectorAll('.aos-element').forEach(el => observer.observe(el));
      }

      // Executar na carga inicial e em cada navegação do Astro
      document.addEventListener('astro:page-load', () => {
        initMobileMenu();
        initAOS();
      });

      // Fallback para carga direta (sem View Transitions)
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          initMobileMenu();
          initAOS();
        });
      } else {
        initMobileMenu();
        initAOS();
      }
    </script>
