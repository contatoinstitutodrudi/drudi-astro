      "medicalSpecialty": "http://schema.org/Optometric",
      "foundingDate": "2015",
      "numberOfEmployees": { "@type": "QuantitativeValue", "minValue": 10 },
      "areaServed": { "@type": "City", "name": "São Paulo" },
