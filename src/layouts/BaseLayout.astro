      ],
      "dateModified": "2026-03-31"
    })} />

    <!-- Schema.org: BreadcrumbList dinâmico — gerado automaticamente por canonicalPath -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbSegments
    })} />

    <!-- Slot para schemas específicos de página (Physician, LocalBusiness, FAQPage) -->
    <slot name="head-schema" />
    <!-- Slot para preloads específicos de página (hero images CSS background) -->
    <slot name="head-preload" />
  </head>
